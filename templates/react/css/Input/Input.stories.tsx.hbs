{{> react/stories-header}}
  argTypes: {
    variant:  { control: 'select', options: {{> shared/variant-options}} },
    size:     { control: 'select', options: {{> shared/size-options}} },
    disabled: { control: 'boolean' },
    required: { control: 'boolean' },
  },
{{> react/stories-footer}}

{{#if features.compoundComponents}}
export const Default: Story = {
  render: (args) => (
    <Input {...args}>
      <Input.Label>Username</Input.Label>
      <Input.Field placeholder="Enter your username" />
    </Input>
  ),
};

export const Error: Story = {
  args: { error: 'Invalid email address' },
  render: (args) => (
    <Input {...args}>
      <Input.Label>Email</Input.Label>
      <Input.Field defaultValue="invalid-email" />
      <Input.Error>{args.error}</Input.Error>
    </Input>
  ),
};

export const Password: Story = {
  render: (args) => (
    <Input {...args}>
      <Input.Label>Password</Input.Label>
      <Input.Field type="password" placeholder="Enter password" />
    </Input>
  ),
};

export const Disabled: Story = {
  args: { disabled: true },
  render: (args) => (
    <Input {...args}>
      <Input.Label>Account ID</Input.Label>
      <Input.Field value="ACC-12345" readOnly />
    </Input>
  ),
};

export const Required: Story = {
  args: { required: true },
  render: (args) => (
    <Input {...args}>
      <Input.Label>Full Name</Input.Label>
      <Input.Field placeholder="Jane Doe" />
    </Input>
  ),
};
{{else}}
export const Default: Story = {
  args: { label: 'Username', placeholder: 'Enter your username' },
};

export const Error: Story = {
  args: { label: 'Email', error: 'Invalid email address', defaultValue: 'invalid-email' },
};

export const Hint: Story = {
  args: { label: 'Password', hint: 'Must be at least 8 characters long', type: 'password' },
};

export const Disabled: Story = {
  args: { label: 'Account ID', disabled: true, value: 'ACC-12345' },
};

export const Required: Story = {
  args: { label: 'Full Name', required: true, placeholder: 'Jane Doe' },
};
{{/if}}
