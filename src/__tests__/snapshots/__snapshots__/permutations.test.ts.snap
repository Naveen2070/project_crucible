  --select-option-padding: calc(var(--spacing-unit) * 2.5);
  --select-dropdown-shadow: 0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -2px rgba(0,0,0,0.05);
  --select-z-index: 900;
  --table-row-height: calc(var(--spacing-unit) * 10);
  --table-header-height: calc(var(--spacing-unit) * 10);
  --table-border-radius: var(--radius-md);
  --table-pagination-height: calc(var(--spacing-unit) * 8);
  --table-virtual-overscan: 5;
  --table-cell-padding: calc(var(--spacing-unit) * 3);
  --table-row-hover-bg: var(--color-secondary);
  --table-striped-bg: var(--color-muted);
  --color-primary: #000;
  --color-secondary: #F3F2FF;
  --color-surface: #fff;
  --color-background: #F8F9FA;
  --color-border: #E2E1F0;
  --color-text: #1A1A2E;
  --color-text-muted: #6B6B8A;
  --color-destructive: #E24B4A;
  --color-success: #1D9E75;
  --color-primary-foreground: #fff;
  --color-secondary-foreground: #1A1A2E;
  --color-destructive-foreground: #fff;
  --color-accent-foreground: #1A1A2E;
  --foreground: #1A1A2E;
  --radius-sm: 4px;
  --radius-md: 4px;
  --radius-lg: 12px;
  --spacing-unit: 4px;
  --font-family: system-ui, sans-serif;
  --font-size-base: 16px;
}


.input-container {
  display:        flex;
  flex-direction: column;
  gap:            var(--spacing-unit);
  width:          100%;

  .label {
    font-family: var(--font-family);
    font-size:   14px;
    font-weight: 500;
    color:       var(--color-text);

    .required {
      color:       var(--color-destructive);
      margin-left: 2px;
    }
  }

  .input-wrapper {
    position: relative;
    width:    100%;

    .input {
      width:           100%;
      font-family:     var(--font-family);
      border: 1px solid var(--color-border);
      border-radius:   var(--radius-md);
      background:      var(--color-surface);
      color:           var(--color-text);
      transition:      border-color 0.15s ease, box-shadow 0.15s ease;
      box-sizing:      border-box;

      &:focus-visible {
        outline:        2px solid var(--color-primary);
        outline-offset: 3px;
        border-color:   var(--color-primary);
      }

      /* Sizes */
      &--sm { padding: 6px 10px;  font-size: 13px; }
      &--md { padding: 10px 14px; font-size: 15px; }
      &--lg { padding: 14px 18px; font-size: 17px; }
    }

    .password-toggle {
      position:   absolute;
      right:      12px;
      top:        50%;
      transform:  translateY(-50%);
      background: transparent;
      border:     none;
      padding:    0;
      margin:     0;
      font-family: var(--font-family);
      font-size:  12px;
      color:      var(--color-text-muted);
      cursor:     pointer;

      &:hover {
        color: var(--color-text);
      }
    }
  }

  &.input--error {
    .input {
      border-color: var(--color-destructive);
    }
  }

  &.input--disabled {
    .input {
      background: var(--color-background);
      cursor:     not-allowed;
      opacity:    0.7;
    }
  }

  .hint {
    color:       var(--color-text-muted);
    font-family: var(--font-family);
    font-size:   12px;
    margin-top:  2px;
  }

  .error {
    color:       var(--color-destructive);
    font-family: var(--font-family);
    font-size:   12px;
    margin-top:  2px;
  }
}
</style>
",
