:root {
{{#each tokens.cssVars}}  {{@key}}: {{this}};
{{/each}}
}

{{#if tokens.darkCssVars}}
@media (prefers-color-scheme: dark) {
  :root {
{{#each tokens.darkCssVars}}    {{@key}}: {{this}};
{{/each}}  }
}
{{/if}}

.input-container {
  display:        flex;
  flex-direction: column;
  gap:            var(--spacing-unit);
  width:          100%;
}

.label {
  font-family: var(--font-family);
  font-size:   14px;
  font-weight: 500;
  color:       var(--color-text);
}

.required {
  color:       var(--color-danger);
  margin-left: 2px;
}

.input {
  width:           100%;
  font-family:     var(--font-family);
  border:          1.5px solid var(--color-border);
  border-radius:   var(--radius-md);
  background:      var(--color-surface);
  color:           var(--color-text);
  transition:      border-color 0.15s ease, box-shadow 0.15s ease;
  box-sizing:      border-box;
}

{{#if a11y.focusRing}}
.input:focus-visible {
  outline:        {{a11y.focusRingWidth}} solid {{a11y.focusRingColor}};
  outline-offset: {{a11y.focusRingOffset}};
  border-color:   var(--color-primary);
}
{{/if}}

/* Sizes */
.input--sm { padding: 6px 10px;  font-size: 13px; }
.input--md { padding: 10px 14px; font-size: 15px; }
.input--lg { padding: 14px 18px; font-size: 17px; }

/* Variants */
.input--error {
  border-color: var(--color-danger);
}

.input--disabled {
  background: var(--color-background);
  cursor:     not-allowed;
  opacity:    0.7;
}

.hint, .error {
  font-family: var(--font-family);
  font-size:   12px;
}

.hint {
  color: var(--color-text-muted);
}

.error {
  color: var(--color-danger);
}
