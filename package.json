{
  "name": "@cruciblelab/crucible",
  "version": "1.0.1",
  "description": "Crucible — Code Generation Engine that generates style system/spec-based components for React, Vue, and Angular. No runtime dependencies. You own every file generated.",
  "main": "dist/cli/index.js",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "bin",
    "templates",
    "assets",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "audit:templates": "tsx scripts/audit-templates.ts",
    "prebuild": "npm run audit:templates",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "concurrently \"npm run build:watch\" \"npm run playground\"",
    "playground": "npm run dev --workspace=playground-react",
    "storybook": "npm run storybook --workspace=playground-react",
    "generate:dev": "node dist/cli/index.js add Button --dev",
    "test": "vitest",
    "test:e2e": "tsx scripts/e2e.ts",
    "test:coverage": "vitest --coverage",
    "chromatic": "chromatic --project-token=$CHROMATIC_PROJECT_TOKEN",
    "pg": "tsx scripts/generate-playground.ts",
    "pg:all": "tsx scripts/generate-playground.ts",
    "pg:react": "tsx scripts/generate-playground.ts react",
    "pg:angular": "tsx scripts/generate-playground.ts angular",
    "pg:vue": "tsx scripts/generate-playground.ts vue",
    "po": "tsx scripts/open-playground.ts",
    "po:react": "tsx scripts/open-playground.ts react",
    "po:angular": "tsx scripts/open-playground.ts angular",
    "po:vue": "tsx scripts/open-playground.ts vue",
    "pd": "tsx scripts/open-playground.ts dev",
    "pd:react": "tsx scripts/open-playground.ts dev react",
    "pd:angular": "tsx scripts/open-playground.ts dev angular",
    "pd:vue": "tsx scripts/open-playground.ts dev vue"
  },
  "workspaces": [
    "playground/*"
  ],
  "bin": {
    "crucible": "./bin/crucible.js"
  },
  "keywords": [
    "code-generation",
    "component-generator",
    "design-system",
    "style-system",
    "react-components",
    "vue-components",
    "angular-components",
    "tailwind",
    "css-modules",
    "scss",
    "cli",
    "scaffolding",
    "component-library",
    "style-system-engine",
    "component-spec",
    "aria",
    "accessibility",
    "dark-mode",
    "oklch"
  ],
  "author": "Naveen R",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Naveen2070/project_crucible"
  },
  "bugs": {
    "url": "https://github.com/Naveen2070/project_crucible"
  },
  "homepage": "https://github.com/Naveen2070/project_crucible#readme",
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "ajv": "^8.17.1",
    "chalk": "^4.1.2",
    "chokidar": "^5.0.0",
    "colorjs.io": "^0.6.1",
    "commander": "^13.1.0",
    "fs-extra": "^11.3.0",
    "handlebars": "^4.7.8"
  },
  "devDependencies": {
    "@storybook/addon-vitest": "^10.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/fs-extra": "^11.0.4",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^22.13.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.0.7",
    "concurrently": "^9.1.2",
    "eslint": "^9.21.0",
    "jsdom": "^29.0.1",
    "playwright": "^1.58.2",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.7",
    "vitest-axe": "^0.1.0"
  },
  "engines": {
    "node": ">=24.13.1"
  }
}
