  "Card.vue": "<script setup lang="ts">
import { computed } from 'vue';

export type CardVariant = 'default' | 'hoverable' | 'clickable';
export type CardSize    = 'sm' | 'md' | 'lg';

interface Props {
  title?:   string;
  variant?: CardVariant;
  size?:    CardSize;
}

const props = withDefaults(defineProps<Props>(), {
  title: '',
  variant: 'default',
  size: 'md',
});

const classes = computed(() => [
  'card',
  \`card--\${props.variant}\`,
  \`card--\${props.size}\`,
]);
</script>

<template>
  <div :class="classes" :tabindex="variant === 'clickable' ? 0 : undefined">
    <slot name="header">
      <div v-if="title || $slots.title || $slots.description || $slots.action" class="header">
        <slot name="title">
          <h3 v-if="title" class="title">{{title}}</h3>
        </slot>
        <slot name="description" />
        <slot name="action" />
      </div>
    </slot>
    
    <div class="content">
      <slot name="content">
        <slot />
      </slot>
    </div>

    <footer v-if="$slots.footer" class="footer">
      <slot name="footer" />
    </footer>
  </div>
</template>

<style scoped>
/* Generated by Crucible — edit freely, re-generate with --force */

