import { Component, Input } from '@angular/core';

@Component({
  selector: 'app-card',
  templateUrl: './card.component.html',
  styleUrls: ['./card.component.{{#if (eq styleSystem "scss")}}scss{{else}}css{{/if}}']
})
export class CardComponent {
  @Input() title = '';
  @Input() variant: {{> variant-types}} = 'default';
  @Input() size:    {{> size-types}} = 'md';

  get classes(): string {
    return [
      'card',
      `card--${this.variant}`,
      `card--${this.size}`
    ].filter(Boolean).join(' ');
  }
}
