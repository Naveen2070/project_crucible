/* Generated by Crucible — edit freely, re-generate with --force */

.card {
  --card-bg: {{tokens.componentTokens.card.backgroundColor}};
  --card-border: {{tokens.componentTokens.card.borderColor}};
  --card-radius: {{tokens.componentTokens.card.borderRadius}};
  --card-shadow: {{tokens.componentTokens.card.shadow}};
  --card-header-padding: {{tokens.componentTokens.card.headerPadding}};
  --card-content-padding: {{tokens.componentTokens.card.contentPadding}};
  --card-footer-padding: {{tokens.componentTokens.card.footerPadding}};

  display:        flex;
  flex-direction: column;
  background:     var(--card-bg);
  border:         1px solid var(--card-border);
  border-radius:  var(--card-radius);
  color:          var(--color-text);
  font-family:    var(--font-family);
  overflow:       hidden;
  text-align:     left;
  width:          100%;
  padding:        0;
  margin:         0;
  text-decoration: none;
  box-shadow:     var(--card-shadow);
}

{{#if a11y.focusRing}}
.card:focus-visible {
  outline:        {{a11y.focusRingWidth}} solid {{a11y.focusRingColor}};
  outline-offset: {{a11y.focusRingOffset}};
}
{{/if}}

/* Sizes */
.card--sm { max-width: 300px; }
.card--md { max-width: 450px; }
.card--lg { max-width: 600px; }

/* Variants */
.card--hoverable:hover {
  border-color: var(--color-primary);
  box-shadow:   0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
}

.card--clickable {
  cursor: pointer;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.card--clickable:hover {
  border-color: var(--color-primary);
  box-shadow:   0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
  transform:    translateY(-2px);
}

.card--clickable:active {
  transform:    translateY(0);
}

.header {
  padding: var(--card-header-padding);
}

.footer {
  padding: var(--card-footer-padding);
}

.card-header {
  padding: var(--card-header-padding);
}

.card-footer {
  padding: var(--card-footer-padding);
}
