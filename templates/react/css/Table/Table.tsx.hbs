export const Table = <T extends Record<string, unknown>>({
  columns,
  data,
  rowKey,
  variant = 'default',
  size = 'md',
  virtualize = false,
  virtualizationThreshold = 100,
  itemHeight = 44,
  customVirtualState,
  paginationMode = 'client',
  pageSize = 10,
  page = 1,
  totalPages: totalPagesProp,
  totalCount,
  onPageChange,
  sortKey,
  sortDirection,
  onSort,
  selectionMode = 'none',
  selectedRows = [],
  onSelect,
  onSelectAll,
  loading = false,
  emptyMessage = 'No data available',
  className,
}: TableProps<T>) => {
  const containerRef = useRef<HTMLDivElement>(null);
  const { shouldVirtualize, virtualState, handleScroll } = useVirtualizer(
    data.length,
    containerRef,
    { itemHeight, virtualizationThreshold, virtualize }
  );

  const effectiveVirtualState = customVirtualState || virtualState;
  const showVirtualContainer = shouldVirtualize && effectiveVirtualState;

  const [internalPage, setInternalPage] = useState(page);
  const [internalSortKey, setInternalSortKey] = useState(sortKey);
  const [internalSortDir, setInternalSortDir] = useState<SortDirection>(sortDirection || 'asc');
  const [internalSelected, setInternalSelected] = useState<string[]>(selectedRows);

  const processedData = useMemo(() => {
    let result = [...data];
    if (internalSortKey && onSort) {
      result = sort(result, internalSortKey, internalSortDir);
    }
    return result;
  }, [data, internalSortKey, internalSortDir, onSort]);

  const paginationResult = useMemo(() => {
    if (paginationMode === 'server') {
      return {
        data: processedData,
        pageInfo: {
          page,
          pageSize,
          totalItems: totalCount || 0,
          totalPages: totalPagesProp || 0,
          startIndex: 0,
          endIndex: processedData.length,
          hasNextPage: page < (totalPagesProp || 0),
          hasPrevPage: page > 1,
        },
      };
    }
    return getPageData(processedData, internalPage, pageSize);
  }, [processedData, paginationMode, page, pageSize, internalPage, totalPagesProp, totalCount]);

  const { data: displayData, pageInfo } = paginationResult;
  const pageNumbers = getPageNumbers(pageInfo.page, pageInfo.totalPages);

  const virtualItems = effectiveVirtualState?.virtualItems || [];
  const totalHeight = effectiveVirtualState?.totalHeight || 0;
  const offsetY = effectiveVirtualState?.offsetY || 0;

  const handleSort = useCallback((column: TableColumn) => {
    if (!column.sortable) return;
    const newDir = internalSortKey === column.key
      ? (internalSortDir === 'asc' ? 'desc' : 'asc')
      : 'asc';
    setInternalSortKey(column.key);
    setInternalSortDir(newDir);
    onSort?.(column.key, newDir);
  }, [internalSortKey, internalSortDir, onSort]);

  const handleSelect = useCallback((row: T) => {
    const key = String(row[rowKey]);
    let newSelected: string[];
    if (selectionMode === 'single') {
      newSelected = internalSelected.includes(key) ? [] : [key];
    } else {
      newSelected = internalSelected.includes(key)
        ? internalSelected.filter(k => k !== key)
        : [...internalSelected, key];
    }
    setInternalSelected(newSelected);
    onSelect?.(newSelected);
  }, [internalSelected, onSelect, selectionMode, rowKey]);

  const handleSelectAll = useCallback(() => {
    const allKeys = displayData.map(row => String(row[rowKey]));
    const newSelected = internalSelected.length === displayData.length
      ? []
      : allKeys;
    setInternalSelected(newSelected);
    onSelectAll?.(newSelected.length > 0);
  }, [displayData, internalSelected, onSelectAll, rowKey]);

  const isStriped = variant === 'striped';
  const isBordered = variant === 'bordered';
  const isCompact = variant === 'compact';

  const wrapperClasses = [
    styles.tableWrapper,
    isBordered ? styles.tableWrapperBordered : '',
    className,
  ].filter(Boolean).join(' ');

  const tableClasses = [
    styles.table,
    loading && styles.tableLoading,
  ].filter(Boolean).join(' ');

  const containerStyle: React.CSSProperties = showVirtualContainer
    ? { height: containerHeight, overflow: 'auto' }
    : {};

  const virtualContainerStyle: React.CSSProperties = { height: totalHeight, position: 'relative' };
  const stickyTableStyle: React.CSSProperties = { position: 'sticky' as const, top: 0 };
  const virtualBodyStyle: React.CSSProperties = { transform: `translateY(${offsetY}px)` };

  const renderRows = (items: T[], startIdx: number = 0) => {
    return items.map((row, idx) => {
      const key = String(row[rowKey]);
      const isSelected = internalSelected.includes(key);
      const actualIndex = startIdx + idx;

      return (
        <tr
          key={key}
          className={[
            styles.row,
            isStriped && actualIndex % 2 === 1 ? styles.rowStriped : '',
            isCompact ? styles.rowCompact : '',
            !isStriped && !isCompact ? styles.rowHover : '',
            isSelected ? styles.rowSelected : '',
          ].filter(Boolean).join(' ')}
        >
          {selectionMode !== 'none' && (
            <td className={[styles.cell, isCompact ? styles.cellCompact : ''].filter(Boolean).join(' ')}>
              <input
                type="checkbox"
                checked={isSelected}
                onChange={() => handleSelect(row)}
                className={styles.checkbox}
              />
            </td>
          )}
          {columns.map(col => (
            <td
              key={col.key}
              className={[
                styles.cell,
                isCompact ? styles.cellCompact : '',
                sizeClasses[size],
                alignClasses[col.align || 'left'],
                isBordered ? styles.cellBordered : '',
              ].filter(Boolean).join(' ')}
              style={col.width ? { width: col.width } : undefined}
            >
              {String(row[col.key] ?? '')}
            </td>
          ))}
        </tr>
      );
    });
  };

  const renderVirtualRows = () => {
    return virtualItems.map((item) => {
      const row = displayData[item.index];
      if (!row) return null;
      const key = String(row[rowKey]);
      const isSelected = internalSelected.includes(key);
      const rowStyle = {
        position: 'absolute' as const,
        top: item.start,
        width: '100%',
      };
      return (
        <tr
          key={`${key}-${item.index}`}
          className={[
            styles.row,
            isStriped && item.index % 2 === 1 ? styles.rowStriped : '',
            isCompact ? styles.rowCompact : '',
            !isStriped && !isCompact ? styles.rowHover : '',
            isSelected ? styles.rowSelected : '',
          ].filter(Boolean).join(' ')}
          style={rowStyle}
        >
          {selectionMode !== 'none' && (
            <td className={[styles.cell, isCompact ? styles.cellCompact : ''].filter(Boolean).join(' ')}>
              <input
                type="checkbox"
                checked={isSelected}
                onChange={() => handleSelect(row)}
                className={styles.checkbox}
              />
            </td>
          )}
          {columns.map(col => (
            <td
              key={col.key}
              className={[
                styles.cell,
                isCompact ? styles.cellCompact : '',
                sizeClasses[size],
                alignClasses[col.align || 'left'],
                isBordered ? styles.cellBordered : '',
              ].filter(Boolean).join(' ')}
              style={col.width ? { width: col.width } : undefined}
            >
              {String(row[col.key] ?? '')}
            </td>
          ))}
        </tr>
      );
    });
  };

  const headerCellClasses = (col: TableColumn) => [
    styles.headerCell,
    sizeClasses[size],
    col.sortable ? styles.headerCellSortable : '',
    alignClasses[col.align || 'left'],
    isBordered ? styles.headerCellBordered : '',
  ].filter(Boolean).join(' ');

  return (
    <div className={wrapperClasses}>
      <div ref={containerRef} className={showVirtualContainer ? styles.tableContainer : undefined} onScroll={showVirtualContainer ? handleScroll : undefined} style={containerStyle}>
        {showVirtualContainer ? (
          <div style={virtualContainerStyle}>
            <table className={tableClasses} role="grid" style={stickyTableStyle}>
              <thead className={styles.thead}>
                <tr className={styles.headerRow}>
                  {selectionMode !== 'none' && (
                    <th className={[styles.headerCell, isBordered ? styles.headerCellBordered : ''].filter(Boolean).join(' ')}>
                      <input
                        type="checkbox"
                        checked={internalSelected.length === displayData.length && displayData.length > 0}
                        onChange={handleSelectAll}
                        className={styles.checkbox}
                      />
                    </th>
                  )}
                  {columns.map(col => (
                    <th
                      key={col.key}
                      className={headerCellClasses(col)}
                      style={col.width ? { width: col.width } : undefined}
                      onClick={() => handleSort(col)}
                      role={col.sortable ? 'columnheader' : undefined}
                      aria-sort={internalSortKey === col.key ? (internalSortDir === 'asc' ? 'ascending' : 'descending') : undefined}
                    >
                      {col.label}
                      {col.sortable && internalSortKey === col.key && (
                        <span className={styles.sortIcon}>{internalSortDir === 'asc' ? '↑' : '↓'}</span>
                      )}
                    </th>
                  ))}
                </tr>
              </thead>
              <tbody className={styles.tbody} style={virtualBodyStyle}>
                {renderVirtualRows()}
              </tbody>
            </table>
          </div>
        ) : (
          <table className={tableClasses} role="grid">
            <thead className={styles.thead}>
              <tr className={styles.headerRow}>
                  {selectionMode !== 'none' && (
                    <th className={[styles.headerCell, isBordered ? styles.headerCellBordered : ''].filter(Boolean).join(' ')}>
                    <input
                      type="checkbox"
                      checked={internalSelected.length === displayData.length && displayData.length > 0}
                      onChange={handleSelectAll}
                      className={styles.checkbox}
                    />
                  </th>
                )}
                {columns.map(col => (
                  <th
                    key={col.key}
                    className={headerCellClasses(col)}
                    style={col.width ? { width: col.width } : undefined}
                    onClick={() => handleSort(col)}
                    role={col.sortable ? 'columnheader' : undefined}
                    aria-sort={internalSortKey === col.key ? (internalSortDir === 'asc' ? 'ascending' : 'descending') : undefined}
                  >
                    {col.label}
                    {col.sortable && internalSortKey === col.key && (
                      <span className={styles.sortIcon}>{internalSortDir === 'asc' ? '↑' : '↓'}</span>
                    )}
                  </th>
                ))}
              </tr>
            </thead>
            <tbody className={styles.tbody}>
              {displayData.length === 0 && !loading ? (
                <tr>
                  <td colSpan={columns.length + (selectionMode !== 'none' ? 1 : 0)} className={styles.emptyRow}>
                    {emptyMessage}
                  </td>
                </tr>
              ) : (
                renderRows(displayData)
              )}
            </tbody>
          </table>
        )}
      </div>

      {paginationMode === 'client' && pageInfo.totalPages > 1 && (
        <div className={styles.pagination}>
          <div className={styles.paginationInfo}>
            Showing {pageInfo.startIndex + 1} to {pageInfo.endIndex} of {pageInfo.totalItems} results
          </div>
          <div className={styles.paginationButtons}>
            <button
              onClick={() => {
                const newPage = internalPage - 1;
                setInternalPage(newPage);
                onPageChange?.(newPage, pageSize);
              }}
              disabled={!pageInfo.hasPrevPage}
              className={styles.paginationBtn}
            >
              Previous
            </button>
            {pageNumbers.map(p => (
              <button
                key={p}
                onClick={() => {
                  setInternalPage(p);
                  onPageChange?.(p, pageSize);
                }}
                className={[
                  styles.paginationBtn,
                  p === internalPage ? styles.paginationBtnActive : '',
                ].filter(Boolean).join(' ')}
              >
                {p}
              </button>
            ))}
            <button
              onClick={() => {
                const newPage = internalPage + 1;
                setInternalPage(newPage);
                onPageChange?.(newPage, pageSize);
              }}
              disabled={!pageInfo.hasNextPage}
              className={styles.paginationBtn}
            >
              Next
            </button>
          </div>
        </div>
      )}
    </div>
  );
};

Table.displayName = 'Table';
{{/if}}
