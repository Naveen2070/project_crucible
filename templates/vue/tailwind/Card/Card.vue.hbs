<script setup lang="ts">
import { computed } from 'vue';

export type CardVariant = {{#each variants}}'{{this}}'{{#unless @last}} | {{/unless}}{{/each}};
export type CardSize    = {{#each sizes}}'{{this}}'{{#unless @last}} | {{/unless}}{{/each}};

interface Props {
  variant?: CardVariant;
  size?:    CardSize;
  title?:   string;
  href?:    string;
}

const props = withDefaults(defineProps<Props>(), {
  variant: 'default',
  size: 'md',
  title: '',
});

const emit = defineEmits(['click']);

const onClick = (event: MouseEvent) => {
  emit('click', event);
};

const variantClasses: Record<CardVariant, string> = {
{{#each variants}}  {{this}}: '{{lookup ../tailwindVariants this}}',
{{/each}}};

const sizeClasses: Record<CardSize, string> = {
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8',
};

const isClickable = computed(() => props.variant === 'clickable' || !!props.href);

const componentTag = computed(() => {
  if (props.href) return 'a';
  if (isClickable.value) return 'button';
  return 'article';
});

const classes = computed(() => [
  'rounded-[var(--radius-lg)] border-[1.5px] transition-all text-left w-full block overflow-hidden',
  {{#if a11y.focusRing}}'focus-visible:outline focus-visible:outline-2 focus-visible:outline-[{{a11y.focusRingColor}}] focus-visible:outline-offset-2',{{/if}}
  variantClasses[props.variant],
  sizeClasses[props.size],
]);
</script>

<template>
  <component
    :is="componentTag"
    :class="classes"
    :href="href"
    :role="isClickable && !href ? 'button' : undefined"
    :tabindex="isClickable ? 0 : undefined"
    @click="onClick"
  >
    {{#if features.compoundComponents}}
    <slot name="title">
      <div v-if="title" class="font-bold text-lg mb-2 text-[var(--color-text)]">
        \{{ title }}
      </div>
    </slot>
    {{else}}
    <div v-if="title" class="font-bold text-lg mb-2 text-[var(--color-text)]">
      \{{ title }}
    </div>
    {{/if}}
    <div class="text-[var(--color-text-muted)]">
      <slot />
    </div>
  </component>
</template>
