<div class="input-container" [class]="classes">
  <label *ngIf="label" [attr.for]="id" class="label">
    \{{ label }}
    <span *ngIf="required" class="required" aria-hidden="true">*</span>
  </label>
  
  <div class="input-wrapper">
    <input
      [id]="id"
      type="text"
      class="input"
      [placeholder]="placeholder"
      [disabled]="disabled"
      [attr.aria-invalid]="!!error"
      [attr.aria-required]="required"
    />
  </div>

  <span *ngIf="hint && !error" class="hint">\{{ hint }}</span>
  <span *ngIf="error" class="error" role="alert">\{{ error }}</span>
</div>
