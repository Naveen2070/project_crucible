",
  "input.component.html": "<div [class]="containerClasses">
  @if (label) {
    <label [attr.for]="id" class="block text-sm font-medium mb-1.5 text-[var(--color-text)]">
      {{ label }}
      @if (required) {
        <span class="text-[var(--color-destructive)]" aria-hidden="true">*</span>
      }
    </label>
  }
  <ng-content select="[label]"></ng-content>
  
  <div class="relative">
    <ng-content select="[field]">
      <input
        [id]="id"
        [type]="currentType"
        [class]="inputClasses"
        [placeholder]="placeholder"
        [disabled]="disabled"
        [attr.aria-invalid]="!!error"
        [attr.aria-required]="required"
        [attr.aria-describedby]="describedBy"
      >
      
      @if (type === 'password') {
        <button
          type="button"
          class="absolute right-3 top-1/2 -translate-y-1/2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors"
          (click)="togglePassword()"
          [attr.aria-label]="showPassword ? 'Hide password' : 'Show password'"
          [attr.aria-pressed]="showPassword"
        >
          {{ showPassword ? 'Hide' : 'Show' }}
        </button>
      }
    </ng-content>
  </div>

  @if (hint && !error) {
    <p [id]="hintId" class="mt-1.5 text-xs text-[var(--color-text-muted)]">
      {{ hint }}
    </p>
  }
  <ng-content select="[hint]"></ng-content>

  @if (error) {
    <p [id]="errorId" class="mt-1.5 text-xs text-[var(--color-destructive)]" role="alert">
      {{ error }}
    </p>
  }
  <ng-content select="[error]"></ng-content>
</div>
",
  "input.component.ts": "import { Component, Input } from '@angular/core';

const variantClasses: Record<string, string> = {
  default: 'bg-[var(--color-surface)] border-[var(--color-border)] focus:border-[var(--color-primary)]',
  error: 'bg-[var(--color-surface)] border-[var(--color-destructive)] focus:border-[var(--color-destructive)]',
 };

const sizeClasses: Record<string, string> = {
  sm: 'px-3 py-1.5 text-sm',
  md: 'px-4 py-2 text-base',
  lg: 'px-5 py-3 text-lg',
};

@Component({
  selector: 'app-input',
  templateUrl: './input.component.html'
})
export class InputComponent {
  private static nextId = 0;
  @Input() id = \`input-\${InputComponent.nextId++}\`;
  @Input() label = '';
  @Input() placeholder = '';
  @Input() variant: 'default' | 'error' = 'default';
  @Input() size:    'sm' | 'md' | 'lg' = 'md';
  @Input() error = '';
  @Input() hint = '';
  @Input() disabled = false;
  @Input() required = false;
  @Input() type: 'text' | 'password' = 'text';
  @Input() className = '';

  showPassword = false;

  togglePassword() {
    this.showPassword = !this.showPassword;
  }

  get currentType(): string {
    if (this.type === 'password') {
      return this.showPassword ? 'text' : 'password';
    }
    return this.type;
  }

  get containerClasses(): string {
    return [
      'flex flex-col gap-[var(--spacing-unit)] w-full',
      this.className
    ].filter(Boolean).join(' ');
  }

  get inputClasses(): string {
    return [
      'w-full border-[1.5px] rounded-[var(--radius-md)] outline-none transition-all bg-[var(--color-surface)]',
      'focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] focus-visible:ring-offset-2',
      'disabled:opacity-50 disabled:cursor-not-allowed',
      variantClasses[this.variant],
      sizeClasses[this.size],
      this.type === 'password' ? 'pr-12' : '',
      (this.variant === 'error' || this.error) ? 'border-[var(--color-destructive)]' : ''
    ].filter(Boolean).join(' ');
  }

  get errorId(): string {
    return \`\${this.id}-error\`;
  }

  get hintId(): string {
    return \`\${this.id}-hint\`;
  }

  get describedBy(): string | null {
    const ids = [];
    if (this.error) ids.push(this.errorId);
    if (this.hint) ids.push(this.hintId);
    return ids.length ? ids.join(' ') : null;
  }
}
",
}
`;

