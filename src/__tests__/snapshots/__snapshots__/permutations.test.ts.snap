  "button.component.css": "/* Generated by Crucible — edit freely, re-generate with --force */

.btn {
  --btn-radius: var(--radius-md);
  --btn-font-weight: 500;
  --btn-transition: background-color 0.2s ease, color 0.2s ease, box-shadow 0.2s ease;

  display:         inline-flex;
  align-items:     center;
  justify-content: center;
  gap:             calc(var(--spacing-unit) * 2);
  font-family:     var(--font-family);
  font-weight:     var(--btn-font-weight);
  border:          1px solid transparent;
  cursor:          pointer;
  border-radius:   var(--btn-radius);
  transition:      var(--btn-transition);
}

.btn:focus-visible {
  outline: none;
  box-shadow: 0 0 0 2px var(--color-background), 0 0 0 4px var(--color-primary);
}

@media (prefers-reduced-motion: reduce) {
  .btn { transition: none; }
}

/* Sizes - standard: xs, sm, md, lg, icon */
.btn--xs    { min-height: 2rem; padding: 0 0.5rem; font-size: 0.75rem; }
.btn--sm    { min-height: calc(var(--spacing-unit) * 9); padding: 0 calc(var(--spacing-unit) * 3); font-size: 0.875rem; }
.btn--md    { min-height: calc(var(--spacing-unit) * 10); padding: 0 calc(var(--spacing-unit) * 4); font-size: 1rem; }
.btn--lg    { min-height: calc(var(--spacing-unit) * 11); padding: 0 calc(var(--spacing-unit) * 8); font-size: 1.125rem; }
.btn--icon  { min-height: 2.5rem; width: 2.5rem; padding: 0; }

/* Variants - standard */
.btn--default   { background: var(--color-primary);   color: var(--color-primary-foreground); border-color: transparent; }
.btn--primary   { background: var(--color-primary);   color: var(--color-primary-foreground); border-color: transparent; }
.btn--secondary { background: var(--color-secondary); color: var(--color-secondary-foreground); border-color: transparent; }
.btn--outline   { background: transparent;           color: var(--color-foreground);        border-color: var(--color-border); }
.btn--ghost     { background: transparent;           color: var(--color-foreground);        border-color: transparent; }
.btn--link      { background: transparent;           color: var(--color-primary);           border-color: transparent; text-decoration: underline; text-underline-offset: 4px; }
.btn--destructive { background: var(--color-destructive); color: var(--color-destructive-foreground); border-color: transparent; }

.btn--default:not(:disabled):hover     { opacity: 0.9; }
.btn--primary:not(:disabled):hover   { opacity: 0.9; }
.btn--secondary:not(:disabled):hover { background: var(--color-secondary); opacity: 0.8; }
.btn--outline:not(:disabled):hover   { background: var(--color-accent); color: var(--color-accent-foreground); }
.btn--ghost:not(:disabled):hover     { background: var(--color-accent); color: var(--color-accent-foreground); }
.btn--link:not(:disabled):hover      { text-decoration: underline; }
.btn--destructive:not(:disabled):hover { opacity: 0.9; }

/* States */
.btn--disabled, .btn:disabled { opacity: 0.45; cursor: not-allowed; }
.btn--loading  { cursor: wait; }

.spinner {
  width: 1em; height: 1em;
  border: 2px solid currentColor;
  border-top-color: transparent;
  border-radius: 50%;
  animation: spin 0.6s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
",
  "button.component.html": "<button
  class="btn"
  [class.btn--default]="variant === 'default'"
  [class.btn--primary]="variant === 'primary'"
  [class.btn--secondary]="variant === 'secondary'"
  [class.btn--outline]="variant === 'outline'"
  [class.btn--ghost]="variant === 'ghost'"
  [class.btn--link]="variant === 'link'"
  [class.btn--destructive]="variant === 'destructive'"
  [class.btn--xs]="size === 'xs'"
  [class.btn--sm]="size === 'sm'"
  [class.btn--md]="size === 'md'"
  [class.btn--lg]="size === 'lg'"
  [class.btn--icon]="size === 'icon'"
  [class.btn--loading]="loading"
  [disabled]="disabled || loading"
  [attr.aria-disabled]="disabled || loading"
  [attr.aria-busy]="loading"
>
  <ng-content select="[btn-spinner]"></ng-content>
  @if (loading) {
    <span class="spinner" aria-hidden="true"></span>
  }
  <ng-content select="[btn-icon]"></ng-content>
  <ng-content select="[btn-label]"></ng-content>
  <ng-content></ng-content>
</button>
",
  "button.component.ts": "import { Component, Input } from '@angular/core';
import { CommonModule } from '@angular/common';

@Component({
  selector: 'app-button',
  standalone: true,
  imports: [CommonModule],
  templateUrl: './button.component.html',
  styleUrls: ['./button.component.css'],
})
export class ButtonComponent {
  @Input() variant: 'default' | 'primary' | 'secondary' | 'outline' | 'ghost' | 'link' | 'destructive' = 'default';
  @Input() size: 'xs' | 'sm' | 'md' | 'lg' | 'icon' = 'xs';
  @Input() disabled = false;
  @Input() loading = false;
}
",
}
`;

