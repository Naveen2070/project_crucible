{{> react/stories-header}}
  argTypes: {
    variant: { control: 'select', options: {{> shared/variant-options}} },
    size:    { control: 'select', options: {{> shared/size-options}} },
  },
{{> react/stories-footer}}

{{#if features.compoundComponents}}
export const Default: Story = {
  args: { variant: 'default', size: 'md' },
  render: (args) => (
    <Card {...args}>
      <Card.Header>
        <h3 style=\{{ margin: 0 }}>Card Title</h3>
      </Card.Header>
      <Card.Content>
        This is a default card with some content inside it.
      </Card.Content>
    </Card>
  ),
};

{{#each variants}}
{{#unless (eq this "default")}}
export const {{capitalize this}}: Story = {
  args: { variant: '{{this}}' },
  render: (args) => (
    <Card {...args}>
      <Card.Header>
        <h3 style=\{{ margin: 0 }}>{{capitalize this}} Variant</h3>
      </Card.Header>
      <Card.Content>
        Card content with {{this}} variant.
      </Card.Content>
    </Card>
  ),
};
{{/unless}}
{{/each}}

{{#each sizes}}
export const {{capitalize this}}: Story = {
  args: { size: '{{this}}' },
  render: (args) => (
    <Card {...args}>
      <Card.Header>
        <h3 style=\{{ margin: 0 }}>{{capitalize this}} Size</h3>
      </Card.Header>
      <Card.Content>
        Card content with {{this}} size.
      </Card.Content>
    </Card>
  ),
};
{{/each}}

export const WithFooter: Story = {
  render: (args) => (
    <Card {...args}>
      <Card.Header>
        <h3 style=\{{ margin: 0 }}>Card with Footer</h3>
      </Card.Header>
      <Card.Content>
        The footer can contain actions or additional information.
      </Card.Content>
      <Card.Footer>
        <div style=\{{ display: 'flex', gap: '8px', justifyContent: 'flex-end' }}>
          <button style=\{{ padding: '4px 8px' }}>Cancel</button>
          <button style=\{{ padding: '4px 8px' }}>Confirm</button>
        </div>
      </Card.Footer>
    </Card>
  ),
};
{{else}}
export const Default: Story = {
  args: {
    title:    'Card Title',
    children: 'This is a default card with some content inside it.',
    size: 'md',
  },
};

{{#each variants}}
{{#unless (eq this "default")}}
export const {{capitalize this}}: Story = {
  args: {
    variant:  '{{this}}',
    title:    '{{capitalize this}} Variant',
    children: 'Card content with {{this}} variant.',
  },
};
{{/unless}}
{{/each}}

{{#each sizes}}
export const {{capitalize this}}: Story = {
  args: {
    size:  '{{this}}',
    title:    '{{capitalize this}} Size',
    children: 'Card content with {{this}} size.',
  },
};
{{/each}}
{{/if}}
