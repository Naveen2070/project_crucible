<script setup lang="ts">
import { ref, computed } from 'vue';

export type SelectVariant = {{#each variants}}'{{this}}'{{#unless @last}} | {{/unless}}{{/each}};
export type SelectSize    = {{#each sizes}}'{{this}}'{{#unless @last}} | {{/unless}}{{/each}};

interface Props {
  options?:     any[];
  value?:       any;
  label?:       string;
  placeholder?: string;
  variant?:     SelectVariant;
  size?:        SelectSize;
  error?:       string;
  disabled?:    boolean;
}

const props = withDefaults(defineProps<Props>(), {
  options: () => [],
  value: null,
  label: '',
  placeholder: 'Select an option',
  variant: 'default',
  size: 'md',
  error: '',
  disabled: false,
});

const emit = defineEmits(['update:value']);

const isOpen = ref(false);
const activeIndex = ref(-1);
const searchString = ref('');
let searchTimeout: any;

const toggle = () => {
  if (!props.disabled) {
    isOpen.value = !isOpen.value;
    if (isOpen.value) {
      activeIndex.value = props.options.findIndex(o => o === props.value || o.value === props.value);
      if (activeIndex.value === -1) activeIndex.value = 0;
    }
  }
};

const handleKeyDown = (e: KeyboardEvent) => {
  if (props.disabled) return;

  // Type-ahead
  if (e.key.length === 1 && !e.ctrlKey && !e.metaKey && !e.altKey) {
    searchString.value += e.key.toLowerCase();
    if (searchTimeout) clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
      searchString.value = '';
    }, 500);

    const matchIndex = props.options.findIndex((opt) =>
      (opt.label || opt).toLowerCase().startsWith(searchString.value)
    );

    if (matchIndex >= 0) {
      activeIndex.value = matchIndex;
      if (!isOpen.value) {
        selectOption(props.options[matchIndex]);
      }
    }
    return;
  }

  if (!isOpen.value) {
    if (e.key === 'Enter' || e.key === ' ' || e.key === 'ArrowDown' || e.key === 'ArrowUp') {
      e.preventDefault();
      toggle();
    }
    return;
  }

  switch (e.key) {
    case 'ArrowDown':
      e.preventDefault();
      activeIndex.value = Math.min(activeIndex.value + 1, props.options.length - 1);
      break;
    case 'ArrowUp':
      e.preventDefault();
      activeIndex.value = Math.max(activeIndex.value - 1, 0);
      break;
    case 'Enter':
    case ' ':
      e.preventDefault();
      if (activeIndex.value >= 0) {
        selectOption(props.options[activeIndex.value]);
      }
      break;
    case 'Escape':
      isOpen.value = false;
      break;
    case 'Home':
      activeIndex.value = 0;
      break;
    case 'End':
      activeIndex.value = props.options.length - 1;
      break;
  }
};

const selectOption = (option: any) => {
  emit('update:value', option);
  isOpen.value = false;
};

const displayValue = computed(() => {
  return props.value ? (props.value.label || props.value) : props.placeholder;
});

const comboboxClasses = computed(() => [
  'combobox',
  `combobox--${props.size}`,
  {
    'combobox--error': props.variant === 'error' || props.error,
    'combobox--disabled': props.disabled,
    'combobox--open': isOpen.value,
  },
]);
</script>

<template>
  <div class="container">
    {{#if features.compoundComponents}}
    <slot name="label">
      <label v-if="label" class="label">\{{ label }}</label>
    </slot>
    {{else}}
    <label v-if="label" class="label">\{{ label }}</label>
    {{/if}}
    
    <div
      :class="comboboxClasses"
      @click="toggle"
      @keydown="handleKeyDown"
      :aria-expanded="isOpen"
      role="combobox"
      aria-haspopup="listbox"
      tabindex="0"
    >
      {{#if features.compoundComponents}}
      <slot name="value">
        <span class="value">\{{ displayValue }}</span>
      </slot>
      <slot name="arrow">
        <span class="arrow" aria-hidden="true">▼</span>
      </slot>
      {{else}}
      <span class="value">\{{ displayValue }}</span>
      <span class="arrow" aria-hidden="true">▼</span>
      {{/if}}
    </div>

    <ul v-if="isOpen" class="listbox" role="listbox">
      {{#if features.compoundComponents}}
      <slot name="listbox">
        <li
          v-for="option in options"
          :key="option.value || option"
          @click="selectOption(option)"
          :class="['option', { 'option--selected': value === option }]"
          role="option"
        >
          <slot name="option" :option="option">
            \{{ option.label || option }}
          </slot>
        </li>
      </slot>
      {{else}}
      <li
        v-for="(option, i) in options"
        :key="option.value || option"
        @click="selectOption(option)"
        :class="['option', { 'option--selected': value === option, 'option--active': activeIndex === i }]"
        role="option"
      >
        \{{ option.label || option }}
      </li>
      {{/if}}
    </ul>

    {{#if features.compoundComponents}}
    <slot name="error">
      <span v-if="error" class="error" role="alert">\{{ error }}</span>
    </slot>
    {{else}}
    <span v-if="error" class="error" role="alert">\{{ error }}</span>
    {{/if}}
  </div>
</template>

