import type { Meta, StoryObj } from '@storybook/vue3';
import { ref } from 'vue';
import Select from './Select.vue';

const meta: Meta<typeof Select> = {
  title: 'Crucible/{{name}}',
  component: Select,
  argTypes: {
    variant:  { control: 'select', options: {{> shared/variant-options}} },
    size:     { control: 'select', options: {{> shared/size-options}} },
    disabled: { control: 'boolean' },
  },
};

export default meta;
type Story = StoryObj<typeof Select>;

const options = [
  { label: 'Option 1', value: '1' },
  { label: 'Option 2', value: '2' },
  { label: 'Option 3', value: '3' },
];

export const Default: Story = {
  args: {
    label: 'Select Option',
    options,
    placeholder: 'Pick one...',
    size: 'md',
    variant: 'default',
  },
  render: (args) => ({
    components: { Select },
    setup() {
      const value = ref(null);
      return { args, value };
    },
    template: `<Select v-bind="args" v-model="value" />`,
  }),
};

{{#each variants}}
{{#unless (eq this "default")}}
export const {{capitalize this}}: Story = {
  args: { variant: '{{this}}', label: '{{capitalize this}} Variant', options },
  render: (args) => ({
    components: { Select },
    setup() {
      const value = ref(null);
      return { args, value };
    },
    template: `<Select v-bind="args" v-model="value" />`,
  }),
};
{{/unless}}
{{/each}}

{{#each sizes}}
export const {{capitalize this}}: Story = {
  args: { size: '{{this}}', label: '{{capitalize this}} Size', options },
  render: (args) => ({
    components: { Select },
    setup() {
      const value = ref(null);
      return { args, value };
    },
    template: `<Select v-bind="args" v-model="value" />`,
  }),
};
{{/each}}

export const WithError: Story = {
  args: {
    label: 'Select Option',
    options,
    error: 'Selection is required',
  },
  render: (args) => ({
    components: { Select },
    setup() {
      const value = ref(null);
      return { args, value };
    },
    template: `<Select v-bind="args" v-model="value" />`,
  }),
};

export const Disabled: Story = {
  args: {
    label: 'Disabled Select',
    options,
    disabled: true,
    modelValue: options[0],
  },
  render: (args) => ({
    components: { Select },
    setup() {
      const value = ref(args.modelValue);
      return { args, value };
    },
    template: `<Select v-bind="args" v-model="value" />`,
  }),
};

{{#if features.compoundComponents}}
export const WithSlots: Story = {
  args: {
    label: 'Custom Select',
    options,
    placeholder: 'Custom style...',
  },
  render: (args) => ({
    components: { Select },
    setup() {
      const value = ref(null);
      return { args, value };
    },
    template: `
<Select v-bind="args" v-model="value">
  <template #label>
    <label style="color: var(--color-success); font-weight: bold;">[CUSTOM LABEL]</label>
  </template>
  <template #icon>
    <span style="transform: rotate(90deg); display: inline-block;">-></span>
  </template>
  <template #item="{ option }">
    <span style="color: var(--color-text);">Option: \{{ typeof option === 'object' ? option.label : option }}</span>
  </template>
</Select>`,
  }),
};
{{/if}}
