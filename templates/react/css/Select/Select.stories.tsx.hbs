{{> react/stories-header}}
  argTypes: {
    variant:  { control: 'select', options: {{> shared/variant-options}} },
    size:     { control: 'select', options: {{> shared/size-options}} },
    disabled: { control: 'boolean' },
  },
{{> react/stories-footer}}


{{#if features.compoundComponents}}
export const Default: Story = {
  args: { variant: 'default', size: 'md' },
  render: (args) => {
    const [value, setValue] = useState('');
    return (
      <Select {...args} value={value} onChange={setValue}>
        <Select.Label>Country</Select.Label>
        <Select.Trigger>
          <Select.Value placeholder="Choose a country..." />
          <Select.Icon />
        </Select.Trigger>
        <Select.Content>
          <Select.Item value="us" label="United States" />
          <Select.Item value="ca" label="Canada" />
          <Select.Item value="uk" label="United Kingdom" />
          <Select.Item value="au" label="Australia" />
        </Select.Content>
      </Select>
    );
  },
};

{{#each variants}}
{{#unless (eq this "default")}}
export const {{capitalize this}}: Story = {
{{#if (eq this "error")}}
  args: { variant: '{{this}}', error: 'Please select an option' },
{{else}}
  args: { variant: '{{this}}' },
{{/if}}
  render: (args) => {
    const [value, setValue] = useState('');
    return (
      <Select {...args} value={value} onChange={setValue}>
        <Select.Label>{{capitalize this}} Variant</Select.Label>
        <Select.Trigger>
          <Select.Value placeholder="Choose one..." />
          <Select.Icon />
        </Select.Trigger>
        <Select.Content>
          <Select.Item value="1" label="Option 1" />
          <Select.Item value="2" label="Option 2" />
        </Select.Content>
        {{#if (eq this "error")}}
        {args.error && <span style=\{{ color: 'var(--color-destructive)', fontSize: '0.75rem', marginTop: '0.25rem' }}>{args.error}</span>}
        {{/if}}
      </Select>
    );
  },
};
{{/unless}}
{{/each}}

{{#each sizes}}
export const {{capitalize this}}: Story = {
  args: { size: '{{this}}' },
  render: (args) => {
    const [value, setValue] = useState('');
    return (
      <Select {...args} value={value} onChange={setValue}>
        <Select.Label>{{capitalize this}} Size</Select.Label>
        <Select.Trigger>
          <Select.Value placeholder="Choose one..." />
          <Select.Icon />
        </Select.Trigger>
        <Select.Content>
          <Select.Item value="1" label="Option 1" />
          <Select.Item value="2" label="Option 2" />
        </Select.Content>
      </Select>
    );
  },
};
{{/each}}

export const Disabled: Story = {
  args: { disabled: true },
  render: (args) => (
    <Select {...args} value="us">
      <Select.Label>Country</Select.Label>
      <Select.Trigger>
        <Select.Value placeholder="Choose a country..." />
        <Select.Icon />
      </Select.Trigger>
      <Select.Content>
        <Select.Item value="us" label="United States" />
      </Select.Content>
    </Select>
  ),
};
{{else}}
const options = [
  { value: 'us', label: 'United States' },
  { value: 'ca', label: 'Canada' },
  { value: 'uk', label: 'United Kingdom' },
  { value: 'au', label: 'Australia' },
];

export const Default: Story = {
  args: {
    label: 'Country',
    options,
    placeholder: 'Choose a country...',
    size: 'md',
  },
};

{{#each variants}}
{{#unless (eq this "default")}}
export const {{capitalize this}}: Story = {
{{#if (eq this "error")}}
  args: {
    label: '{{capitalize this}} Variant',
    variant: '{{this}}',
    error: 'Please select an option',
    options,
    placeholder: 'Choose one...',
  },
{{else}}
  args: {
    label: '{{capitalize this}} Variant',
    variant: '{{this}}',
    options,
    placeholder: 'Choose one...',
  },
{{/if}}
};
{{/unless}}
{{/each}}

{{#each sizes}}
export const {{capitalize this}}: Story = {
  args: {
    label: '{{capitalize this}} Size',
    size: '{{this}}',
    options,
    placeholder: 'Choose one...',
  },
};
{{/each}}

export const Disabled: Story = {
  args: {
    label: 'Country',
    options,
    disabled: true,
    value: 'us',
  },
};
{{/if}}
