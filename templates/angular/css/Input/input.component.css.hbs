.input-container {
  display: flex;
  flex-direction: column;
  gap: 4px;
  width: 100%;
}

.label {
  font-family: system-ui, -apple-system, sans-serif;
  font-size: 14px;
  font-weight: 500;
  color: #1a1a2e;
}

.required {
  color: #e24b4a;
  margin-left: 2px;
}

.input {
  width: 100%;
  font-family: system-ui, -apple-system, sans-serif;
  border: 1.5px solid #e2e1f0;
  border-radius: 8px;
  background: #ffffff;
  color: #1a1a2e;
  transition: border-color 0.15s ease, box-shadow 0.15s ease;
  box-sizing: border-box;
}

.input:focus {
  outline: none;
  border-color: #6c63ff;
  box-shadow: 0 0 0 2px rgba(108, 99, 255, 0.2);
}

.input--sm { padding: 6px 10px; font-size: 13px; }
.input--md { padding: 10px 14px; font-size: 15px; }
.input--lg { padding: 14px 18px; font-size: 17px; }

.input--error {
  border-color: #e24b4a;
}

.input--disabled {
  background: #f8f9fa;
  cursor: not-allowed;
  opacity: 0.7;
}

.hint, .error {
  font-family: system-ui, -apple-system, sans-serif;
  font-size: 12px;
  margin-top: 2px;
}

.hint {
  color: #6b7280;
}

.error {
  color: #e24b4a;
}
