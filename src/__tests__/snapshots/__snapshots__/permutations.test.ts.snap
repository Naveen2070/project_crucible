  "Select.vue": "<script setup lang="ts">
import { ref, computed, onMounted, onUnmounted } from 'vue';

export type SelectVariant = 'default' | 'error';
export type SelectSize    = 'sm' | 'md' | 'lg';

interface Option {
  value: any;
  label: string;
}

interface Props {
  options?:     Option[];
  value?:       any;
  label?:       string;
  placeholder?: string;
  variant?:     SelectVariant;
  size?:        SelectSize;
  error?:       string;
  disabled?:    boolean;
}

const props = withDefaults(defineProps<Props>(), {
  options: () => [],
  value: null,
  label: '',
  placeholder: 'Select an option',
  variant: 'default',
  size: 'md',
  error: '',
  disabled: false,
});

const emit = defineEmits(['update:value']);

const isOpen = ref(false);
const activeIndex = ref(-1);
const containerRef = ref<HTMLElement | null>(null);

const listboxId = \`select-listbox-\${Math.floor(Math.random() * 1000000)}\`;
const getOptionId = (index: number) => \`select-option-\${listboxId}-\${index}\`;

const toggle = () => {
  if (!props.disabled) {
    isOpen.value = !isOpen.value;
    if (isOpen.value) {
      activeIndex.value = props.options.findIndex(o => (o.value || o) === (props.value?.value || props.value));
      if (activeIndex.value === -1) activeIndex.value = 0;
    }
  }
};

const selectOption = (option: any) => {
  emit('update:value', option.value !== undefined ? option.value : option);
  isOpen.value = false;
};

const isSelected = (option: any) => {
  const val = props.value?.value || props.value;
  const optVal = option?.value || option;
  return val === optVal;
};

const displayValue = computed(() => {
  const selected = props.options.find(o => isSelected(o));
  return selected ? (selected.label || selected) : props.placeholder;
});

const variantClasses: Record<SelectVariant, string> = {
  default: 'bg-[var(--color-surface)] border-[var(--color-border)] focus:border-[var(--color-primary)]',
  error: 'bg-[var(--color-surface)] border-[var(--color-destructive)] focus:border-[var(--color-destructive)]',
 };

const sizeClasses: Record<SelectSize, string> = {
  sm: 'px-3 py-1.5 text-sm',
  md: 'px-4 py-2 text-base',
  lg: 'px-5 py-3 text-lg',
};

const comboboxClasses = computed(() => [
  'flex items-center justify-between bg-[var(--color-surface)] border-[1px] rounded-[var(--radius-md)] cursor-pointer transition-all outline-none w-full',
  'focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] focus-visible:ring-offset-2',
  isOpen.value ? 'border-[var(--color-primary)] rounded-b-none' : 'border-[var(--color-border)]',
  props.disabled ? 'opacity-50 cursor-not-allowed bg-[var(--color-background)]' : '',
  (props.variant === 'error' || props.error) ? 'border-[var(--color-destructive)]' : '',
  variantClasses[props.variant],
  sizeClasses[props.size],
]);

const handleClickOutside = (event: MouseEvent) => {
  if (containerRef.value && !containerRef.value.contains(event.target as Node)) {
    isOpen.value = false;
  }
};

const handleKeyDown = (e: KeyboardEvent) => {
  if (props.disabled) return;

  if (!isOpen.value) {
    if (e.key === 'Enter' || e.key === ' ' || e.key === 'ArrowDown' || e.key === 'ArrowUp') {
      e.preventDefault();
      isOpen.value = true;
      activeIndex.value = Math.max(0, props.options.findIndex(o => isSelected(o)));
    }
    return;
  }

  switch (e.key) {
    case 'ArrowDown':
      e.preventDefault();
      activeIndex.value = (activeIndex.value < props.options.length - 1) ? activeIndex.value + 1 : activeIndex.value;
      break;
    case 'ArrowUp':
      e.preventDefault();
      activeIndex.value = (activeIndex.value > 0) ? activeIndex.value - 1 : activeIndex.value;
      break;
    case 'Enter':
    case ' ':
      e.preventDefault();
      if (activeIndex.value >= 0) {
        selectOption(props.options[activeIndex.value]);
      }
      break;
    case 'Escape':
      isOpen.value = false;
      break;
  }
};

onMounted(() => {
  document.addEventListener('click', handleClickOutside);
});

onUnmounted(() => {
  document.removeEventListener('click', handleClickOutside);
});

const activeOptionId = computed(() => 
  activeIndex.value >= 0 ? getOptionId(activeIndex.value) : undefined
);
</script>

<template>
  <div class="flex flex-col gap-[var(--spacing-unit)] w-full relative" ref="containerRef">
    <slot name="label">
      <label v-if="label" class="font-medium text-[var(--color-text)] text-sm">{{ label }}</label>
    </slot>
    
    <slot name="trigger" :toggle="toggle" :isOpen="isOpen" :displayValue="displayValue">
      <div
        :class="comboboxClasses"
        @click="toggle"
        @keydown="handleKeyDown"
        :aria-expanded="isOpen"
        role="combobox"
        aria-haspopup="listbox"
        :aria-controls="listboxId"
        :aria-activedescendant="activeOptionId"
        :tabindex="disabled ? -1 : 0"
      >
        <slot name="value">
          <span class="truncate flex-1 text-[var(--color-text)]">{{ displayValue }}</span>
        </slot>
        <slot name="icon">
          <span class="ml-2 text-[var(--color-text-muted)] text-xs" aria-hidden="true">▼</span>
        </slot>
      </div>
    </slot>

    <slot name="content" v-if="isOpen">
      <ul 
        :id="listboxId"
        class="absolute top-full left-0 right-0 z-50 bg-[var(--color-surface)] border-[1px] border-[var(--color-primary)] border-t-0 rounded-b-[var(--radius-md)] shadow-lg max-h-[200px] overflow-y-auto m-0 p-0 list-none" 
        role="listbox"
      >
        <li
          v-for="(option, index) in options"
          :key="option.value || option"
          :id="getOptionId(index)"
          @click="selectOption(option)"
          @mouseenter="activeIndex = index"
          :class="[
            'px-4 py-2 cursor-pointer transition-colors text-sm',
            isSelected(option) ? 'bg-[var(--color-secondary)] text-[var(--color-primary)] font-semibold' : 'text-[var(--color-text)]',
            activeIndex === index ? 'bg-[var(--color-secondary)] text-[var(--color-primary)]' : '',
          ]"
          role="option"
          :aria-selected="isSelected(option)"
        >
          <slot name="item" :option="option" :isSelected="isSelected(option)">
            <slot name="item-text" :option="option">
              {{ option.label || option }}
            </slot>
          </slot>
        </li>
      </ul>
    </slot>

    <slot name="error">
      <span v-if="error" class="text-xs text-[var(--color-destructive)] mt-1" role="alert">{{ error }}</span>
    </slot>
  </div>
</template>
",
}
`;

