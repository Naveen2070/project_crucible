{{> react/stories-header}}
  argTypes: {
    variant:  { control: 'select', options: {{> shared/variant-options}} },
    size:     { control: 'select', options: {{> shared/size-options}} },
    loading:  { control: 'boolean' },
    disabled: { control: 'boolean' },
  },
{{> react/stories-footer}}

{{#if features.compoundComponents}}
export const Default: Story = {
  args: { variant: 'default', size: 'md' },
  render: (args) => (
    <Button {...args}>
      <Button.Label>Button</Button.Label>
    </Button>
  ),
};

{{#each variants}}
{{#unless (eq this "default")}}
export const {{capitalize this}}: Story = {
  args: { variant: '{{this}}' },
  render: (args) => (
    <Button {...args}>
      <Button.Label>{{capitalize this}} Button</Button.Label>
    </Button>
  ),
};
{{/unless}}
{{/each}}

{{#each sizes}}
export const {{capitalize this}}: Story = {
  args: { size: '{{this}}' },
  render: (args) => (
    <Button {...args}>
      <Button.Label>{{capitalize this}} Size</Button.Label>
    </Button>
  ),
};
{{/each}}

export const Loading: Story = {
  args: { variant: 'primary', loading: true },
  render: (args) => (
    <Button {...args}>
      <Button.Spinner />
      <Button.Label>Loading...</Button.Label>
    </Button>
  ),
};

export const Disabled: Story = {
  args: { variant: 'primary', disabled: true },
  render: (args) => (
    <Button {...args}>
      <Button.Label>Disabled</Button.Label>
    </Button>
  ),
};

export const WithIcon: Story = {
  args: { variant: 'primary' },
  render: (args) => (
    <Button {...args}>
      <Button.Icon>🚀</Button.Icon>
      <Button.Label>Launch</Button.Label>
    </Button>
  ),
};
{{else}}
export const Default: Story = {
  args: { variant: 'default', size: 'md', children: 'Button' },
};

{{#each variants}}
export const {{capitalize this}}: Story = {
  args: { variant: '{{this}}', children: '{{capitalize this}} Button' },
};
{{/each}}

{{#each sizes}}
export const {{capitalize this}}: Story = {
  args: { size: '{{this}}', children: '{{capitalize this}} Size' },
};
{{/each}}

export const Loading: Story = {
  args: { variant: 'primary', loading: true, children: 'Loading...' },
};

export const Disabled: Story = {
  args: { variant: 'primary', disabled: true, children: 'Disabled' },
};
{{/if}}
