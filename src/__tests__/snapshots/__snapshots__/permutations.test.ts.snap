        <ng-content select="[dialog-body]"></ng-content>
        <ng-content></ng-content>
      </div>
      
      <footer class="p-6 border-t border-[var(--color-border)] bg-[var(--color-background)]/50 flex justify-end gap-3 empty:hidden">
