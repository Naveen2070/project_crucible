{
  "Input.tsx": "import React, { useId, useState, createContext, useContext } from 'react';

const variantClasses: Record<string, string> = {
  default: 'bg-[var(--color-surface)] border-[var(--color-border)] focus:border-[var(--color-primary)]',
  error: 'bg-[var(--color-surface)] border-[var(--color-destructive)] focus:border-[var(--color-destructive)]',
 };
const sizeClasses: Record<string, string> = {
  sm: 'px-3 py-1.5 text-sm',
  md: 'px-4 py-2 text-base',
  lg: 'px-5 py-3 text-lg',
};

export type InputVariant = 'default' | 'error';
export type InputSize    = 'sm' | 'md' | 'lg';

export interface InputProps extends Omit<React.InputHTMLAttributes<HTMLInputElement>, 'size'> {
  label?:    string;
  variant?:  InputVariant;
  size?:     InputSize;
  error?:    string;
  hint?:     string;
  required?: boolean;
}

interface InputContextValue {
  id: string;
  variant: InputVariant;
  size: InputSize;
  error?: string;
  hint?: string;
  required?: boolean;
  disabled?: boolean;
}

const InputContext = createContext<InputContextValue | undefined>(undefined);

const useInputContext = () => {
  const context = useContext(InputContext);
  if (!context) throw new Error('Input sub-components must be used within Input');
  return context;
};

export const InputRoot = ({
  children,
  variant = 'default',
  size = 'md',
  error,
  hint,
  required,
  disabled,
  id: providedId,
  className,
}: {
  children: React.ReactNode;
  variant?: InputVariant;
  size?: InputSize;
  error?: string;
  hint?: string;
  required?: boolean;
  disabled?: boolean;
  id?: string;
  className?: string;
}) => {
  const generatedId = useId();
  const id = providedId || generatedId;

  return (
    <InputContext.Provider value={{ id, variant, size, error, hint, required, disabled }}>
      <div className={['flex flex-col gap-[var(--spacing-unit)] w-full', className].filter(Boolean).join(' ')}>
        {children}
      </div>
    </InputContext.Provider>
  );
};

export const InputLabel = ({ children, className }: { children: React.ReactNode; className?: string }) => {
  const { id, required } = useInputContext();
  return (
    <label htmlFor={id} className={['font-medium text-[var(--color-text)] text-sm', className].filter(Boolean).join(' ')}>
      {children}
      {required && <span className="text-[var(--color-destructive)] ml-1" aria-hidden="true">*</span>}
    </label>
  );
};

export const InputField = React.forwardRef<HTMLInputElement, Omit<React.InputHTMLAttributes<HTMLInputElement>, 'size'>>(
  ({ className, type = 'text', ...props }, ref) => {
    const { id, variant, size, error, hint, disabled, required } = useInputContext();
    const [showPassword, setShowPassword] = useState(false);
    const isPassword = type === 'password';
    const inputType = isPassword ? (showPassword ? 'text' : 'password') : type;

    const cls = [
      'w-full border-[1.5px] rounded-[var(--radius-md)] outline-none transition-all',
      'focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] focus-visible:ring-offset-2 outline-none',
      'disabled:opacity-50 disabled:cursor-not-allowed',
      variantClasses[variant],
      sizeClasses[size],
      isPassword && 'pr-12',
      (error || variant === 'error') && 'border-[var(--color-destructive)]',
      className,
    ].filter(Boolean).join(' ');

    const describedBy = [
      error ? \`\${id}-error\` : null,
      hint ? \`\${id}-hint\` : null,
    ].filter(Boolean).join(' ') || undefined;

    return (
      <div className="relative w-full">
        <input
          ref={ref}
          id={id}
          type={inputType}
          className={cls}
          aria-invalid={!!error}
          aria-required={required}
          aria-describedby={describedBy}
          disabled={disabled}
          {...props}
        />
        {isPassword && (
          <button
            type="button"
            className="absolute right-3 top-1/2 -translate-y-1/2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] rounded-sm"
            onClick={() => setShowPassword(!showPassword)}
            aria-label={showPassword ? 'Hide password' : 'Show password'}
            aria-pressed={showPassword}
          >
            {showPassword ? 'Hide' : 'Show'}
          </button>
        )}
      </div>
    );
  }
);

export const InputError = ({ children, className }: { children: React.ReactNode; className?: string }) => {
  const { id } = useInputContext();
  return (
    <span id={\`\${id}-error\`} className={['text-xs text-[var(--color-destructive)]', className].filter(Boolean).join(' ')} role="alert">
      {children}
    </span>
  );
};

export const InputHint = ({ children, className }: { children: React.ReactNode; className?: string }) => {
  const { id } = useInputContext();
  return (
    <span id={\`\${id}-hint\`} className={['text-xs text-[var(--color-text-muted)]', className].filter(Boolean).join(' ')}>
      {children}
    </span>
  );
};

export const Input = Object.assign(InputRoot, {
  Label: InputLabel,
  Field: InputField,
  Error: InputError,
  Hint: InputHint,
});

Input.displayName = 'Input';
InputRoot.displayName = 'Input.Root';
InputLabel.displayName = 'Input.Label';
InputField.displayName = 'Input.Field';
InputError.displayName = 'Input.Error';
InputHint.displayName = 'Input.Hint';
",
