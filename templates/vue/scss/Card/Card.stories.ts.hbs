import type { Meta, StoryObj } from '@storybook/vue3';
import Card from './Card.vue';

const meta: Meta<typeof Card> = {
  title: 'Crucible/{{name}}',
  component: Card,
  argTypes: {
    variant: { control: 'select', options: [{{#each variants}}'{{this}}'{{#unless @last}}, {{/unless}}{{/each}}] },
    size:    { control: 'select', options: [{{#each sizes}}'{{this}}'{{#unless @last}}, {{/unless}}{{/each}}] },
  },
};

export default meta;
type Story = StoryObj<typeof Card>;

export const Default: Story = {
  args: {
    title: 'Card Title',
  },
  render: (args) => ({
    components: { Card },
    setup() { return { args }; },
    template: `<Card v-bind="args">This is the card content.</Card>`,
  }),
};

export const Clickable: Story = {
  args: {
    title: 'Interactive Card',
    variant: 'clickable',
  },
  render: (args) => ({
    components: { Card },
    setup() { return { args }; },
    template: `<Card v-bind="args">You can click this card!</Card>`,
  }),
};

{{#if features.compoundComponents}}
export const CustomTitle: Story = {
  args: {},
  render: (args) => ({
    components: { Card },
    setup() { return { args }; },
    template: `
<Card v-bind="args">
  <template #title>
    <div style="background: #f0f0f0; padding: 1rem; border-bottom: 2px solid #333;">
      <strong>Custom Header Slot</strong>
    </div>
  </template>
  The content area still works as expected.
</Card>`,
  }),
};
{{/if}}
