/* Generated by Crucible — edit freely, re-generate with --force */

.input-container {
  display:        flex;
  flex-direction: column;
  gap:            var(--spacing-unit);
  width:          100%;
}

.label {
  font-family: var(--font-family);
  font-size:   0.875rem;
  font-weight: 500;
  color:       var(--color-text);
  margin-bottom: calc(var(--spacing-unit) * 1.5);
}

.required {
  color:       var(--color-danger);
  margin-left: calc(var(--spacing-unit) * 0.5);
}

.input-wrapper {
  position: relative;
  width:    100%;
}

.input {
  --input-height: {{tokens.componentTokens.input.height}};
  --input-radius: {{tokens.componentTokens.input.borderRadius}};
  --input-border: {{tokens.componentTokens.input.borderColor}};
  --input-transition: {{tokens.componentTokens.input.transition}};

  width:           100%;
  font-family:     var(--font-family);
  border:          1px solid var(--input-border);
  border-radius:   var(--input-radius);
  background:      var(--color-surface);
  color:           var(--color-text);
  transition:      var(--input-transition);
  box-sizing:      border-box;
}

{{#if a11y.focusRing}}
.input:focus-visible {
  outline:        {{a11y.focusRingWidth}} solid {{a11y.focusRingColor}};
  outline-offset: {{a11y.focusRingOffset}};
  border-color:   var(--color-primary);
  box-shadow:     0 0 0 4px rgba(108, 99, 255, 0.1);
}
{{/if}}

/* Sizes */
.input--sm { 
  min-height: var(--input-height);
  padding:    0 {{tokens.componentTokens.input.paddingX}};
  font-size:  0.875rem; 
}
.input--md { 
  min-height: var(--input-height);
  padding:    0 {{tokens.componentTokens.input.paddingX}};
  font-size:  1rem; 
}
.input--lg { 
  min-height: var(--input-height);
  padding:    0 {{tokens.componentTokens.input.paddingX}};
  font-size:  1.125rem; 
}

/* Variants */
.input--error {
  border-color: var(--color-danger);
}

.input--disabled {
  background: var(--color-background);
  cursor:     not-allowed;
  opacity:    0.7;
}

.password-toggle {
  position:   absolute;
  right:      12px;
  top:        50%;
  transform:  translateY(-50%);
  background: transparent;
  border:     none;
  padding:    0;
  margin:     0;
  font-family: var(--font-family);
  font-size:  12px;
  color:      var(--color-text-muted);
  cursor:     pointer;
}

.password-toggle:hover {
  color: var(--color-text);
}

{{#if a11y.focusRing}}
.password-toggle:focus-visible {
  outline:        {{a11y.focusRingWidth}} solid {{a11y.focusRingColor}};
  outline-offset: {{a11y.focusRingOffset}};
  border-radius:  var(--radius-sm);
}
{{/if}}

.hint, .error {
  font-family: var(--font-family);
  font-size:   12px;
  margin-top:  2px;
}

.hint {
  color: var(--color-text-muted);
}

.error {
  color: var(--color-danger);
}
