import { Meta, StoryObj } from '@storybook/angular';
import { DialogComponent } from './Dialog.component';

const meta: Meta<DialogComponent> = {
  title: 'Crucible/Dialog',
  component: DialogComponent,
  tags: ['autodocs'],
  argTypes: {
    variant: { control: 'select', options: {{> shared/variant-options}} },
    size:    { control: 'select', options: {{> shared/size-options}} },
    isOpen:  { control: 'boolean' },
    title:   { control: 'text' },
  },
};

export default meta;
type Story = StoryObj<DialogComponent>;

export const Default: Story = {
  args: {
    isOpen: true,
    title: 'Dialog Title',
    size: 'md',
    variant: 'default',
  },
  render: (args) => ({
    props: args,
    template: `
      <app-Dialog [isOpen]="isOpen" [title]="title" [size]="size" [variant]="variant">
        <p>This is the Dialog content.</p>
        <div dialog-footer>
          <button style="padding: 8px 16px;">Confirm</button>
        </div>
      </app-Dialog>
    `,
  }),
};

{{#each variants}}
{{#unless (eq this "default")}}
export const {{capitalize this}}: Story = {
  args: { variant: '{{this}}', title: '{{capitalize this}} Variant', isOpen: true },
  render: (args) => ({
    props: args,
    template: `
      <app-Dialog [isOpen]="isOpen" [title]="title" [size]="size" [variant]="variant">
        <p>Dialog content with {{this}} variant.</p>
      </app-Dialog>
    `,
  }),
};
{{/unless}}
{{/each}}

{{#each sizes}}
export const {{capitalize this}}: Story = {
  args: { size: '{{this}}', title: '{{capitalize this}} Size', isOpen: true },
  render: (args) => ({
    props: args,
    template: `
      <app-Dialog [isOpen]="isOpen" [title]="title" [size]="size" [variant]="variant">
        <p>Dialog content with {{this}} size.</p>
      </app-Dialog>
    `,
  }),
};
{{/each}}
