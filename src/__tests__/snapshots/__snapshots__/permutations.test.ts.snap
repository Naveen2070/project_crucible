  font-family: var(--font-family);
  font-size:   12px;
  margin-top:  2px;
}

.input-hint, .hint {
  color: var(--color-text-muted);
}

.input-error, .error {
  color: var(--color-destructive);
}

.input[type="password"],
.input[type="text"]:has(+ .password-toggle) {
  padding-right: 48px;
}
