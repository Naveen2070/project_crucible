/* Generated by Crucible — edit freely, re-generate with --force */

.dialog-overlay, .overlay {
  --dialog-overlay-bg: {{tokens.componentTokens.Dialog.overlayBg}};
  --Dialog-padding: {{tokens.componentTokens.Dialog.padding}};

  position:        fixed;
  top:             0;
  left:            0;
  right:           0;
  bottom:          0;
  background-color: var(--dialog-overlay-bg);
  display:         flex;
  align-items:     center;
  justify-content: center;
  z-index:         {{tokens.componentTokens.Dialog.zIndex}};
  padding:         var(--Dialog-padding);
}

.Dialog {
  --Dialog-radius: {{tokens.componentTokens.Dialog.borderRadius}};
  --Dialog-shadow: {{tokens.componentTokens.Dialog.shadow}};

  background:      var(--color-surface);
  border-radius:   var(--Dialog-radius);
  box-shadow:      var(--Dialog-shadow);
  max-height:      calc(100vh - (var(--spacing-unit) * 10));
  display:         flex;
  flex-direction:  column;
  width:           100%;
  animation:       dialog-open 0.2s ease-out;
}

@keyframes dialog-open {
  from { opacity: 0; transform: scale(0.95) translateY(10px); }
  to   { opacity: 1; transform: scale(1) translateY(0); }
}

.dialog-header, .header {
  padding:        var(--Dialog-padding);
  border-bottom:  1px solid var(--color-border);
  display:        flex;
  align-items:    center;
  justify-content: space-between;
}

.dialog-title, .title {
  margin:      0;
  font-size:   1.25rem;
  font-weight: 600;
  color:       var(--color-text);
  font-family: var(--font-family);
}

.dialog-description, .description {
  margin:      0.5rem 0 0;
  font-size:   0.875rem;
  color:       var(--color-text-muted);
  font-family: var(--font-family);
  line-height: 1.5;
}

.dialog-close, .close-button {
  background:    transparent;
  border:        none;
  font-size:     1.5rem;
  line-height:   1;
  color:         var(--color-text-muted);
  cursor:        pointer;
  padding:       calc(var(--spacing-unit) * 2);
  border-radius: var(--radius-sm);
  transition:    background 0.15s ease;
}

{{#if a11y.focusRing}}
.dialog-close:focus-visible, .close-button:focus-visible {
  outline: none;
  box-shadow: 0 0 0 2px var(--color-background), 0 0 0 4px {{a11y.focusRingColor}};
}
{{/if}}

.dialog-close:hover, .close-button:hover {
  background: var(--color-background);
  color:      var(--color-text);
}

.dialog-body, .body {
  padding:     var(--Dialog-padding);
  overflow-y:  auto;
  font-family: var(--font-family);
  color:       var(--color-text);
  line-height: 1.5;
}

.dialog-footer, .footer {
  padding:       var(--Dialog-padding);
  border-top:    1px solid var(--color-border);
  display:       flex;
  justify-content: flex-end;
  gap:           calc(var(--spacing-unit) * 3);
}

/* Sizes */
.Dialog--sm { max-width: 400px; }
.Dialog--md { max-width: 600px; }
.Dialog--lg { max-width: 800px; }
