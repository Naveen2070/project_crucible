import { Component, Input } from '@angular/core';

@Component({
  selector: 'app-button',
  templateUrl: './button.component.html',
  styleUrls: ['./button.component.{{#if (eq styleSystem "scss")}}scss{{else}}css{{/if}}']
})
export class ButtonComponent {
  @Input() variant: {{> shared/variant-types}} = 'primary';
  @Input() size:    {{> size-types}} = 'md';
  @Input() loading = false;
  @Input() disabled = false;
  @Input() className = '';

  get classes(): string {
    return [
      'btn',
      `btn--${this.variant}`,
      `btn--${this.size}`,
      this.loading ? 'btn--loading' : '',
      this.disabled ? 'btn--disabled' : '',
      this.className
    ].filter(Boolean).join(' ');
  }
}
