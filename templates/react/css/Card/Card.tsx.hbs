import React from 'react';
{{> react/styles-import}}

export type CardVariant = {{> shared/variant-types}};
export type CardSize    = {{> shared/size-types}};

{{> react/props-interface}}

{{#if features.compoundComponents}}
export const CardRoot = ({
  variant = 'default',
  size = 'md',
  children,
  onClick,
  className,
  href,
}: CardProps) => {
  const isClickable = variant === 'clickable' || !!onClick || !!href;
  
  const cls = [
    styles.card,
    styles[`card--${variant}`],
    styles[`card--${size}`],
    isClickable && styles['card--clickable'],
    className,
  ].filter(Boolean).join(' ');

  const handleKeyDown = (e: React.KeyboardEvent) => {
    if (isClickable && (e.key === 'Enter' || e.key === ' ')) {
      e.preventDefault();
      onClick?.();
      if (href) window.location.href = href;
    }
  };

  const Component = href ? 'a' : isClickable ? 'button' : 'article';

  return (
    <Component
      className={cls}
      onClick={onClick}
      href={href}
      role={href ? undefined : isClickable ? 'button' : 'article'}
      tabIndex={isClickable ? 0 : undefined}
      onKeyDown={isClickable ? handleKeyDown : undefined}
    >
      {children}
    </Component>
  );
};

export const CardHeader = ({ children, className }: { children: React.ReactNode; className?: string }) => (
  <div className={[styles.header, className].filter(Boolean).join(' ')}>{children}</div>
);

export const CardTitle = ({ children, className }: { children: React.ReactNode; className?: string }) => (
  <h3 className={[styles.title, className].filter(Boolean).join(' ')}>{children}</h3>
);

export const CardDescription = ({ children, className }: { children: React.ReactNode; className?: string }) => (
  <p className={[styles.description, className].filter(Boolean).join(' ')}>{children}</p>
);

export const CardAction = ({ children, className }: { children: React.ReactNode; className?: string }) => (
  <div className={[styles.action, className].filter(Boolean).join(' ')}>{children}</div>
);

export const CardContent = ({ children, className }: { children: React.ReactNode; className?: string }) => (
  <div className={[styles.content, className].filter(Boolean).join(' ')}>{children}</div>
);

export const CardFooter = ({ children, className }: { children: React.ReactNode; className?: string }) => (
  <div className={[styles.footer, className].filter(Boolean).join(' ')}>{children}</div>
);

export const Card = Object.assign(CardRoot, {
  Header: CardHeader,
  Title: CardTitle,
  Description: CardDescription,
  Action: CardAction,
  Content: CardContent,
  Footer: CardFooter,
});

Card.displayName = 'Card';
{{else}}
export const CardDescription = ({ children, className }: { children: React.ReactNode; className?: string }) => (
  <p className={[styles.description, className].filter(Boolean).join(' ')}>{children}</p>
);

export const CardAction = ({ children, className }: { children: React.ReactNode; className?: string }) => (
  <div className={[styles.action, className].filter(Boolean).join(' ')}>{children}</div>
);
export const Card: React.FC<CardProps> = ({
  variant = 'default',
  size = 'md',
  title,
  children,
  onClick,
  className,
  href,
}) => {
  const isClickable = variant === 'clickable' || !!onClick || !!href;
  
  const cls = [
    styles.card,
    styles[`card--${variant}`],
    styles[`card--${size}`],
    isClickable && styles['card--clickable'],
    className,
  ].filter(Boolean).join(' ');

  const handleKeyDown = (e: React.KeyboardEvent) => {
    if (isClickable && (e.key === 'Enter' || e.key === ' ')) {
      e.preventDefault();
      onClick?.();
      if (href) window.location.href = href;
    }
  };

  const Component = href ? 'a' : isClickable ? 'button' : 'article';

  return (
    <Component
      className={cls}
      onClick={onClick}
      href={href}
      role={href ? undefined : isClickable ? 'button' : 'article'}
      tabIndex={isClickable ? 0 : undefined}
      onKeyDown={isClickable ? handleKeyDown : undefined}
    >
      {title && <h3 className={styles.title}>{title}</h3>}
      <div className={styles.content}>{children}</div>
    </Component>
  );
};

Card.displayName = 'Card';
{{/if}}
