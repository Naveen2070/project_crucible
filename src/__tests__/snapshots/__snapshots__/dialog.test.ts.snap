"import type { Meta, StoryObj } from '@storybook/react';
import React, { useState } from 'react';
import { Dialog } from './Dialog';

const meta: Meta<typeof Dialog> = {
  title: 'Crucible/Dialog',
  component: Dialog,
  parameters: { layout: 'centered' },
import { Button } from '../Button/Button';

  argTypes: {
    variant:  { control: 'select', options: ['default', 'confirm'] },
    size:     { control: 'select', options: ['sm', 'md', 'lg'] },
  },
};
export default meta;
type Story = StoryObj<typeof Dialog>;

export const Default: Story = {
  args: { variant: 'default', size: 'md' },
  render: (args) => {
    const [isOpen, setIsOpen] = useState(false);
    return (
      <div style={{ height: '300px', display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
        <button onClick={() => setIsOpen(true)}>Open Dialog</button>
        <Dialog {...args} isOpen={isOpen} onClose={() => setIsOpen(false)}>
          <Dialog.Overlay>
            <Dialog.Content>
              <Dialog.Header>
                <Dialog.Title>Dialog Title</Dialog.Title>
                <Dialog.Close />
              </Dialog.Header>
              <Dialog.Body>
                <p>This is the Dialog body content.</p>
              </Dialog.Body>
              <Dialog.Footer>
                <div style={{ display: 'flex', gap: '8px', justifyContent: 'flex-end' }}>
                  <button onClick={() => setIsOpen(false)}>Cancel</button>
                  <button onClick={() => setIsOpen(false)}>Confirm</button>
                </div>
              </Dialog.Footer>
            </Dialog.Content>
          </Dialog.Overlay>
        </Dialog>
      </div>
    );
  },
};

export const Confirm: Story = {
  args: { variant: 'confirm' },
  render: (args) => {
    const [isOpen, setIsOpen] = useState(false);
    return (
      <div style={{ height: '300px', display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
        <button onClick={() => setIsOpen(true)}>Open Confirm Dialog</button>
        <Dialog {...args} isOpen={isOpen} onClose={() => setIsOpen(false)}>
          <Dialog.Overlay>
            <Dialog.Content>
              <Dialog.Header>
                <Dialog.Title>Confirm Variant</Dialog.Title>
                <Dialog.Close />
              </Dialog.Header>
              <Dialog.Body>
                <p>Dialog content with confirm variant.</p>
              </Dialog.Body>
            </Dialog.Content>
          </Dialog.Overlay>
        </Dialog>
      </div>
    );
  },
};

export const Sm: Story = {
  args: { size: 'sm' },
  render: (args) => {
    const [isOpen, setIsOpen] = useState(false);
    return (
      <div style={{ height: '300px', display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
        <button onClick={() => setIsOpen(true)}>Open Sm Dialog</button>
        <Dialog {...args} isOpen={isOpen} onClose={() => setIsOpen(false)}>
          <Dialog.Overlay>
            <Dialog.Content>
              <Dialog.Header>
                <Dialog.Title>Sm Size</Dialog.Title>
                <Dialog.Close />
              </Dialog.Header>
              <Dialog.Body>
                <p>Dialog content with sm size.</p>
              </Dialog.Body>
            </Dialog.Content>
          </Dialog.Overlay>
        </Dialog>
      </div>
    );
  },
};
export const Md: Story = {
  args: { size: 'md' },
  render: (args) => {
    const [isOpen, setIsOpen] = useState(false);
    return (
      <div style={{ height: '300px', display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
        <button onClick={() => setIsOpen(true)}>Open Md Dialog</button>
        <Dialog {...args} isOpen={isOpen} onClose={() => setIsOpen(false)}>
          <Dialog.Overlay>
            <Dialog.Content>
              <Dialog.Header>
                <Dialog.Title>Md Size</Dialog.Title>
                <Dialog.Close />
              </Dialog.Header>
              <Dialog.Body>
                <p>Dialog content with md size.</p>
              </Dialog.Body>
            </Dialog.Content>
          </Dialog.Overlay>
        </Dialog>
      </div>
    );
  },
};
export const Lg: Story = {
  args: { size: 'lg' },
  render: (args) => {
    const [isOpen, setIsOpen] = useState(false);
    return (
      <div style={{ height: '300px', display: 'flex', alignItems: 'center', justifyContent: 'center' }}>
        <button onClick={() => setIsOpen(true)}>Open Lg Dialog</button>
        <Dialog {...args} isOpen={isOpen} onClose={() => setIsOpen(false)}>
