import type { Meta, StoryObj } from '@storybook/vue3';
import Dialog from './Dialog.vue';

const meta: Meta<typeof Dialog> = {
  title: 'Crucible/{{name}}',
  component: Dialog,
  argTypes: {
    variant: { control: 'select', options: {{> shared/variant-options}} },
    size:    { control: 'select', options: {{> shared/size-options}} },
    isOpen:  { control: 'boolean' },
    onClose: { action: 'close' },
  },
};

export default meta;
type Story = StoryObj<typeof Dialog>;

export const Default: Story = {
  args: {
    isOpen: true,
    title: 'Dialog Title',
    variant: 'default',
    size: 'md',
  },
  render: (args) => ({
    components: { Dialog },
    setup() { return { args }; },
    template: `
<Dialog v-bind="args">
  This is the Dialog content.
  <template #footer>
    <button @click="args.onClose">Confirm</button>
  </template>
</Dialog>`,
  }),
};

{{#each variants}}
{{#unless (eq this "default")}}
export const {{capitalize this}}: Story = {
  args: { variant: '{{this}}', title: '{{capitalize this}} Variant', isOpen: true },
  render: (args) => ({
    components: { Dialog },
    setup() { return { args }; },
    template: `
<Dialog v-bind="args">
  Dialog content with {{this}} variant.
</Dialog>`,
  }),
};
{{/unless}}
{{/each}}

{{#each sizes}}
export const {{capitalize this}}: Story = {
  args: { size: '{{this}}', title: '{{capitalize this}} Size', isOpen: true },
  render: (args) => ({
    components: { Dialog },
    setup() { return { args }; },
    template: `
<Dialog v-bind="args">
  Dialog content with {{this}} size.
</Dialog>`,
  }),
};
{{/each}}

{{#if features.compoundComponents}}
export const WithSlots: Story = {
  args: { isOpen: true, title: 'Slot Example' },
  render: (args) => ({
    components: { Dialog },
    setup() { return { args }; },
    template: `
<Dialog v-bind="args">
  <template #header>
    <div style="display: flex; justify-content: space-between; align-items: center; width: 100%; border-bottom: 2px solid purple; padding-bottom: 8px;">
      <h3 style="margin: 0; color: purple;">Custom Header Slot</h3>
      <button @click="args.onClose" style="background: none; border: 1px solid purple; color: purple; border-radius: 4px; padding: 2px 8px;">Exit</button>
    </div>
  </template>
  <template #default>
    Custom body content via default slot.
  </template>
  <template #footer>
    <div style="width: 100%; text-align: right;">
      <button @click="args.onClose" style="margin-right: 8px;">Cancel</button>
      <button @click="args.onClose" style="background: purple; color: white; border: none; border-radius: 4px; padding: 4px 12px;">Submit</button>
    </div>
  </template>
</Dialog>`,
  }),
};
{{/if}}
