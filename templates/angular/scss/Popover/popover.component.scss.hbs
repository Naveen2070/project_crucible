:host {
  display: inline-block;
}

.popover-root {
  position: relative;
  display: inline-block;
}

.popover-content {
  position: absolute;
  z-index: var(--popover-z-index, {{tokens.componentTokens.popover.zIndex}});
  background: var(--popover-background, {{tokens.componentTokens.popover.background}});
  border: 1px solid var(--popover-border, {{tokens.componentTokens.popover.border}});
  border-radius: var(--popover-radius, {{tokens.componentTokens.popover.radius}});
  box-shadow: var(--popover-shadow, {{tokens.componentTokens.popover.shadow}});
  padding: var(--popover-padding, {{tokens.componentTokens.popover.padding}});
  min-width: 180px;
  overflow: hidden;

  &.placement-top {
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    margin-bottom: 8px;

    &.alignment-start {
      left: 0;
      transform: translateX(0);
    }

    &.alignment-end {
      left: auto;
      right: 0;
      transform: translateX(0);
    }
  }

  &.placement-bottom {
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    margin-top: 8px;

    &.alignment-start {
      left: 0;
      transform: translateX(0);
    }

    &.alignment-end {
      left: auto;
      right: 0;
      transform: translateX(0);
    }
  }

  &.placement-left {
    right: 100%;
    top: 50%;
    transform: translateY(-50%);
    margin-right: 8px;

    &.alignment-start {
      top: 0;
      transform: translateY(0);
    }

    &.alignment-end {
      top: auto;
      bottom: 0;
      transform: translateY(0);
    }
  }

  &.placement-right {
    left: 100%;
    top: 50%;
    transform: translateY(-50%);
    margin-left: 8px;

    &.alignment-start {
      top: 0;
      transform: translateY(0);
    }

    &.alignment-end {
      top: auto;
      bottom: 0;
      transform: translateY(0);
    }
  }

  &.variant-minimal {
    border: none;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  }

  &.size-sm {
    font-size: 0.875rem;
    padding: calc(var(--popover-padding) * 0.75);
  }

  &.size-md {
    font-size: 1rem;
  }

  &.size-lg {
    font-size: 1.125rem;
    padding: calc(var(--popover-padding) * 1.5);
  }

  &.content-open {
    animation: popover-fade-in 0.2s ease-out;
  }
}

@keyframes popover-fade-in {
  from {
    opacity: 0;
    transform: scale(0.95);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}
