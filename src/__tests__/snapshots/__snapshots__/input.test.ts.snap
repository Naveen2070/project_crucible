exports[`Input snapshots > Input files match snapshots 1`] = `
"import React, { useId } from 'react';
import styles from './Input.module.css';

export type InputVariant = 'default' | 'error';
export type InputSize    = 'sm' | 'md' | 'lg';

export interface InputProps extends React.InputHTMLAttributes<HTMLInputElement> {
  label:     string;
  variant?:  InputVariant;
  size?:     InputSize;
  error?:    string;
  hint?:     string;
  required?: boolean;
}

export const Input = React.forwardRef<HTMLInputElement, InputProps>(
  ({ label, variant = 'default', size = 'md', error, hint, required, id: providedId, className, ...props }, ref) => {
    const generatedId = useId();
    const id = providedId || generatedId;
    const errorId = \`\${id}-error\`;
    const hintId = \`\${id}-hint\`;

    const cls = [
      styles.input,
      styles[\`input--\${variant}\`],
      styles[\`input--\${size}\`],
      error && styles['input--error'],
      props.disabled && styles['input--disabled'],
      className,
    ].filter(Boolean).join(' ');

    const describedBy = [
      error ? errorId : null,
      hint ? hintId : null,
    ].filter(Boolean).join(' ') || undefined;

    return (
      <div className={styles['input-container']}>
        <label htmlFor={id} className={styles.label}>
          {label}
          {required && <span className={styles.required} aria-hidden="true">*</span>}
        </label>
        <input
          ref={ref}
          id={id}
          className={cls}
          aria-invalid={!!error}
          aria-describedby={describedBy}
          aria-required={required}
          {...props}
        />
        {hint && !error && (
          <span id={hintId} className={styles.hint}>
            {hint}
          </span>
        )}
        {error && (
          <span id={errorId} className={styles.error} role="alert">
            {error}
          </span>
        )}
      </div>
    );
  }
);

Input.displayName = 'Input';
"
`;

exports[`Input snapshots > Input files match snapshots 2`] = `
"/* Generated by Crucible — edit freely, re-generate with --force */

.input-container {
  display:        flex;
  flex-direction: column;
  gap:            var(--spacing-unit);
  width:          100%;
}

.label {
  font-family: var(--font-family);
  font-size:   14px;
  font-weight: 500;
  color:       var(--color-text);
}

.required {
  color:       var(--color-danger);
  margin-left: 2px;
}

.input {
  width:           100%;
  font-family:     var(--font-family);
  border:          1.5px solid var(--color-border);
  border-radius:   var(--radius-md);
  background:      var(--color-surface);
  color:           var(--color-text);
  transition:      border-color 0.15s ease, box-shadow 0.15s ease;
  box-sizing:      border-box;
}

.input:focus-visible {
  outline:        2px solid var(--color-primary);
  outline-offset: 3px;
  border-color:   var(--color-primary);
}

/* Sizes */
.input--sm { padding: 6px 10px;  font-size: 13px; }
.input--md { padding: 10px 14px; font-size: 15px; }
.input--lg { padding: 14px 18px; font-size: 17px; }

/* Variants */
.input--error {
  border-color: var(--color-danger);
}

.input--disabled {
  background: var(--color-background);
  cursor:     not-allowed;
  opacity:    0.7;
}

.hint, .error {
  font-family: var(--font-family);
  font-size:   12px;
}

.hint {
  color: var(--color-text-muted);
}

.error {
  color: var(--color-danger);
}
"
`;

