{
  "Dialog.vue": "<script setup lang="ts">
import { computed } from 'vue';

export type DialogVariant = 'default' | 'confirm';
export type DialogSize    = 'sm' | 'md' | 'lg';

interface Props {
  isOpen?:  boolean;
  title?:   string;
  variant?: DialogVariant;
  size?:    DialogSize;
}

const props = withDefaults(defineProps<Props>(), {
  isOpen: false,
  title: '',
  variant: 'default',
  size: 'md',
});

const emit = defineEmits(['close']);

const onClose = () => {
  emit('close');
};

const dialogClasses = computed(() => [
  'Dialog',
  \`Dialog--\${props.size}\`,
  \`Dialog--\${props.variant}\`,
]);

const titleId = \`dialog-title-\${Math.floor(Math.random() * 1000000)}\`;
const descriptionId = \`dialog-desc-\${Math.floor(Math.random() * 1000000)}\`;
</script>

<template>
  <slot name="overlay" :close="onClose" :isOpen="isOpen">
    <div v-if="isOpen" class="dialog-overlay" @click="onClose">
      <slot name="content">
        <div :class="dialogClasses" @click.stop role="dialog" aria-modal="true" :aria-labelledby="titleId" :aria-describedby="descriptionId">
          <slot name="header">
            <header class="dialog-header">
              <slot name="title">
                <h2 :id="titleId" v-if="title" class="dialog-title">{{ title }}</h2>
              </slot>
              <slot name="description">
                <p :id="descriptionId" class="dialog-description">
                  <slot name="description-content" />
                </p>
              </slot>
              <slot name="close">
                <button type="button" class="dialog-close" @click="onClose" aria-label="Close Dialog">
                  &times;
                </button>
              </slot>
            </header>
          </slot>
          
          <slot name="body">
            <div class="dialog-body">
              <slot />
            </div>
          </slot>
          
          <slot name="footer" v-if="$slots.footer">
            <footer class="dialog-footer">
              <slot name="footer-content">
                <slot name="footer" />
              </slot>
            </footer>
          </slot>
        </div>
      </slot>
    </div>
  </slot>
</template>

<style scoped>
/* Generated by Crucible — edit freely, re-generate with --force */

