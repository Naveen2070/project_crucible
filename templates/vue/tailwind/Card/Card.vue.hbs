<script setup lang="ts">
import { computed } from 'vue';

export type CardVariant = {{#each variants}}'{{this}}'{{#unless @last}} | {{/unless}}{{/each}};
export type CardSize    = {{#each sizes}}'{{this}}'{{#unless @last}} | {{/unless}}{{/each}};

interface Props {
  variant?: CardVariant;
  size?:    CardSize;
  title?:   string;
  href?:    string;
}

const props = withDefaults(defineProps<Props>(), {
  variant: 'default',
  size: 'md',
  title: '',
});

const emit = defineEmits(['click']);

const onClick = (event: MouseEvent) => {
  emit('click', event);
};

const variantClasses: Record<CardVariant, string> = {
{{#each variants}}  {{this}}: '{{lookup ../tailwindVariants this}}',
{{/each}} };

const sizeClasses: Record<CardSize, string> = {
  sm: 'max-w-[300px]',
  md: 'max-w-[450px]',
  lg: 'max-w-[600px]',
};

const isClickable = computed(() => props.variant === 'clickable' || !!props.href);

const componentTag = computed(() => {
  if (props.href) return 'a';
  if (isClickable.value) return 'button';
  return 'article';
});

const classes = computed(() => [
  'rounded-[var(--radius-lg)] border-[1px] transition-all text-left w-full block overflow-hidden bg-[var(--color-surface)]',
  {{#if a11y.focusRing}}'focus-visible:outline focus-visible:outline-2 focus-visible:outline-[{{a11y.focusRingColor}}] focus-visible:outline-offset-2',{{/if}}
  variantClasses[props.variant],
  sizeClasses[props.size],
]);
</script>

<template>
  <component
    :is="componentTag"
    :class="classes"
    :href="href"
    :role="isClickable && !href ? 'button' : undefined"
    :tabindex="isClickable ? 0 : undefined"
    @click="onClick"
  >
    <slot name="header">
      <div v-if="title || $slots.title || $slots.description || $slots.action" class="p-4 border-b border-[var(--color-border)] flex items-start justify-between gap-2">
        <div>
          <slot name="title">
            <h3 v-if="title" class="font-semibold text-lg text-[var(--color-text)]">
              {{hbs "title"}}
            </h3>
          </slot>
          <slot name="description" />
        </div>
        <slot name="action" />
      </div>
    </slot>

    <div class="p-4">
      <slot name="content">
        <slot />
      </slot>
    </div>

    <footer v-if="$slots.footer" class="p-4 border-t border-[var(--color-border)]">
      <slot name="footer" />
    </footer>
  </component>
</template>
