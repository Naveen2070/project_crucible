}

.size-md {
  font-size: 1rem;
}

.size-lg {
  font-size: 1.125rem;
  padding: calc(var(--popover-padding) * 1.5);
}

/* Animation */
.content-open {
  animation: popover-fade-in 0.2s ease-out;
}

@keyframes popover-fade-in {
  from {
    opacity: 0;
    transform: scale(0.95);
  }
