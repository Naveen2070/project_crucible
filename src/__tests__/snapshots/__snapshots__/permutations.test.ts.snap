exports[`Framework x Style-System Permutation Snapshots > Framework: vue > Theme: minimal > StyleSystem: scss > Component: Dialog > renders correctly 1`] = `
{
  "Dialog.vue": "<script setup lang="ts">
import { computed } from 'vue';

export type DialogVariant = 'default' | 'confirm';
export type DialogSize    = 'sm' | 'md' | 'lg';

interface Props {
  isOpen?:  boolean;
  title?:   string;
  variant?: DialogVariant;
  size?:    DialogSize;
}

const props = withDefaults(defineProps<Props>(), {
  isOpen: false,
  title: '',
  variant: 'default',
  size: 'md',
});

const emit = defineEmits(['close']);

const onClose = () => {
  emit('close');
};

const dialogClasses = computed(() => [
  'Dialog',
  \`Dialog--\${props.size}\`,
  \`Dialog--\${props.variant}\`,
]);

const titleId = \`dialog-title-\${Math.floor(Math.random() * 1000000)}\`;
const descriptionId = \`dialog-desc-\${Math.floor(Math.random() * 1000000)}\`;
</script>

<template>
  <slot name="overlay" :close="onClose" :isOpen="isOpen">
    <div v-if="isOpen" class="dialog-overlay" @click="onClose">
      <slot name="content">
        <div :class="dialogClasses" @click.stop role="dialog" aria-modal="true" :aria-labelledby="titleId" :aria-describedby="descriptionId">
          <slot name="header">
            <header class="dialog-header">
              <slot name="title">
                <h2 :id="titleId" v-if="title" class="dialog-title">{{ title }}</h2>
              </slot>
              <slot name="description">
                <p :id="descriptionId" class="dialog-description">
                  <slot name="description-content" />
                </p>
              </slot>
              <slot name="close">
                <button type="button" class="dialog-close" @click="onClose" aria-label="Close Dialog">
                  &times;
                </button>
              </slot>
            </header>
          </slot>
          
          <slot name="body">
            <div class="dialog-body">
              <slot />
            </div>
          </slot>
          
          <slot name="footer" v-if="$slots.footer">
            <footer class="dialog-footer">
              <slot name="footer-content">
                <slot name="footer" />
              </slot>
            </footer>
          </slot>
        </div>
      </slot>
    </div>
  </slot>
</template>

<style scoped lang="scss">
/* Generated by Crucible — edit freely, re-generate with --force */

/* Generated by Crucible — edit freely, re-generate with --force */

.dialog-overlay, .overlay {
  --dialog-overlay-bg: rgba(0, 0, 0, 0.4);
  --Dialog-padding: calc(var(--spacing-unit) * 6);

  position:        fixed;
  top:             0;
  left:            0;
  right:           0;
  bottom:          0;
  background-color: var(--dialog-overlay-bg);
  display:         flex;
  align-items:     center;
  justify-content: center;
  z-index:         1000;
  padding:         var(--Dialog-padding);
}

.Dialog {
  --Dialog-radius: var(--radius-lg);
  --Dialog-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 10px 10px -5px rgba(0,0,0,0.04);

  background:      var(--color-surface);
  border-radius:   var(--Dialog-radius);
  box-shadow:      var(--Dialog-shadow);
  max-height:      calc(100vh - (var(--spacing-unit) * 10));
  display:         flex;
  flex-direction:  column;
  width:           100%;
  animation:       dialog-open 0.2s ease-out;
}

@keyframes dialog-open {
  from { opacity: 0; transform: scale(0.95) translateY(10px); }
  to   { opacity: 1; transform: scale(1) translateY(0); }
}

.dialog-header, .header {
  padding:        var(--Dialog-padding);
  border-bottom:  1px solid var(--color-border);
  display:        flex;
  align-items:    center;
  justify-content: space-between;
}

.dialog-title, .title {
  margin:      0;
  font-size:   1.25rem;
  font-weight: 600;
  color:       var(--color-text);
  font-family: var(--font-family);
}

.dialog-description, .description {
  margin:      0.5rem 0 0;
  font-size:   0.875rem;
  color:       var(--color-text-muted);
  font-family: var(--font-family);
  line-height: 1.5;
}

.dialog-close, .close-button {
  background:    transparent;
  border:        none;
  font-size:     1.5rem;
  line-height:   1;
  color:         var(--color-text-muted);
  cursor:        pointer;
  padding:       calc(var(--spacing-unit) * 2);
  border-radius: var(--radius-sm);
  transition:    background 0.15s ease;
}

.dialog-close:focus-visible, .close-button:focus-visible {
  outline: none;
  box-shadow: 0 0 0 2px var(--color-background), 0 0 0 4px var(--color-primary);
}

.dialog-close:hover, .close-button:hover {
  background: var(--color-background);
  color:      var(--color-text);
}

.dialog-body, .body {
  padding:     var(--Dialog-padding);
  overflow-y:  auto;
  font-family: var(--font-family);
  color:       var(--color-text);
  line-height: 1.5;
}

.dialog-footer, .footer {
  padding:       var(--Dialog-padding);
  border-top:    1px solid var(--color-border);
  display:       flex;
  justify-content: flex-end;
  gap:           calc(var(--spacing-unit) * 3);
}

/* Sizes */
.Dialog--sm { max-width: 400px; }
.Dialog--md { max-width: 600px; }
.Dialog--lg { max-width: 800px; }
</style>
",
