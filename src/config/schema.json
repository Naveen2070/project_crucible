{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "version": { "type": "string" },
    "framework": { "type": "string", "enum": ["react", "angular", "vue"] },
    "theme": { "type": "string", "enum": ["minimal", "soft", "custom"], "default": "minimal" },
    "styleSystem": { "type": "string", "enum": ["css", "tailwind", "scss"], "default": "css" },
    "darkMode": {
      "oneOf": [
        { "type": "boolean" },
        {
          "type": "object",
          "properties": {
            "strategy": { "type": "string", "enum": ["auto", "manual"] },
            "tokens": { "type": "object", "additionalProperties": { "type": "string" } }
          },
          "required": ["strategy"]
        }
      ],
      "default": false
    },
    "tokens": {
      "type": "object",
      "properties": {
        "color": { "type": "object", "additionalProperties": { "type": "string" } },
        "radius": { "type": "object", "additionalProperties": { "type": "string" } },
        "spacing": {
          "type": "object",
          "properties": {
            "unit": { "type": "string" }
          }
        },
        "typography": {
          "type": "object",
          "properties": {
            "fontFamily": { "type": "string" },
            "scaleBase": { "type": "string" }
          }
        },
        "components": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        }
      }
    },
    "features": {
      "type": "object",
      "properties": {
        "hover": { "type": "boolean", "default": true },
        "focusRing": { "type": "boolean", "default": true },
        "motionSafe": { "type": "boolean", "default": true },
        "compoundComponents": { "type": "boolean", "default": true }
      },
      "default": {}
    },
    "a11y": {
      "type": "object",
      "properties": {
        "focusRingStyle": { "type": "string", "default": "outline" },
        "focusRingColor": { "type": "string", "default": "var(--color-primary)" },
        "focusRingWidth": { "type": "string", "default": "2px" },
        "focusRingOffset": { "type": "string", "default": "2px" },
        "reduceMotion": { "type": "boolean", "default": true }
      },
      "default": {}
    },
    "flags": {
      "type": "object",
      "properties": {
        "outputDir": { "type": "string", "default": "src/components" },
        "stories": { "type": "boolean", "default": false }
      },
      "default": {}
    }
  },
  "required": ["version", "framework"]
}
