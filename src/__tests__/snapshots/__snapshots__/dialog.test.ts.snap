exports[`Dialog snapshots > tailwind mode snapshot 1`] = `
"import React, { useEffect, useId, createContext, useContext } from 'react';
import { FocusTrap } from 'focus-trap-react';

const variantClasses: Record<string, string> = {
  default: 'bg-[var(--color-surface)]',
  confirm: 'bg-[var(--color-surface)] border-t-4 border-[var(--color-primary)]',
 };

const sizeClasses: Record<string, string> = {
  sm: 'max-w-md',
  md: 'max-w-lg',
  lg: 'max-w-2xl',
};

export type DialogVariant = 'default' | 'confirm';
export type DialogSize    = 'sm' | 'md' | 'lg';

interface DialogContextValue {
  isOpen: boolean;
  onClose: () => void;
  titleId: string;
  variant: DialogVariant;
  size: DialogSize;
}

const DialogContext = createContext<DialogContextValue | undefined>(undefined);

const useDialogContext = () => {
  const context = useContext(DialogContext);
  if (!context) throw new Error('Dialog components must be wrapped in <Dialog />');
  return context;
};

export interface DialogProps {
  isOpen:   boolean;
  onClose:  () => void;
  variant?: DialogVariant;
  size?:    DialogSize;
  children: React.ReactNode;
}

const DialogRoot: React.FC<DialogProps> = ({
  isOpen,
  onClose,
  variant = 'default',
  size = 'md',
  children,
}) => {
  const titleId = useId();

  useEffect(() => {
    if (isOpen) {
      document.body.style.overflow = 'hidden';
    } else {
      document.body.style.overflow = '';
    }
    return () => {
      document.body.style.overflow = '';
    };
  }, [isOpen]);

  useEffect(() => {
    const handleEscape = (e: KeyboardEvent) => {
      if (e.key === 'Escape') onClose();
    };
    if (isOpen) {
      window.addEventListener('keydown', handleEscape);
    }
    return () => {
      window.removeEventListener('keydown', handleEscape);
    };
  }, [isOpen, onClose]);

  if (!isOpen) return null;

  return (
    <DialogContext.Provider value={{ isOpen, onClose, titleId, variant, size }}>
      {children}
    </DialogContext.Provider>
  );
};

const DialogOverlay: React.FC<{ children: React.ReactNode; className?: string }> = ({ children, className }) => {
  const { onClose } = useDialogContext();
  return (
    <div 
      className={["fixed inset-0 z-50 flex items-center justify-center p-4 bg-[var(--dialog-overlay-bg)] backdrop-blur-sm", className].filter(Boolean).join(' ')}
      onClick={onClose}
    >
      {children}
    </div>
  );
};

const DialogContent: React.FC<{ children: React.ReactNode; className?: string }> = ({ children, className }) => {
  const { titleId, variant, size } = useDialogContext();
  return (
    <FocusTrap>
      <div
        className={[
          'w-full bg-[var(--color-surface)] rounded-[var(--radius-lg)] shadow-2xl overflow-hidden',
          variantClasses[variant],
          sizeClasses[size],
          className
        ].filter(Boolean).join(' ')}
        role="dialog"
        aria-modal="true"
        aria-labelledby={titleId}
        onClick={(e) => e.stopPropagation()}
      >
        {children}
      </div>
    </FocusTrap>
  );
};

const DialogHeader: React.FC<{ children: React.ReactNode; className?: string }> = ({ children, className }) => (
  <header className={["flex items-center justify-between p-6 border-b border-[var(--color-border)]", className].filter(Boolean).join(' ')}>
    {children}
  </header>
);

const DialogTitle: React.FC<{ children: React.ReactNode; className?: string }> = ({ children, className }) => {
  const { titleId } = useDialogContext();
  return <h2 id={titleId} className={["text-xl font-bold text-[var(--color-text)]", className].filter(Boolean).join(' ')}>{children}</h2>;
};

const DialogClose: React.FC<{ className?: string }> = ({ className }) => {
  const { onClose } = useDialogContext();
  return (
    <button
      className={["text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors text-2xl", className].filter(Boolean).join(' ')}
      onClick={onClose}
      aria-label="Close Dialog"
    >
      &times;
    </button>
  );
};

const DialogBody: React.FC<{ children: React.ReactNode; className?: string }> = ({ children, className }) => (
  <div className={["p-6 text-[var(--color-text-muted)]", className].filter(Boolean).join(' ')}>
    {children}
  </div>
);

const DialogFooter: React.FC<{ children: React.ReactNode; className?: string }> = ({ children, className }) => (
  <footer className={["p-6 border-t border-[var(--color-border)] bg-[var(--color-background)]/50", className].filter(Boolean).join(' ')}>
    {children}
  </footer>
);

export const Dialog = Object.assign(DialogRoot, {
  Root: DialogRoot,
  Overlay: DialogOverlay,
  Content: DialogContent,
  Header: DialogHeader,
  Title: DialogTitle,
  Close: DialogClose,
  Body: DialogBody,
  Footer: DialogFooter,
});

Dialog.displayName = 'Dialog';
DialogRoot.displayName = 'Dialog.Root';
DialogOverlay.displayName = 'Dialog.Overlay';
DialogContent.displayName = 'Dialog.Content';
DialogHeader.displayName = 'Dialog.Header';
DialogTitle.displayName = 'Dialog.Title';
DialogClose.displayName = 'Dialog.Close';
DialogBody.displayName = 'Dialog.Body';
DialogFooter.displayName = 'Dialog.Footer';
"
`;

