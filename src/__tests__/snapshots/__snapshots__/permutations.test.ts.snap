  font-size:   14px;
  font-weight: 500;
  color:       var(--color-text);
}

.select-combobox, .combobox {
  --select-height: calc(var(--spacing-unit) * 10);
  --select-padding-x: calc(var(--spacing-unit) * 3);
  --select-radius: var(--radius-md);

  display:         flex;
  align-items:     center;
  justify-content: space-between;
  background:      var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius:   var(--select-radius);
  cursor:          pointer;
  font-family:     var(--font-family);
  color:           var(--color-text);
  transition:      border-color 0.15s ease, box-shadow 0.15s ease;
  width:           100%;
  min-height:      var(--select-height);
  padding:         0 var(--select-padding-x);
  box-sizing:      border-box;
}

.select-combobox--open, .combobox--open {
  border-color: var(--color-primary);
  border-bottom-left-radius: 0;
  border-bottom-right-radius: 0;
}

.select-combobox:focus-visible, .combobox:focus-visible {
  outline: none;
  border-color: var(--color-primary);
  box-shadow: 0 0 0 2px var(--color-background), 0 0 0 4px var(--color-primary);
}

.select-combobox--disabled, .combobox--disabled {
  background: var(--color-background);
  cursor:     not-allowed;
  opacity:    0.7;
}

.select-combobox--error, .combobox--error {
  border-color: var(--color-destructive);
}

.select-value, .value {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.select-arrow, .arrow {
  margin-left: calc(var(--spacing-unit) * 2);
  font-size:   0.8em;
  color:       var(--color-text-muted);
}

.select-listbox, .listbox {
