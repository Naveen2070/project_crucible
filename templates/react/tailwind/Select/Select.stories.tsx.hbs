import type { Meta, StoryObj } from '@storybook/react';
import { Select } from './Select';
import React, { useState } from 'react';

const meta: Meta<typeof Select> = {
  title: 'Crucible/{{name}}',
  component: Select,
  parameters: { layout: 'centered' },
  argTypes: {
    variant:  { control: 'select', options: [{{#each variants}}'{{this}}'{{#unless @last}}, {{/unless}}{{/each}}] },
    size:     { control: 'select', options: [{{#each sizes}}'{{this}}'{{#unless @last}}, {{/unless}}{{/each}}] },
    disabled: { control: 'boolean' },
  },
};
export default meta;
type Story = StoryObj<typeof Select>;

const options = [
  { value: 'react', label: 'React' },
  { value: 'angular', label: 'Angular' },
  { value: 'vue', label: 'Vue' },
  { value: 'svelte', label: 'Svelte' },
];

{{#if features.compoundComponents}}
export const Default: Story = {
  render: (args) => {
    const [value, setValue] = useState('');
    return (
      <Select {...args} options={options} value={value} onChange={setValue}>
        <Select.Label>Favorite Framework</Select.Label>
        <Select.Trigger />
      </Select>
    );
  }
};
{{else}}
export const Default: Story = {
  args: { 
    label: 'Favorite Framework',
    options,
    placeholder: 'Select a framework',
  },
};
{{/if}}
