exports[`Framework x Style-System Permutation Snapshots > Framework: vue > Theme: soft > StyleSystem: tailwind > Component: Input > renders correctly 1`] = `
{
  "Input.vue": "<script setup lang="ts">
import { ref, computed } from 'vue';

export type InputVariant = 'default' | 'error';
export type InputSize    = 'sm' | 'md' | 'lg';

interface Props {
  id?:          string;
  label?:       string;
  placeholder?: string;
  variant?:     InputVariant;
  size?:        InputSize;
  error?:       string;
  hint?:        string;
  disabled?:    boolean;
  required?:    boolean;
  type?:        'text' | 'password';
}

const props = withDefaults(defineProps<Props>(), {
  id: '',
  label: '',
  placeholder: '',
  variant: 'default',
  size: 'md',
  error: '',
  hint: '',
  disabled: false,
  required: false,
  type: 'text',
});

const showPassword = ref(false);
const generatedId = \`input-\${Math.floor(Math.random() * 1000000)}\`;
const inputId = computed(() => props.id || generatedId);
const errorId = computed(() => \`\${inputId.value}-error\`);
const hintId = computed(() => \`\${inputId.value}-hint\`);

const describedBy = computed(() => {
  const ids = [];
  if (props.error) ids.push(errorId.value);
  if (props.hint) ids.push(hintId.value);
  return ids.join(' ') || undefined;
});

const togglePassword = () => {
  showPassword.value = !showPassword.value;
};

const currentType = computed(() => {
  if (props.type === 'password') {
    return showPassword.value ? 'text' : 'password';
  }
  return props.type;
});

const variantClasses: Record<InputVariant, string> = {
  default: 'bg-[var(--color-surface)] border-[var(--color-border)] focus:border-[var(--color-primary)]',
  error: 'bg-[var(--color-surface)] border-[var(--color-destructive)] focus:border-[var(--color-destructive)]',
 };

const sizeClasses: Record<InputSize, string> = {
  sm: 'px-3 py-1.5 text-sm',
  md: 'px-4 py-2 text-base',
  lg: 'px-5 py-3 text-lg',
};

const inputClasses = computed(() => [
  'w-full border-[1px] rounded-[var(--radius-md)] outline-none transition-all',
  'focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] focus-visible:ring-offset-2',
  'disabled:opacity-50 disabled:cursor-not-allowed',
  variantClasses[props.variant],
  sizeClasses[props.size],
  props.type === 'password' ? 'pr-12' : '',
  props.error ? 'border-[var(--color-destructive)]' : '',
]);
</script>

<template>
  <div class="flex flex-col gap-[var(--spacing-unit)] w-full">
    <slot name="label">
      <label v-if="label" :for="inputId" class="font-medium text-[var(--color-text)] text-sm">
        {{ label }}
        <span v-if="required" class="text-[var(--color-destructive)] ml-1" aria-hidden="true">*</span>
      </label>
    </slot>
    
    <div class="relative w-full">
      <slot name="field">
        <input
          :id="inputId"
          :type="currentType"
          :class="inputClasses"
          :placeholder="placeholder"
          :disabled="disabled"
          :aria-invalid="!!error"
          :aria-required="required"
          :aria-describedby="describedBy"
        >
      </slot>
      
      <slot name="toggle" v-if="type === 'password'">
        <button
          type="button"
          class="absolute right-3 top-1/2 -translate-y-1/2 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-text)] focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] rounded-sm"
          @click="togglePassword"
          :aria-label="showPassword ? 'Hide password' : 'Show password'"
          :aria-pressed="showPassword"
        >
          {{ showPassword ? 'Hide' : 'Show' }}
        </button>
      </slot>
    </div>

    <slot name="hint">
      <span v-if="hint && !error" :id="hintId" class="text-xs text-[var(--color-text-muted)]">{{ hint }}</span>
    </slot>

    <slot name="error">
      <span v-if="error" :id="errorId" class="text-xs text-[var(--color-destructive)]" role="alert">{{ error }}</span>
    </slot>
  </div>
</template>
",
