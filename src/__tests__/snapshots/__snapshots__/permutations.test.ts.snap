  "Dialog.tsx": "import React, { useEffect, useId, createContext, useContext } from 'react';
import { FocusTrap } from 'focus-trap-react';
import styles from './Dialog.module.scss';
export type DialogVariant = 'default' | 'confirm';
export type DialogSize    = 'sm' | 'md' | 'lg';

export interface DialogProps {
  isOpen:    boolean;
  onClose:   () => void;
  title?:    string;
  children:  React.ReactNode;
  variant?:  DialogVariant;
  size?:     DialogSize;
  footer?:   React.ReactNode;
}

interface DialogContextValue {
  isOpen: boolean;
  onClose: () => void;
  size: DialogSize;
  titleId: string;
}

const DialogContext = createContext<DialogContextValue | undefined>(undefined);

const useDialogContext = () => {
  const context = useContext(DialogContext);
  if (!context) throw new Error('Dialog sub-components must be used within Dialog');
  return context;
};

export const DialogRoot = ({
  isOpen,
  onClose,
  children,
  size = 'md',
}: {
  isOpen: boolean;
  onClose: () => void;
  children: React.ReactNode;
  size?: DialogSize;
}) => {
  const titleId = useId();

  useEffect(() => {
    if (isOpen) {
      document.body.style.overflow = 'hidden';
    } else {
      document.body.style.overflow = '';
    }
    return () => {
      document.body.style.overflow = '';
    };
  }, [isOpen]);

  useEffect(() => {
    const handleEscape = (e: KeyboardEvent) => {
      if (e.key === 'Escape') onClose();
    };
    if (isOpen) {
      window.addEventListener('keydown', handleEscape);
    }
    return () => {
      window.removeEventListener('keydown', handleEscape);
    };
  }, [isOpen, onClose]);

  if (!isOpen) return null;

  return (
    <DialogContext.Provider value={{ isOpen, onClose, size, titleId }}>
      <FocusTrap>
        {children as React.ReactElement}
      </FocusTrap>
    </DialogContext.Provider>
  );
};

export const DialogOverlay = ({ children, className }: { children: React.ReactNode; className?: string }) => {
  const { onClose } = useDialogContext();
  return (
    <div className={[styles.overlay, className].filter(Boolean).join(' ')} onClick={onClose}>
      {children}
    </div>
  );
};

export const DialogContent = ({ children, className }: { children: React.ReactNode; className?: string }) => {
  const { size, titleId } = useDialogContext();
  return (
    <div
      className={[styles.Dialog, styles[\`Dialog--\${size}\`], className].filter(Boolean).join(' ')}
      role="dialog"
      aria-modal="true"
      aria-labelledby={titleId}
      aria-describedby={\`\${titleId}-desc\`}
      onClick={(e) => e.stopPropagation()}
    >
      {children}
    </div>
  );
};

export const DialogHeader = ({ children, className }: { children: React.ReactNode; className?: string }) => (
  <header className={[styles.header, className].filter(Boolean).join(' ')}>
    {children}
  </header>
);

export const DialogTitle = ({ children, className }: { children: React.ReactNode; className?: string }) => {
  const { titleId } = useDialogContext();
  return <h2 id={titleId} className={[styles.title, className].filter(Boolean).join(' ')}>{children}</h2>;
};

export const DialogDescription = ({ children, className }: { children: React.ReactNode; className?: string }) => {
  const { titleId } = useDialogContext();
  return <p id={\`\${titleId}-desc\`} className={[styles.description, className].filter(Boolean).join(' ')}>{children}</p>;
};

export const DialogClose = ({ className }: { className?: string }) => {
  const { onClose } = useDialogContext();
  return (
    <button
      className={[styles['close-button'], className].filter(Boolean).join(' ')}
      onClick={onClose}
      aria-label="Close Dialog"
    >
      &times;
    </button>
  );
};

export const DialogBody = ({ children, className }: { children: React.ReactNode; className?: string }) => (
  <div className={[styles.body, className].filter(Boolean).join(' ')}>
    {children}
  </div>
);

export const DialogFooter = ({ children, className }: { children: React.ReactNode; className?: string }) => (
  <footer className={[styles.footer, className].filter(Boolean).join(' ')}>
    {children}
  </footer>
);

export const Dialog = Object.assign(DialogRoot, {
  Root: DialogRoot,
  Overlay: DialogOverlay,
  Content: DialogContent,
  Header: DialogHeader,
  Title: DialogTitle,
  Description: DialogDescription,
  Close: DialogClose,
  Body: DialogBody,
  Footer: DialogFooter,
});

Dialog.displayName = 'Dialog';
DialogRoot.displayName = 'Dialog.Root';
DialogOverlay.displayName = 'Dialog.Overlay';
DialogContent.displayName = 'Dialog.Content';
DialogHeader.displayName = 'Dialog.Header';
DialogTitle.displayName = 'Dialog.Title';
DialogDescription.displayName = 'Dialog.Description';
DialogClose.displayName = 'Dialog.Close';
DialogBody.displayName = 'Dialog.Body';
DialogFooter.displayName = 'Dialog.Footer';
",
