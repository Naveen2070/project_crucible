{{#if features.compoundComponents}}
export const WithSlots: Story = {
  args: { label: 'Custom Label' },
  render: (args) => ({
    components: { Input },
    setup() {
      const value = ref('');
      return { args, value };
    },
    template: `
<Input v-bind="args" v-model="value">
  <template #label>
    <label style="color: var(--color-primary); font-weight: bold;">Custom Slot Label</label>
  </template>
  <template #error>
    <span style="color: var(--color-destructive);">Custom error message slot</span>
  </template>
</Input>`,
  }),
};
