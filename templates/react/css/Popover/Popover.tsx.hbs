import React, { createContext, useContext, useState, useRef, useEffect } from 'react';
{{> react/styles-import}}

{{#if features.compoundComponents}}
type PopoverContextType = {
  isOpen: boolean;
  setIsOpen: (open: boolean) => void;
  variant: string;
  size: string;
  placement: string;
  alignment: string;
};

const PopoverContext = createContext<PopoverContextType | undefined>(undefined);

const usePopover = () => {
  const context = useContext(PopoverContext);
  if (!context) {
    throw new Error('Popover compound components must be used within a Popover.Root');
  }
  return context;
};
{{/if}}

export interface PopoverProps {
  /**
   * Controlled open state
   */
  isOpen?: boolean;
  /**
   * Callback for open state changes
   */
  onOpenChange?: (open: boolean) => void;
  /**
   * Placement relative to trigger
   * @default 'bottom'
   */
  placement?: 'top' | 'bottom' | 'left' | 'right';
  /**
   * Alignment relative to trigger
   * @default 'center'
   */
  alignment?: 'start' | 'center' | 'end';
  /**
   * Trigger type
   * @default 'click'
   */
  trigger?: 'click' | 'hover';
  /**
   * Whether to close when clicking outside
   * @default true
   */
  closeOnClickOutside?: boolean;
  /**
   * Whether to close when pressing Escape
   * @default true
   */
  closeOnEscape?: boolean;
  /**
   * Visual variant
   * @default 'default'
   */
  variant?: 'default' | 'minimal';
  /**
   * Size
   * @default 'md'
   */
  size?: 'sm' | 'md' | 'lg';
  /**
   * Additional class name
   */
  className?: string;
  /**
   * Content
   */
  children?: React.ReactNode;
}

{{#if features.compoundComponents}}
/**
 * Popover.Root - Container that manages the state
 */
export const PopoverRoot: React.FC<PopoverProps> = ({
  isOpen: controlledOpen,
  onOpenChange,
  placement = 'bottom',
  alignment = 'center',
  variant = 'default',
  size = 'md',
  children,
  className = '',
}) => {
  const [internalOpen, setInternalOpen] = useState(false);
  const isOpen = controlledOpen !== undefined ? controlledOpen : internalOpen;

  const setIsOpen = (open: boolean) => {
    if (controlledOpen === undefined) {
      setInternalOpen(open);
    }
    onOpenChange?.(open);
  };

  return (
    <PopoverContext.Provider value=\{{ isOpen, setIsOpen, variant, size, placement, alignment }}>
      <div className={`${styles.popover} ${className}`}>{children}</div>
    </PopoverContext.Provider>
  );
};

/**
 * Popover.Trigger - The element that toggles the popover
 */
export const PopoverTrigger: React.FC<{ children: React.ReactNode; className?: string }> = ({
  children,
  className = '',
}) => {
  const { isOpen, setIsOpen } = usePopover();
  const triggerRef = useRef<HTMLDivElement>(null);

  return (
    <div
      ref={triggerRef}
      className={`${styles.trigger} ${className}`}
      onClick={() => setIsOpen(!isOpen)}
    >
      {children}
    </div>
  );
};

/**
 * Popover.Content - The floating panel
 */
export const PopoverContent: React.FC<{ children: React.ReactNode; className?: string }> = ({
  children,
  className = '',
}) => {
  const { isOpen, setIsOpen, variant, size, placement, alignment } = usePopover();
  const contentRef = useRef<HTMLDivElement>(null);

  useEffect(() => {
    if (!isOpen) return;

    const handleClickOutside = (event: MouseEvent) => {
      if (contentRef.current && !contentRef.current.contains(event.target as Node)) {
        setIsOpen(false);
      }
    };

    const handleEscape = (event: KeyboardEvent) => {
      if (event.key === 'Escape') {
        setIsOpen(false);
      }
    };

    document.addEventListener('mousedown', handleClickOutside);
    document.addEventListener('keydown', handleEscape);
    return () => {
      document.removeEventListener('mousedown', handleClickOutside);
      document.removeEventListener('keydown', handleEscape);
    };
  }, [isOpen, setIsOpen]);

  if (!isOpen) return null;

  return (
    <div
      ref={contentRef}
      className={`
        ${styles.content}
        ${styles[`placement-${placement}`]}
        ${styles[`alignment-${alignment}`]}
        ${styles[`variant-${variant}`]}
        ${styles[`size-${size}`]}
        ${isOpen ? styles['content-open'] : ''}
        ${className}
      `}
    >
      {children}
    </div>
  );
};

/**
 * Popover.Item - An item within the popover content
 */
export const PopoverItem: React.FC<{
  children: React.ReactNode;
  className?: string;
  onClick?: () => void;
  closeOnClick?: boolean;
}> = ({ children, className = '', onClick, closeOnClick = true }) => {
  const { setIsOpen } = usePopover();

  const handleClick = () => {
    onClick?.();
    if (closeOnClick) {
      setIsOpen(false);
    }
  };

  return (
    <div className={`${styles.item} ${className}`} onClick={handleClick}>
      {children}
    </div>
  );
};

/**
 * Popover.Separator - A divider between items
 */
export const PopoverSeparator: React.FC<{ className?: string }> = ({ className = '' }) => (
  <div className={`${styles.separator} ${className}`} />
);

/**
 * Popover.Sub - Nested popover for submenus
 */
export const PopoverSub: React.FC<{ children: React.ReactNode; className?: string }> = ({
  children,
  className = '',
}) => {
  const [isOpen, setIsOpen] = useState(false);

  return (
    <div
      className={`${styles.sub} ${className}`}
      onMouseEnter={() => setIsOpen(true)}
      onMouseLeave={() => setIsOpen(false)}
    >
      {children}
    </div>
  );
};

/**
 * Popover.SubTrigger - Trigger for submenus
 */
export const PopoverSubTrigger: React.FC<{ children: React.ReactNode; className?: string }> = ({
  children,
  className = '',
}) => (
  <div className={`${styles.item} ${styles.subTrigger} ${className}`}>
    {children}
  </div>
);

/**
 * Popover.SubContent - Content for submenus
 */
export const PopoverSubContent: React.FC<{ children: React.ReactNode; className?: string }> = ({
  children,
  className = '',
}) => {
  // Accessing parent context for styling consistency
  const context = usePopover();
  
  return (
    <div className={`
      ${styles.content}
      ${styles.subContent}
      ${styles[`variant-${context.variant}`]}
      ${styles[`size-${context.size}`]}
      ${className}
    `}>
      {children}
    </div>
  );
};
{{/if}}

/**
 * Main Popover Component
 */
export const Popover: React.FC<PopoverProps> & {
  {{#if features.compoundComponents}}
  Root: typeof PopoverRoot;
  Trigger: typeof PopoverTrigger;
  Content: typeof PopoverContent;
  Item: typeof PopoverItem;
  Separator: typeof PopoverSeparator;
  Sub: typeof PopoverSub;
  SubTrigger: typeof PopoverSubTrigger;
  SubContent: typeof PopoverSubContent;
  {{/if}}
} = (props) => {
  {{#if features.compoundComponents}}
  return (
    <PopoverRoot {...props}>
      {props.children}
    </PopoverRoot>
  );
  {{else}}
  const {
    isOpen: controlledOpen,
    onOpenChange,
    placement = 'bottom',
    alignment = 'center',
    variant = 'default',
    size = 'md',
    children,
    className = '',
  } = props;

  const [internalOpen, setInternalOpen] = useState(false);
  const isOpen = controlledOpen !== undefined ? controlledOpen : internalOpen;
  const contentRef = useRef<HTMLDivElement>(null);

  const setIsOpen = (open: boolean) => {
    if (controlledOpen === undefined) {
      setInternalOpen(open);
    }
    onOpenChange?.(open);
  };

  useEffect(() => {
    if (!isOpen) return;

    const handleClickOutside = (event: MouseEvent) => {
      if (contentRef.current && !contentRef.current.contains(event.target as Node)) {
        setIsOpen(false);
      }
    };

    const handleEscape = (event: KeyboardEvent) => {
      if (event.key === 'Escape') {
        setIsOpen(false);
      }
    };

    document.addEventListener('mousedown', handleClickOutside);
    document.addEventListener('keydown', handleEscape);
    return () => {
      document.removeEventListener('mousedown', handleClickOutside);
      document.removeEventListener('keydown', handleEscape);
    };
  }, [isOpen]);

  // For monolithic version, we assume children contains [trigger, content]
  // In a real implementation we might use React.Children.map to identify components
  // But for this scaffold we'll keep it simple
  return (
    <div className={`${styles.popover} ${className}`}>
      <div onClick={() => setIsOpen(!isOpen)}>
        {/* Assume first child is trigger */}
        {Array.isArray(children) ? children[0] : 'Trigger'}
      </div>
      {isOpen && (
        <div
          ref={contentRef}
          className={`
            ${styles.content}
            ${styles[`placement-${placement}`]}
            ${styles[`alignment-${alignment}`]}
            ${styles[`variant-${variant}`]}
            ${styles[`size-${size}`]}
            ${styles['content-open']}
          `}
        >
          {Array.isArray(children) ? children.slice(1) : children}
        </div>
      )}
    </div>
  );
  {{/if}}
};

{{#if features.compoundComponents}}
Popover.Root = PopoverRoot;
Popover.Trigger = PopoverTrigger;
Popover.Content = PopoverContent;
Popover.Item = PopoverItem;
Popover.Separator = PopoverSeparator;
Popover.Sub = PopoverSub;
Popover.SubTrigger = PopoverSubTrigger;
Popover.SubContent = PopoverSubContent;
{{/if}}

export default Popover;
