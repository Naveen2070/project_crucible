}

/* Sizes */
.select-combobox--sm, .combobox--sm { min-height: var(--select-height); font-size: 13px; }
.select-combobox--md, .combobox--md { min-height: var(--select-height); font-size: 15px; }
.select-combobox--lg, .combobox--lg { min-height: var(--select-height); font-size: 17px; }
