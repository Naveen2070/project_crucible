  --color-text-muted: #6D6490;
  --color-destructive: #DC2626;
  --color-success: #059669;
  --color-primary-foreground: #fff;
  --color-secondary-foreground: #1E1B2E;
  --color-destructive-foreground: #fff;
  --color-accent-foreground: #1E1B2E;
  --foreground: #1E1B2E;
  --radius-sm: 6px;
  --radius-md: 4px;
  --radius-lg: 20px;
  --spacing-unit: 4px;
  --font-family: "Inter", system-ui, sans-serif;
  --font-size-base: 16px;
}


.input-container {
  display:        flex;
  flex-direction: column;
  gap:            var(--spacing-unit);
  width:          100%;

  .label {
    font-family: var(--font-family);
    font-size:   14px;
    font-weight: 500;
    color:       var(--color-text);
  }

  .required {
    color:       var(--color-destructive);
    margin-left: 2px;
  }

  .input-wrapper {
    position: relative;
    width:    100%;
  }

  .input {
    width:           100%;
    font-family:     var(--font-family);
    border: 1px solid var(--color-border);
    border-radius:   var(--radius-md);
    background:      var(--color-surface);
    color:           var(--color-text);
    transition:      border-color 0.15s ease, box-shadow 0.15s ease;
    box-sizing:      border-box;

    &:focus-visible {
      outline:        2px solid var(--color-primary);
      outline-offset: 3px;
      border-color:   var(--color-primary);
    }

    &--sm { padding: 6px 10px;  font-size: 13px; }
    &--md { padding: 10px 14px; font-size: 15px; }
    &--lg { padding: 14px 18px; font-size: 17px; }
  }

  &--error .input {
    border-color: var(--color-destructive);
  }

  &--disabled .input {
    background: var(--color-background);
    cursor:     not-allowed;
    opacity:    0.7;
  }

  .password-toggle {
    position:   absolute;
    right:      12px;
    top:        50%;
    transform:  translateY(-50%);
    background: transparent;
    border:     none;
    padding:    0;
    margin:     0;
    font-family: var(--font-family);
    font-size:  12px;
    color:      var(--color-text-muted);
    cursor:     pointer;

    &:hover {
      color: var(--color-text);
    }
  }

  .error {
    color:       var(--color-destructive);
    font-family: var(--font-family);
    font-size:   12px;
    margin-top:  2px;
  }
}
",
  "input.component.ts": "import { Component, Input } from '@angular/core';
import { CommonModule } from '@angular/common';

@Component({
  selector: 'app-input',
  standalone: true,
  imports: [CommonModule],
  templateUrl: './input.component.html',
  styleUrls: ['./input.component.css'],
})
export class InputComponent {
  @Input() label = '';
  @Input() placeholder = '';
  @Input() value = '';
  @Input() error = '';
  @Input() hint = '';
  @Input() disabled = false;
  @Input() required = false;
  @Input() size: 'sm' | 'md' | 'lg' = 'sm';

  id = 'input-' + Math.random().toString(36).substring(2, 9);
}
",
}
