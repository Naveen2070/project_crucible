  "select.component.html": "<div class="select-container">
  @if (label) {
    <label [attr.for]="id" class="select-label">{{ label }}</label>
  }
  
  <div class="select-wrapper">
    <ng-content select="[prefix]"></ng-content>
    <select
      [id]="id"
      class="select-combobox"
      [class.select-combobox--sm]="size === 'sm'"
      [class.select-combobox--md]="size === 'md'"
      [class.select-combobox--lg]="size === 'lg'"
      [class.select-combobox--error]="variant === 'error' || error"
      [disabled]="disabled"
      [attr.aria-invalid]="!!error"
      (change)="onChange($event)"
    >
      <option value="" disabled>{{ placeholder }}</option>
      @for (opt of options; track opt.value) {
        <option [value]="opt.value">{{ opt.label }}</option>
      }
    </select>
    <ng-content select="[suffix]"></ng-content>
  </div>

  @if (error) {
    <span class="select-error" role="alert">{{ error }}</span>
  }
  <ng-content></ng-content>
</div>
