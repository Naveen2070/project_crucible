import { Meta, StoryObj } from '@storybook/angular';
import { CardComponent } from './card.component';

const meta: Meta<CardComponent> = {
  title: 'Crucible/Card',
  component: CardComponent,
  tags: ['autodocs'],
  argTypes: {
    variant: { control: 'select', options: {{> shared/variant-options}} },
    size:    { control: 'select', options: {{> shared/size-options}} },
    title:   { control: 'text' },
  },
};

export default meta;
type Story = StoryObj<CardComponent>;

export const Default: Story = {
  args: {
    title: 'Card Title',
    variant: 'default',
    size: 'md',
  },
  render: (args) => ({
    props: args,
    template: `<app-card [title]="title" [variant]="variant" [size]="size">This is the card content.</app-card>`,
  }),
};

{{#each variants}}
{{#unless (eq this "default")}}
export const {{capitalize this}}: Story = {
  args: { variant: '{{this}}', title: '{{capitalize this}} Variant' },
  render: (args) => ({
    props: args,
    template: `<app-card [title]="title" [variant]="variant" [size]="size">Card content with {{this}} variant.</app-card>`,
  }),
};
{{/unless}}
{{/each}}

{{#each sizes}}
export const {{capitalize this}}: Story = {
  args: { size: '{{this}}', title: '{{capitalize this}} Size' },
  render: (args) => ({
    props: args,
    template: `<app-card [title]="title" [variant]="variant" [size]="size">Card content with {{this}} size.</app-card>`,
  }),
};
{{/each}}

export const CustomContent: Story = {
  args: { title: 'Custom Content' },
  render: (args) => ({
    props: args,
    template: `
      <app-card [title]="title">
        <div card-header>
          <strong style="color: var(--color-primary)">Custom Header</strong>
        </div>
        <p>Main card content goes here.</p>
        <div card-footer>
          <small>Posted 2 hours ago</small>
        </div>
      </app-card>
    `,
  }),
};
