/* Generated by Crucible — edit freely, re-generate with --force */

{{> shared/css-tokens}}

.container {
  display:        flex;
  flex-direction: column;
  gap:            var(--spacing-unit);
  width:          100%;
  position:       relative;
}

.label {
  font-family: var(--font-family);
  font-size:   14px;
  font-weight: 500;
  color:       var(--color-text);
}

.combobox {
  display:         flex;
  align-items:     center;
  justify-content: space-between;
  background:      var(--color-surface);
  border:          1.5px solid var(--color-border);
  border-radius:   var(--radius-md);
  cursor:          pointer;
  font-family:     var(--font-family);
  color:           var(--color-text);
  transition:      border-color 0.15s ease, box-shadow 0.15s ease;
  width:           100%;
  box-sizing:      border-box;
}

.combobox--open {
  border-color: var(--color-primary);
  border-bottom-left-radius: 0;
  border-bottom-right-radius: 0;
}

{{#if a11y.focusRing}}
.combobox:focus-visible {
  outline:        {{a11y.focusRingWidth}} solid {{a11y.focusRingColor}};
  outline-offset: {{a11y.focusRingOffset}};
  border-color:   var(--color-primary);
}
{{/if}}

.combobox--disabled {
  background: var(--color-background);
  cursor:     not-allowed;
  opacity:    0.7;
}

.combobox--error {
  border-color: var(--color-danger);
}

.value {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.arrow {
  margin-left: calc(var(--spacing-unit) * 2);
  font-size:   0.8em;
  color:       var(--color-text-muted);
}

.listbox {
  position:      absolute;
  top:           100%;
  left:          0;
  right:         0;
  background:    var(--color-surface);
  border:        1.5px solid var(--color-primary);
  border-top:    none;
  border-radius: 0 0 var(--radius-md) var(--radius-md);
  list-style:    none;
  margin:        0;
  padding:       0;
  z-index:       10;
  max-height:    200px;
  overflow-y:    auto;
  box-shadow:    0 10px 15px -3px rgba(0, 0, 0, 0.1);
}

.option {
  padding:     calc(var(--spacing-unit) * 2) calc(var(--spacing-unit) * 4);
  cursor:      pointer;
  font-family: var(--font-family);
  font-size:   14px;
  color:       var(--color-text);
  transition:  background 0.15s ease;
}

.option--active {
  background: var(--color-secondary);
  color:      var(--color-primary);
}

.option--selected {
  font-weight: 600;
  background:  var(--color-secondary);
  color:       var(--color-primary);
}

.error {
  color:       var(--color-danger);
  font-family: var(--font-family);
  font-size:   12px;
  margin-top:  2px;
}

/* Sizes */
.combobox--sm { padding: 6px 10px;  font-size: 13px; }
.combobox--md { padding: 10px 14px; font-size: 15px; }
.combobox--lg { padding: 14px 18px; font-size: 17px; }
