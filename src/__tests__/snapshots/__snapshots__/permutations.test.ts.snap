  overflow: auto;
}

.tableContainerVirtual {
  overflow: auto;
}

.table {
  width: 100%;
  border-collapse: collapse;
}

.tableLoading {
  opacity: 0.5;
  pointer-events: none;
}

.thead {
  background-color: var(--color-surface);
  position: sticky;
  top: 0;
  z-index: 10;
}

