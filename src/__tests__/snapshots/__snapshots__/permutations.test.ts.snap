  "card.component.html": "<div 
  class="card"
  [class.card--sm]="size === 'sm'"
  [class.card--md]="size === 'md'"
  [class.card--lg]="size === 'lg'"
  [class.card--hoverable]="variant === 'hoverable'"
  [class.card--clickable]="variant === 'clickable'"
  [attr.tabindex]="variant === 'clickable' ? 0 : null"
  [attr.role]="variant === 'clickable' ? 'button' : article"
>
  <header class="p-6 border-b border-[var(--color-border)] empty:hidden flex items-start justify-between gap-4">
    <div>
      <ng-content select="[header]"></ng-content>
      @if (title) {
        <h3 class="m-0 text-lg font-semibold text-[var(--color-text)]">{{ title }}</h3>
      }
      <p class="m-0 text-sm text-[var(--color-text-muted)]">
        <ng-content select="[description]"></ng-content>
      </p>
    </div>
    <div class="flex-shrink-0">
      <ng-content select="[action]"></ng-content>
    </div>
  </header>

  <div class="flex-1 p-6 text-[var(--color-text-muted)]">
    <ng-content select="[content]"></ng-content>
    <ng-content></ng-content>
  </div>

  <footer class="p-6 border-t border-[var(--color-border)] empty:hidden">
    <ng-content select="[footer]"></ng-content>
  </footer>
</div>",
  "card.component.ts": "import { Component, Input } from '@angular/core';

const variantClasses: Record<string, string> = {
  default: 'bg-[var(--color-surface)] border-[var(--color-border)]',
  hoverable: 'bg-[var(--color-surface)] border-[var(--color-border)] hover:shadow-lg',
  clickable: 'bg-[var(--color-surface)] border-[var(--color-border)] cursor-pointer hover:shadow-lg',
 };

const sizeClasses: Record<string, string> = {
  sm: 'max-w-[300px]',
  md: 'max-w-[450px]',
  lg: 'max-w-[600px]',
};

@Component({
  selector: 'app-card',
  templateUrl: './card.component.html'
})
export class CardComponent {
  @Input() title = '';
  @Input() variant: 'default' | 'hoverable' | 'clickable' = 'default';
  @Input() size:    'sm' | 'md' | 'lg' = 'md';
  @Input() className = '';

  get classes(): string {
    const isClickable = this.variant === 'clickable';
    return [
      'rounded-[var(--radius-lg)] border-[1px] border-[var(--color-border)] transition-all text-left w-full flex flex-col bg-[var(--color-surface)] overflow-hidden',
      'focus-visible:outline focus-visible:outline-[2px] focus-visible:outline-[var(--color-primary)] focus-visible:outline-offset-[3px]',
      variantClasses[this.variant],
      sizeClasses[this.size],
      isClickable ? 'cursor-pointer hover:border-[var(--color-primary)] hover:shadow-lg hover:-translate-y-0.5 active:translate-y-0' : '',
      this.className
    ].filter(Boolean).join(' ');
  }
}
",
}
`;

