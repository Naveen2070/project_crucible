",
  "input.component.css": "/* Generated by Crucible — edit freely, re-generate with --force */

.input-container {
  display:        flex;
  flex-direction: column;
  gap:            var(--spacing-unit);
  width:          100%;
}

.input-label, .label {
  font-family: var(--font-family);
  font-size:   0.875rem;
  font-weight: 500;
  color:       var(--color-text);
  margin-bottom: calc(var(--spacing-unit) * 1.5);
}

.input-required, .required {
  color:       var(--color-destructive);
  margin-left: calc(var(--spacing-unit) * 0.5);
}

.input-wrapper {
  position: relative;
  width:    100%;
}

.input {
  --input-height: calc(var(--spacing-unit) * 10);
  --input-radius: var(--radius-md);
  --input-border: var(--color-border);
  --input-transition: border-color 0.2s ease, box-shadow 0.2s ease;

  width:           100%;
  font-family:     var(--font-family);
  border:          1px solid var(--input-border);
  border-radius:   var(--input-radius);
  background:      var(--color-surface);
  color:           var(--color-text);
  transition:      var(--input-transition);
  box-sizing:      border-box;
}

.input:focus-visible {
  outline: none;
  border-color: var(--color-primary);
  box-shadow: 0 0 0 2px var(--color-background), 0 0 0 4px var(--color-primary);
}

/* Sizes */
.input--sm { 
  min-height: var(--input-height);
  padding:    0 calc(var(--spacing-unit) * 3);
  font-size:  0.875rem; 
}
.input--md { 
  min-height: var(--input-height);
  padding:    0 calc(var(--spacing-unit) * 3);
  font-size:  1rem; 
}
.input--lg { 
  min-height: var(--input-height);
  padding:    0 calc(var(--spacing-unit) * 3);
  font-size:  1.125rem; 
}

/* Variants */
.input--error {
  border-color: var(--color-destructive);
}

.input--disabled {
  background: var(--color-background);
  cursor:     not-allowed;
  opacity:    0.7;
}

.input-password-toggle, .password-toggle {
  position:   absolute;
  right:      12px;
  top:        50%;
  transform:  translateY(-50%);
  background: transparent;
  border:     none;
  padding:    0;
  margin:     0;
  font-family: var(--font-family);
  font-size:  12px;
  color:      var(--color-text-muted);
  cursor:     pointer;
}

.input-password-toggle:hover, .password-toggle:hover {
  color: var(--color-text);
}

.input-password-toggle:focus-visible, .password-toggle:focus-visible {
  outline:        2px solid var(--color-primary);
  outline-offset: 3px;
  border-radius:  var(--radius-sm);
}

.input-hint, .input-error, .hint, .error {
  font-family: var(--font-family);
  font-size:   12px;
  margin-top:  2px;
}

.input-hint, .hint {
  color: var(--color-text-muted);
}

.input-error, .error {
  color: var(--color-destructive);
}
",
  "input.component.html": "<div class="input-container">
  @if (label) {
    <label [attr.for]="id" class="label">
      {{ label }}
      @if (required) {
        <span class="required">*</span>
      }
    </label>
  }
  
  <div class="input-wrapper">
    <ng-content select="[prefix]"></ng-content>
    <input
      [id]="id"
      type="text"
      class="input"
      [class.input--sm]="size === 'sm'"
      [class.input--md]="size === 'md'"
      [class.input--lg]="size === 'lg'"
      [class.input--error]="error"
      [class.input--disabled]="disabled"
      [placeholder]="placeholder"
      [disabled]="disabled"
      [attr.aria-invalid]="!!error"
      [attr.aria-required]="required"
    />
    <ng-content select="[suffix]"></ng-content>
  </div>

  @if (hint && !error) {
    <span class="hint">{{ hint }}</span>
  }
  @if (error) {
    <span class="error" role="alert">{{ error }}</span>
  }
  <ng-content></ng-content>
</div>
",
  "input.component.ts": "import { Component, Input } from '@angular/core';
import { CommonModule } from '@angular/common';

