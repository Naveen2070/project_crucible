{
  "Input.vue": "<script setup lang="ts">
import { ref, computed } from 'vue';

export type InputVariant = 'default' | 'error';
export type InputSize    = 'sm' | 'md' | 'lg';

interface Props {
  id?:          string;
  modelValue?:  string;
  label?:       string;
  placeholder?: string;
  variant?:     InputVariant;
  size?:        InputSize;
  error?:       string;
  hint?:        string;
  disabled?:    boolean;
  required?:    boolean;
  type?:        'text' | 'password';
}

const props = withDefaults(defineProps<Props>(), {
  id: '',
  modelValue: '',
  label: '',
  placeholder: '',
  variant: 'default',
  size: 'md',
  error: '',
  hint: '',
  disabled: false,
  required: false,
  type: 'text',
});

const emit = defineEmits(['update:modelValue']);

const showPassword = ref(false);
const generatedId = \`input-\${Math.floor(Math.random() * 1000000)}\`;
const inputId = computed(() => props.id || generatedId);
const errorId = computed(() => \`\${inputId.value}-error\`);
const hintId = computed(() => \`\${inputId.value}-hint\`);

const onInput = (event: Event) => {
  const target = event.target as HTMLInputElement;
  emit('update:modelValue', target.value);
};

const describedBy = computed(() => {
  const ids = [];
  if (props.error) ids.push(errorId.value);
  if (props.hint) ids.push(hintId.value);
  return ids.join(' ') || undefined;
});

const togglePassword = () => {
  showPassword.value = !showPassword.value;
};

const currentType = computed(() => {
  if (props.type === 'password') {
    return showPassword.value ? 'text' : 'password';
  }
  return props.type;
});

const containerClasses = computed(() => [
  'input-container',
  \`input--\${props.size}\`,
  {
    'input--error': props.variant === 'error' || props.error,
    'input--disabled': props.disabled,
  },
]);
</script>

<template>
  <div :class="containerClasses">
    <slot name="label">
      <label v-if="label" :for="inputId" class="input-label">
        {{ label }}
        <span v-if="required" class="input-required" aria-hidden="true">*</span>
      </label>
    </slot>
    
    <div class="input-wrapper">
      <slot name="field">
        <input
          :id="inputId"
          :type="currentType"
          :class="['input', \`input--\${size}\`]"
          :placeholder="placeholder"
          :disabled="disabled"
          :value="modelValue"
          @input="onInput"
          :aria-invalid="!!error"
          :aria-required="required"
          :aria-describedby="describedBy"
        >
      </slot>
      
      <slot name="toggle" v-if="type === 'password'">
        <button
          type="button"
          class="input-password-toggle"
          @click="togglePassword"
          :aria-label="showPassword ? 'Hide password' : 'Show password'"
          :aria-pressed="showPassword"
        >
          {{ showPassword ? 'Hide' : 'Show' }}
        </button>
      </slot>
    </div>

    <slot name="hint">
      <span v-if="hint && !error" :id="hintId" class="input-hint">{{ hint }}</span>
    </slot>

    <slot name="error">
      <span v-if="error" :id="errorId" class="input-error" role="alert">{{ error }}</span>
    </slot>
  </div>
</template>

<style scoped>
