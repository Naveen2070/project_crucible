import { Component, Input } from '@angular/core';

const variantClasses: Record<string, string> = {
{{#each variants}}  {{this}}: '{{lookup ../tailwindVariants this}}',
{{/each}} };

const sizeClasses: Record<string, string> = {
  sm: 'max-w-[300px]',
  md: 'max-w-[450px]',
  lg: 'max-w-[600px]',
};

@Component({
  selector: 'app-card',
  templateUrl: './card.component.html'
})
export class CardComponent {
  @Input() title = '';
  @Input() variant: {{#each variants}}'{{this}}'{{#unless @last}} | {{/unless}}{{/each}} = 'default';
  @Input() size:    {{#each sizes}}'{{this}}'{{#unless @last}} | {{/unless}}{{/each}} = 'md';
  @Input() className = '';

  get classes(): string {
    const isClickable = this.variant === 'clickable';
    return [
      'rounded-[var(--radius-lg)] border-[1px] border-[var(--color-border)] transition-all text-left w-full flex flex-col bg-[var(--color-surface)] overflow-hidden',
      {{#if a11y.focusRing}}'focus-visible:outline focus-visible:outline-[{{a11y.focusRingWidth}}] focus-visible:outline-[{{a11y.focusRingColor}}] focus-visible:outline-offset-[{{a11y.focusRingOffset}}]',{{/if}}
      variantClasses[this.variant],
      sizeClasses[this.size],
      isClickable ? 'cursor-pointer hover:border-[var(--color-primary)] hover:shadow-lg hover:-translate-y-0.5 active:translate-y-0' : '',
      this.className
    ].filter(Boolean).join(' ');
  }
}
