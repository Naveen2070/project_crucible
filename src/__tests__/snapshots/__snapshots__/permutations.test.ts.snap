",
  "select.component.html": "<div class="select-container">
  @if (label) {
    <label [attr.for]="id" class="select-label">{{ label }}</label>
  }
  
  <div class="select-wrapper">
    <ng-content select="[prefix]"></ng-content>
    <select
      [id]="id"
      class="select-combobox"
      [class.select-combobox--sm]="size === 'sm'"
      [class.select-combobox--md]="size === 'md'"
      [class.select-combobox--lg]="size === 'lg'"
      [class.select-combobox--error]="variant === 'error' || error"
      [disabled]="disabled"
      [attr.aria-invalid]="!!error"
      (change)="onChange($event)"
    >
      <option value="" disabled>{{ placeholder }}</option>
      @for (opt of options; track opt.value) {
        <option [value]="opt.value">{{ opt.label }}</option>
      }
    </select>
    <ng-content select="[suffix]"></ng-content>
  </div>

  @if (error) {
    <span class="select-error" role="alert">{{ error }}</span>
  }
  <ng-content></ng-content>
</div>
",
  "select.component.scss": "/* Generated by Crucible — edit freely, re-generate with --force */

.select-container, .container {
  display:        flex;
  flex-direction: column;
  gap:            var(--spacing-unit);
  width:          100%;
  position:       relative;
}

.select-wrapper {
  position:       relative;
  display:        flex;
  align-items:    center;
  width:          100%;
}

.select-label, .label {
  font-family: var(--font-family);
  font-size:   14px;
  font-weight: 500;
  color:       var(--color-text);
}

.select-combobox, .combobox {
  --select-height: calc(var(--spacing-unit) * 10);
  --select-padding-x: calc(var(--spacing-unit) * 3);
  --select-radius: var(--radius-md);

  display:         flex;
  align-items:     center;
  justify-content: space-between;
  background:      var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius:   var(--select-radius);
  cursor:          pointer;
  font-family:     var(--font-family);
  color:           var(--color-text);
  transition:      border-color 0.15s ease, box-shadow 0.15s ease;
  width:           100%;
  min-height:      var(--select-height);
  padding:         0 var(--select-padding-x);
  box-sizing:      border-box;
}

.select-combobox--open, .combobox--open {
  border-color: var(--color-primary);
  border-bottom-left-radius: 0;
  border-bottom-right-radius: 0;
}

.select-combobox:focus-visible, .combobox:focus-visible {
  outline: none;
  border-color: var(--color-primary);
  box-shadow: 0 0 0 2px var(--color-background), 0 0 0 4px var(--color-primary);
}

.select-combobox--disabled, .combobox--disabled {
  background: var(--color-background);
  cursor:     not-allowed;
  opacity:    0.7;
}

.select-combobox--error, .combobox--error {
  border-color: var(--color-destructive);
}

.select-value, .value {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.select-arrow, .arrow {
  margin-left: calc(var(--spacing-unit) * 2);
  font-size:   0.8em;
  color:       var(--color-text-muted);
}

.select-listbox, .listbox {
  --select-dropdown-shadow: 0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -2px rgba(0,0,0,0.05);

  position:      absolute;
  top:           100%;
  left:          0;
  right:         0;
  background:    var(--color-surface);
  border: 1px solid var(--color-primary);
  border-top:    none;
  border-radius: 0 0 var(--select-radius) var(--select-radius);
  list-style:    none;
  margin:        0;
  padding:       0;
  z-index:       900;
  max-height:    200px;
  overflow-y:    auto;
  box-shadow:    var(--select-dropdown-shadow);
}

.select-option, .option {
  --select-option-padding: calc(var(--spacing-unit) * 2.5);
  padding:     var(--select-option-padding) var(--select-padding-x);
  cursor:      pointer;
  font-family: var(--font-family);
  font-size:   14px;
  color:       var(--color-text);
  transition:  background 0.15s ease;
}

.select-option--active, .option--active {
  background: var(--color-secondary);
  color:      var(--color-primary);
}

.select-option--selected, .option--selected {
  font-weight: 600;
  background:  var(--color-secondary);
  color:       var(--color-primary);
}

.select-error, .error {
  color:       var(--color-destructive);
  font-family: var(--font-family);
  font-size:   12px;
  margin-top:  2px;
}

/* Group and Indicator */
.select-group, .select-group-label {
  padding:     0.5rem var(--select-padding-x);
  font-size:   0.75rem;
  font-weight: 600;
  color:       var(--color-text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.item-indicator {
  width:      1.25rem;
  height:     1.25rem;
  display:    flex;
  align-items: center;
  justify-content: center;
  color:       var(--color-primary);
}

/* Sizes */
.select-combobox--sm, .combobox--sm { min-height: var(--select-height); font-size: 13px; }
.select-combobox--md, .combobox--md { min-height: var(--select-height); font-size: 15px; }
.select-combobox--lg, .combobox--lg { min-height: var(--select-height); font-size: 17px; }
",
  "select.component.ts": "import { Component, Input, Output, EventEmitter } from '@angular/core';
import { CommonModule } from '@angular/common';

@Component({
  selector: 'app-select',
  standalone: true,
  imports: [CommonModule],
  templateUrl: './select.component.html',
  styleUrls: ['./select.component.css'],
})
export class SelectComponent {
  @Input() label = '';
  @Input() placeholder = 'Select an option';
  @Input() options: { label: string; value: any }[] = [];
  @Input() value: any = null;
  @Input() error = '';
  @Input() disabled = false;
  @Input() size: 'sm' | 'md' | 'lg' = 'sm';
  @Input() variant: 'default' | 'error' = 'default';

  @Output() valueChange = new EventEmitter<any>();

  id = 'select-' + Math.random().toString(36).substring(2, 9);

  onChange(event: Event) {
    const target = event.target as HTMLSelectElement;
    this.value = target.value;
    this.valueChange.emit(this.value);
  }
}
",
}
`;

