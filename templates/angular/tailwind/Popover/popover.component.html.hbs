<div [class]="'relative inline-block ' + className">
  <div #triggerRef class="cursor-pointer" (click)="toggle()">
    <ng-content select="[trigger]"></ng-content>
  </div>

  @if (isOpen) {
    <div 
      #contentRef 
      class="absolute z-[var(--popover-z-index)] rounded-[var(--popover-radius)] min-w-[180px] overflow-hidden"
      [ngClass]="getTailwindClasses()"
    >
      <ng-content></ng-content>
    </div>
  }
</div>
