/* Generated by Crucible — edit freely, re-generate with --force */

.overlay {
  --modal-overlay-bg: {{tokens.componentTokens.modal.overlayBg}};
  --modal-padding: {{tokens.componentTokens.modal.padding}};

  position:        fixed;
  top:             0;
  left:            0;
  right:           0;
  bottom:          0;
  background-color: var(--modal-overlay-bg);
  display:         flex;
  align-items:     center;
  justify-content: center;
  z-index:         1000;
  padding:         var(--modal-padding);
}

.modal {
  --modal-radius: {{tokens.componentTokens.modal.borderRadius}};
  --modal-shadow: {{tokens.componentTokens.modal.shadow}};

  background:      var(--color-surface);
  border-radius:   var(--modal-radius);
  box-shadow:      var(--modal-shadow);
  max-height:      calc(100vh - (var(--spacing-unit) * 10));
  display:         flex;
  flex-direction:  column;
  width:           100%;
  animation:       modalIn 0.3s ease-out;
}

@keyframes modalIn {
  from { opacity: 0; transform: scale(0.95) translateY(10px); }
  to   { opacity: 1; transform: scale(1) translateY(0); }
}

.header {
  padding:        var(--modal-padding);
  border-bottom:  1px solid var(--color-border);
  display:        flex;
  align-items:    center;
  justify-content: space-between;
}

.title {
  margin:      0;
  font-size:   1.25rem;
  font-weight: 600;
  color:       var(--color-text);
  font-family: var(--font-family);
}

.closeButton {
  background:    transparent;
  border:        none;
  font-size:     1.5rem;
  line-height:   1;
  color:         var(--color-text-muted);
  cursor:        pointer;
  padding:       calc(var(--spacing-unit) * 2);
  border-radius: var(--radius-sm);
  transition:    background 0.15s ease;
}

.closeButton:hover {
  background: var(--color-background);
  color:      var(--color-text);
}

.body {
  padding:     var(--modal-padding);
  overflow-y:  auto;
  font-family: var(--font-family);
  color:       var(--color-text);
  line-height: 1.5;
}

.footer {
  padding:       var(--modal-padding);
  border-top:    1px solid var(--color-border);
  display:       flex;
  justify-content: flex-end;
  gap:           calc(var(--spacing-unit) * 3);
}

/* Sizes */
.modal--sm { max-width: 400px; }
.modal--md { max-width: 600px; }
.modal--lg { max-width: 800px; }
