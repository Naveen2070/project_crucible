<script setup lang="ts">
import { ref, computed } from 'vue';

export type SelectVariant = {{#each variants}}'{{this}}'{{#unless @last}} | {{/unless}}{{/each}};
export type SelectSize    = {{#each sizes}}'{{this}}'{{#unless @last}} | {{/unless}}{{/each}};

interface Props {
  options?:     any[];
  value?:       any;
  label?:       string;
  placeholder?: string;
  variant?:     SelectVariant;
  size?:        SelectSize;
  error?:       string;
  disabled?:    boolean;
}

const props = withDefaults(defineProps<Props>(), {
  options: () => [],
  value: null,
  label: '',
  placeholder: 'Select an option',
  variant: 'default',
  size: 'md',
  error: '',
  disabled: false,
});

const emit = defineEmits(['update:value']);

const isOpen = ref(false);

const toggle = () => {
  if (!props.disabled) {
    isOpen.value = !isOpen.value;
  }
};

const selectOption = (option: any) => {
  emit('update:value', option);
  isOpen.value = false;
};

const displayValue = computed(() => {
  return props.value ? (props.value.label || props.value) : props.placeholder;
});

const comboboxClasses = computed(() => [
  'combobox',
  `combobox--${props.size}`,
  {
    'combobox--error': props.variant === 'error' || props.error,
    'combobox--disabled': props.disabled,
    'combobox--open': isOpen.value,
  },
]);
</script>

<template>
  <div class="container">
    {{#if features.compoundComponents}}
    <slot name="label">
      <label v-if="label" class="label">\{{ label }}</label>
    </slot>
    {{else}}
    <label v-if="label" class="label">\{{ label }}</label>
    {{/if}}
    
    <div
      :class="comboboxClasses"
      @click="toggle"
      :aria-expanded="isOpen"
      role="combobox"
      aria-haspopup="listbox"
      tabindex="0"
    >
      {{#if features.compoundComponents}}
      <slot name="value">
        <span class="value">\{{ displayValue }}</span>
      </slot>
      <slot name="arrow">
        <span class="arrow" aria-hidden="true">▼</span>
      </slot>
      {{else}}
      <span class="value">\{{ displayValue }}</span>
      <span class="arrow" aria-hidden="true">▼</span>
      {{/if}}
    </div>

    <ul v-if="isOpen" class="listbox" role="listbox">
      {{#if features.compoundComponents}}
      <slot name="listbox">
        <li
          v-for="option in options"
          :key="option.value || option"
          @click="selectOption(option)"
          :class="['option', { 'option--selected': value === option }]"
          role="option"
        >
          <slot name="option" :option="option">
            \{{ option.label || option }}
          </slot>
        </li>
      </slot>
      {{else}}
      <li
        v-for="option in options"
        :key="option.value || option"
        @click="selectOption(option)"
        :class="['option', { 'option--selected': value === option }]"
        role="option"
      >
        \{{ option.label || option }}
      </li>
      {{/if}}
    </ul>

    {{#if features.compoundComponents}}
    <slot name="error">
      <span v-if="error" class="error" role="alert">\{{ error }}</span>
    </slot>
    {{else}}
    <span v-if="error" class="error" role="alert">\{{ error }}</span>
    {{/if}}
  </div>
</template>

