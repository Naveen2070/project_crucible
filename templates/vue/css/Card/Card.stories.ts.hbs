import type { Meta, StoryObj } from '@storybook/vue3';
import Card from './Card.vue';

const meta: Meta<typeof Card> = {
  title: 'Crucible/{{name}}',
  component: Card,
  argTypes: {
    variant: { control: 'select', options: {{> shared/variant-options}} },
    size:    { control: 'select', options: {{> shared/size-options}} },
  },
};

export default meta;
type Story = StoryObj<typeof Card>;

export const Default: Story = {
  args: { variant: 'default', size: 'md', title: 'Card Title' },
  render: (args) => ({
    components: { Card },
    setup() { return { args }; },
    template: `<Card :title="args.title" :variant="args.variant" :size="args.size">This is a default card with some content.</Card>`,
  }),
};

{{#each variants}}
{{#unless (eq this "default")}}
export const {{capitalize this}}: Story = {
  args: { variant: '{{this}}', title: '{{capitalize this}} Variant' },
  render: (args) => ({
    components: { Card },
    setup() { return { args }; },
    template: `<Card :title="args.title" :variant="args.variant">Card content with {{this}} variant.</Card>`,
  }),
};
{{/unless}}
{{/each}}

{{#each sizes}}
export const {{capitalize this}}: Story = {
  args: { size: '{{this}}', title: '{{capitalize this}} Size' },
  render: (args) => ({
    components: { Card },
    setup() { return { args }; },
    template: `<Card :title="args.title" :size="args.size">Card content with {{this}} size.</Card>`,
  }),
};
{{/each}}

{{#if features.compoundComponents}}
export const WithSlots: Story = {
  args: { variant: 'default' },
  render: (args) => ({
    components: { Card },
    setup() { return { args }; },
    template: `
<Card v-bind="args">
  <template #header>
    <div style="background: var(--color-accent); padding: 10px; font-style: italic;">Custom Header Slot</div>
  </template>
  <template #default>
    Custom card body via default slot.
  </template>
  <template #footer>
    <div style="text-align: right;">Custom Footer Slot</div>
  </template>
</Card>`,
  }),
};
{{/if}}
