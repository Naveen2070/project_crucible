",
  "card.component.ts": "import { Component, Input } from '@angular/core';

const variantClasses: Record<string, string> = {
  default: 'bg-[var(--color-surface)] border-[var(--color-border)]',
  hoverable: 'bg-[var(--color-surface)] border-[var(--color-border)] hover:shadow-lg',
  clickable: 'bg-[var(--color-surface)] border-[var(--color-border)] cursor-pointer hover:shadow-lg',
 };

const sizeClasses: Record<string, string> = {
  sm: 'max-w-[300px]',
  md: 'max-w-[450px]',
  lg: 'max-w-[600px]',
};

@Component({
  selector: 'app-card',
  templateUrl: './card.component.html'
})
export class CardComponent {
  @Input() title = '';
  @Input() variant: 'default' | 'hoverable' | 'clickable' = 'default';
  @Input() size:    'sm' | 'md' | 'lg' = 'md';
  @Input() className = '';

  get classes(): string {
    const isClickable = this.variant === 'clickable';
    return [
      'rounded-[var(--radius-lg)] border-[1px] border-[var(--color-border)] transition-all text-left w-full flex flex-col bg-[var(--color-surface)] overflow-hidden',
      'focus-visible:outline focus-visible:outline-[2px] focus-visible:outline-[var(--color-primary)] focus-visible:outline-offset-[3px]',
      variantClasses[this.variant],
      sizeClasses[this.size],
      isClickable ? 'cursor-pointer hover:border-[var(--color-primary)] hover:shadow-lg hover:-translate-y-0.5 active:translate-y-0' : '',
      this.className
    ].filter(Boolean).join(' ');
  }
}
",
}
`;

