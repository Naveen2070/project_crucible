/* Generated by Crucible — edit freely, re-generate with --force */

{{> shared/css-tokens}}

.select-container {
  display:        flex;
  flex-direction: column;
  gap:            var(--spacing-unit);
  width:          100%;
}

.label {
  font-family: var(--font-family);
  font-size:   14px;
  font-weight: 500;
  color:       var(--color-text);
}

.select-wrapper {
  position: relative;
  width:    100%;
}

.select {
  width:         100%;
  font-family:   var(--font-family);
  border:        1.5px solid var(--color-border);
  border-radius: var(--radius-md);
  background:    var(--color-surface);
  color:         var(--color-text);
  padding:       10px 14px;
  font-size:     15px;
  cursor:        pointer;
  transition:    border-color 0.15s ease, box-shadow 0.15s ease;
  box-sizing:    border-box;
}

{{#if a11y.focusRing}}
.select:focus-visible {
  outline:        {{a11y.focusRingWidth}} solid {{a11y.focusRingColor}};
  outline-offset: {{a11y.focusRingOffset}};
  border-color:   var(--color-primary);
}
{{/if}}

.select--disabled {
  background: var(--color-background);
  cursor:     not-allowed;
  opacity:    0.7;
}

.select--error {
  border-color: var(--color-danger);
}

.error {
  color:       var(--color-danger);
  font-family: var(--font-family);
  font-size:   12px;
  margin-top:  2px;
}

/* Sizes */
.select--sm { padding: 6px 10px;  font-size: 13px; }
.select--md { padding: 10px 14px; font-size: 15px; }
.select--lg { padding: 14px 18px; font-size: 17px; }
