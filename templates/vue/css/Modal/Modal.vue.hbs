<script setup lang="ts">
import { computed } from 'vue';

export type ModalVariant = {{#each variants}}'{{this}}'{{#unless @last}} | {{/unless}}{{/each}};
export type ModalSize    = {{#each sizes}}'{{this}}'{{#unless @last}} | {{/unless}}{{/each}};

interface Props {
  isOpen?:  boolean;
  title?:   string;
  variant?: ModalVariant;
  size?:    ModalSize;
}

const props = withDefaults(defineProps<Props>(), {
  isOpen: false,
  title: '',
  variant: 'default',
  size: 'md',
});

const emit = defineEmits(['close']);

const onClose = () => {
  emit('close');
};

const modalClasses = computed(() => [
  'modal',
  `modal--${props.size}`,
  `modal--${props.variant}`,
]);
</script>

<template>
  <div v-if="isOpen" class="overlay" @click="onClose">
    <div :class="modalClasses" @click.stop role="dialog" aria-modal="true">
      <header class="header">
        {{#if features.compoundComponents}}
        <slot name="title">
          <h2 v-if="title" class="title">\{{ title }}</h2>
        </slot>
        <slot name="close">
          <button type="button" class="closeButton" @click="onClose" aria-label="Close modal">
            &times;
          </button>
        </slot>
        {{else}}
        <h2 v-if="title" class="title">\{{ title }}</h2>
        <button type="button" class="closeButton" @click="onClose" aria-label="Close modal">
          &times;
        </button>
        {{/if}}
      </header>
      
      <div class="body">
        <slot />
      </div>
      
      <footer class="footer">
        <slot name="footer" />
      </footer>
    </div>
  </div>
</template>

