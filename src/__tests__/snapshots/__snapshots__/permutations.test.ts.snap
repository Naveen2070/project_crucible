  border:         1px solid var(--card-border);
  border-radius:  var(--card-radius);
  color:          var(--color-text);
  font-family:    var(--font-family);
  overflow:       hidden;
  text-align:     left;
  width:          100%;
  padding:        0;
  margin:         0;
  text-decoration: none;
  box-shadow:     var(--card-shadow);
}

.card:focus-visible {
  outline: none;
  box-shadow: 0 0 0 2px var(--card-bg), 0 0 0 4px var(--color-primary);
}

/* Sizes */
.card--sm { max-width: 300px; }
.card--md { max-width: 450px; }
.card--lg { max-width: 600px; }

/* Variants */
.card--hoverable:hover {
  border-color: var(--color-primary);
  box-shadow:   0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
}

.card--clickable {
  cursor: pointer;
  transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
}

.card--clickable:hover {
  border-color: var(--color-primary);
  box-shadow:   0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
  transform:    translateY(-4px);
}

.card--clickable:active {
  transform:    translateY(0);
}

.header, .card-header {
  padding: var(--card-header-padding);
  border-bottom: 1px solid var(--card-border);
}

.title, .card-title {
  margin:      0;
  font-size:   1.1rem;
  font-weight: 600;
  color:       var(--color-text);
  font-family: var(--font-family);
}

.description, .card-description {
  margin:      0;
  padding:     0 var(--card-header-padding);
  font-size:   0.875rem;
  color:       var(--color-text-muted);
  font-family: var(--font-family);
}

.action, .card-action {
  margin-left: auto;
  display:     flex;
  align-items: center;
  gap:        var(--spacing-unit);
}

.content, .card-content {
  padding: var(--card-content-padding);
}

.footer, .card-footer {
  padding: var(--card-footer-padding);
  border-top: 1px solid var(--card-border);
}
",
  "card.component.html": "<div 
  class="card"
  [class.card--sm]="size === 'sm'"
  [class.card--md]="size === 'md'"
  [class.card--lg]="size === 'lg'"
  [class.card--hoverable]="variant === 'hoverable'"
  [class.card--clickable]="variant === 'clickable'"
  [attr.tabindex]="variant === 'clickable' ? 0 : null"
  [attr.role]="variant === 'clickable' ? 'button' : article"
>
  <header class="card-header">
    <ng-content select="[card-title]"></ng-content>
    @if (title) {
      <h3 class="card-title">{{ title }}</h3>
    }
    <p class="card-description">
      <ng-content select="[card-description]"></ng-content>
    </p>
    <div class="card-action">
      <ng-content select="[card-action]"></ng-content>
    </div>
  </header>

  <div class="card-content">
    <ng-content select="[card-content]"></ng-content>
    <ng-content></ng-content>
  </div>

  <footer class="card-footer">
    <ng-content select="[card-footer]"></ng-content>
  </footer>
</div>
",
  "card.component.ts": "import { Component, Input } from '@angular/core';
import { CommonModule } from '@angular/common';

@Component({
  selector: 'app-card',
  standalone: true,
  imports: [CommonModule],
  templateUrl: './card.component.html',
  styleUrls: ['./card.component.css'],
})
export class CardComponent {
  @Input() title = '';
  @Input() variant: 'default' | 'hoverable' | 'clickable' = 'default';
  @Input() size: 'sm' | 'md' | 'lg' = 'sm';
}
",
}
`;

