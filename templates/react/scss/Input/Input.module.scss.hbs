/* Generated by Crucible — edit freely, re-generate with --force */

:root {
{{#each tokens.cssVars}}  {{@key}}: {{this}};
{{/each}}
}

{{#if tokens.darkCssVars}}
@media (prefers-color-scheme: dark) {
  :root {
{{#each tokens.darkCssVars}}    {{@key}}: {{this}};
{{/each}}  }
}
{{/if}}

.input-container {
  display:        flex;
  flex-direction: column;
  gap:            var(--spacing-unit);
  width:          100%;
}

.label {
  font-family: var(--font-family);
  font-size:   14px;
  font-weight: 500;
  color:       var(--color-text);
}

.required {
  color:       var(--color-danger);
  margin-left: 2px;
}

.input-wrapper {
  position: relative;
  width:    100%;
}

.input {
  width:           100%;
  font-family:     var(--font-family);
  border: 1px solid var(--color-border);
  border-radius:   var(--radius-md);
  background:      var(--color-surface);
  color:           var(--color-text);
  transition:      border-color 0.15s ease, box-shadow 0.15s ease;
  box-sizing:      border-box;

  &[type="password"],
  &[type="text"]:has(+ .password-toggle) {
    padding-right: 48px;
  }

  {{#if a11y.focusRing}}
  &:focus-visible {
    outline:        {{a11y.focusRingWidth}} solid {{a11y.focusRingColor}};
    outline-offset: {{a11y.focusRingOffset}};
    border-color:   var(--color-primary);
  }
  {{/if}}

  /* Sizes */
  &--sm { padding: 6px 10px;  font-size: 13px; }
  &--md { padding: 10px 14px; font-size: 15px; }
  &--lg { padding: 14px 18px; font-size: 17px; }

  /* Variants */
  &--error {
    border-color: var(--color-danger);
  }

  &--disabled {
    background: var(--color-background);
    cursor:     not-allowed;
    opacity:    0.7;
  }
}

.password-toggle {
  position:   absolute;
  right:      12px;
  top:        50%;
  transform:  translateY(-50%);
  background: transparent;
  border:     none;
  padding:    0;
  margin:     0;
  font-family: var(--font-family);
  font-size:  12px;
  color:      var(--color-text-muted);
  cursor:     pointer;

  &:hover {
    color: var(--color-text);
  }

  &:focus-visible {
    outline:        {{a11y.focusRingWidth}} solid {{a11y.focusRingColor}};
    outline-offset: {{a11y.focusRingOffset}};
    border-radius:  var(--radius-sm);
  }
}

.hint, .error {
  font-family: var(--font-family);
  font-size:   12px;
}

.hint {
  color: var(--color-text-muted);
}

.error {
  color: var(--color-danger);
}
