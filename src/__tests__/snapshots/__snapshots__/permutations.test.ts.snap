exports[`Framework x Style-System Permutation Snapshots > Framework: vue > Theme: soft > StyleSystem: tailwind > Component: Dialog > renders correctly 1`] = `
{
  "Dialog.vue": "<script setup lang="ts">
import { computed, onMounted, onUnmounted, watch } from 'vue';

export type DialogVariant = 'default' | 'confirm';
export type DialogSize    = 'sm' | 'md' | 'lg';

interface Props {
  isOpen?:  boolean;
  title?:   string;
  variant?: DialogVariant;
  size?:    DialogSize;
}

const props = withDefaults(defineProps<Props>(), {
  isOpen: false,
  title: '',
  variant: 'default',
  size: 'md',
});

const emit = defineEmits(['close']);

const onClose = () => {
  emit('close');
};

const variantClasses: Record<DialogVariant, string> = {
  default: 'bg-[var(--color-surface)]',
  confirm: 'bg-[var(--color-surface)] border-t-4 border-[var(--color-primary)]',
 };

const sizeClasses: Record<DialogSize, string> = {
  sm: 'max-w-md',
  md: 'max-w-lg',
  lg: 'max-w-2xl',
};

const dialogClasses = computed(() => [
  'w-full bg-[var(--color-surface)] rounded-[var(--radius-lg)] shadow-2xl overflow-hidden flex flex-col',
  'animate-[dialog-open_0.2s_ease-out]',
  variantClasses[props.variant],
  sizeClasses[props.size],
]);

watch(() => props.isOpen, (newVal) => {
  if (newVal) {
    document.body.style.overflow = 'hidden';
  } else {
    document.body.style.overflow = '';
  }
});

const handleEscape = (e: KeyboardEvent) => {
  if (e.key === 'Escape' && props.isOpen) onClose();
};

onMounted(() => {
  window.addEventListener('keydown', handleEscape);
});

onUnmounted(() => {
  window.removeEventListener('keydown', handleEscape);
  document.body.style.overflow = '';
});

const titleId = \`dialog-title-\${Math.floor(Math.random() * 1000000)}\`;
const descriptionId = \`dialog-desc-\${Math.floor(Math.random() * 1000000)}\`;
</script>

<template>
  <Teleport to="body">
    <slot name="overlay" :close="onClose" :isOpen="isOpen">
      <div 
        v-if="isOpen" 
        class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-[var(--dialog-overlay-bg)] backdrop-blur-sm"
        @click="onClose"
      >
        <slot name="content">
          <div 
            :class="dialogClasses" 
            @click.stop 
            role="dialog" 
            aria-modal="true"
            :aria-labelledby="titleId"
            :aria-describedby="descriptionId"
          >
            <slot name="header">
              <header class="flex items-center justify-between p-6 border-b border-[var(--color-border)]">
                <slot name="title">
                  <h2 :id="titleId" v-if="title" class="text-xl font-bold text-[var(--color-text)]">{{ title }}</h2>
                </slot>
                <slot name="description">
                  <p :id="descriptionId" class="text-sm text-[var(--color-text-muted)] mt-1">
                    <slot name="description-content" />
                  </p>
                </slot>
                <slot name="close">
                  <button 
                    type="button" 
                    class="text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors text-2xl p-2 rounded-[var(--radius-sm)] hover:bg-[var(--color-background)]" 
                    @click="onClose" 
                    aria-label="Close Dialog"
                  >
                    &times;
                  </button>
                </slot>
              </header>
            </slot>
            
            <slot name="body">
              <div class="p-6 overflow-y-auto text-[var(--color-text)] leading-relaxed flex-1">
                <slot />
              </div>
            </slot>
            
            <slot name="footer" v-if="$slots.footer">
              <footer class="p-6 border-t border-[var(--color-border)] bg-[var(--color-background)]/50 flex justify-end gap-3">
                <slot name="footer-content">
                  <slot name="footer" />
                </slot>
              </footer>
            </slot>
          </div>
        </slot>
      </div>
    </slot>
  </Teleport>
</template>

<style scoped>
@keyframes dialog-open {
  from { opacity: 0; transform: scale(0.95) translateY(10px); }
  to   { opacity: 1; transform: scale(1) translateY(0); }
}
</style>
",
  "README.md": "# Dialog

Generated by Crucible v1.0.0 | Theme: soft | Framework: vue

