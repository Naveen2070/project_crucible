  "dialog.component.html": "@if (isOpen) {
  <div class="dialog-overlay" (click)="onOverlayClick($event)">
    <div 
      class="Dialog"
      [class.Dialog--sm]="size === 'sm'"
      [class.Dialog--md]="size === 'md'"
      [class.Dialog--lg]="size === 'lg'"
      [class.Dialog--confirm]="variant === 'confirm'"
      role="dialog" 
      aria-modal="true"
      [attr.aria-labelledby]="titleId"
      [attr.aria-describedby]="descriptionId"
      (click)="$event.stopPropagation()"
    >
      <ng-content select="[dialog-content]"></ng-content>
      <header class="dialog-header">
        <h2 [id]="titleId" class="dialog-title">
          <ng-content select="[dialog-title]">{{ title }}</ng-content>
        </h2>
        <p [id]="descriptionId" class="dialog-description">
          <ng-content select="[dialog-description]"></ng-content>
        </p>
        <button type="button" class="dialog-close" (click)="onClose()" aria-label="Close Dialog">
          <ng-content select="[dialog-close]">&times;</ng-content>
        </button>
      </header>
      
      <div class="dialog-body">
        <ng-content select="[dialog-body]"></ng-content>
        <ng-content></ng-content>
      </div>
      
      <footer class="dialog-footer">
        <ng-content select="[dialog-footer]"></ng-content>
      </footer>
    </div>
  </div>
}
",
  "dialog.component.scss": "/* Generated by Crucible — edit freely, re-generate with --force */

.dialog-overlay, .overlay {
  --dialog-overlay-bg: rgba(0, 0, 0, 0.4);
  --Dialog-padding: calc(var(--spacing-unit) * 6);

  position:        fixed;
  top:             0;
  left:            0;
  right:           0;
  bottom:          0;
  background-color: var(--dialog-overlay-bg);
  display:         flex;
  align-items:     center;
  justify-content: center;
  z-index:         1000;
  padding:         var(--Dialog-padding);
}

.Dialog {
  --Dialog-radius: var(--radius-lg);
  --Dialog-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 10px 10px -5px rgba(0,0,0,0.04);

  background:      var(--color-surface);
  border-radius:   var(--Dialog-radius);
  box-shadow:      var(--Dialog-shadow);
  max-height:      calc(100vh - (var(--spacing-unit) * 10));
  display:         flex;
  flex-direction:  column;
  width:           100%;
  animation:       dialog-open 0.2s ease-out;
}

@keyframes dialog-open {
  from { opacity: 0; transform: scale(0.95) translateY(10px); }
  to   { opacity: 1; transform: scale(1) translateY(0); }
}

.dialog-header, .header {
  padding:        var(--Dialog-padding);
  border-bottom:  1px solid var(--color-border);
  display:        flex;
  align-items:    center;
  justify-content: space-between;
}

.dialog-title, .title {
  margin:      0;
  font-size:   1.25rem;
  font-weight: 600;
  color:       var(--color-text);
  font-family: var(--font-family);
}

.dialog-description, .description {
  margin:      0.5rem 0 0;
  font-size:   0.875rem;
  color:       var(--color-text-muted);
  font-family: var(--font-family);
  line-height: 1.5;
}

.dialog-close, .close-button {
  background:    transparent;
  border:        none;
  font-size:     1.5rem;
  line-height:   1;
  color:         var(--color-text-muted);
  cursor:        pointer;
  padding:       calc(var(--spacing-unit) * 2);
  border-radius: var(--radius-sm);
  transition:    background 0.15s ease;
}

.dialog-close:focus-visible, .close-button:focus-visible {
  outline: none;
  box-shadow: 0 0 0 2px var(--color-background), 0 0 0 4px var(--color-primary);
}

.dialog-close:hover, .close-button:hover {
  background: var(--color-background);
  color:      var(--color-text);
}

.dialog-body, .body {
  padding:     var(--Dialog-padding);
  overflow-y:  auto;
  font-family: var(--font-family);
  color:       var(--color-text);
  line-height: 1.5;
}

.dialog-footer, .footer {
  padding:       var(--Dialog-padding);
  border-top:    1px solid var(--color-border);
  display:       flex;
  justify-content: flex-end;
  gap:           calc(var(--spacing-unit) * 3);
}

/* Sizes */
.Dialog--sm { max-width: 400px; }
.Dialog--md { max-width: 600px; }
.Dialog--lg { max-width: 800px; }
",
  "dialog.component.ts": "import { Component, Input, Output, EventEmitter } from '@angular/core';
import { CommonModule } from '@angular/common';

@Component({
  selector: 'app-Dialog',
  standalone: true,
  imports: [CommonModule],
  templateUrl: './dialog.component.html',
  styleUrls: ['./dialog.component.css'],
})
export class DialogComponent {
  @Input() isOpen = false;
  @Input() title = '';
  @Input() description = '';
  @Input() size: 'sm' | 'md' | 'lg' = 'sm';
  @Input() variant: 'default' | 'confirm' = 'default';

  @Output() close = new EventEmitter<void>();

  titleId = \`dialog-title-\${Math.random().toString(36).substr(2, 9)}\`;
  descriptionId = \`dialog-desc-\${Math.random().toString(36).substr(2, 9)}\`;

  onClose() {
    this.close.emit();
  }

  onOverlayClick(event: MouseEvent) {
    if ((event.target as HTMLElement).classList.contains('dialog-overlay')) {
      this.onClose();
    }
  }
}
",
}
`;

