@if (isOpen) {
  <div 
    class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-[var(--dialog-overlay-bg)] backdrop-blur-sm"
    (click)="onClose()"
  >
    <ng-content select="[dialog-overlay]"></ng-content>
    <div
      [class]="dialogClasses"
      role="dialog"
      aria-modal="true"
      [attr.aria-labelledby]="titleId"
      [attr.aria-describedby]="descriptionId"
      (click)="$event.stopPropagation()"
    >
      <ng-content select="[dialog-content]"></ng-content>
      <header class="flex items-center justify-between p-6 border-b border-[var(--color-border)]">
        <ng-content select="[dialog-header]"></ng-content>
        <h2 [id]="titleId" class="text-xl font-bold text-[var(--color-text)]">
          <ng-content select="[dialog-title]">\{{ title }}</ng-content>
        </h2>
        <ng-content select="[dialog-description]"></ng-content>
        <p [id]="descriptionId" class="text-sm text-[var(--color-text-muted)]">
          <ng-content select="[description]"></ng-content>
        </p>
        <button
          type="button"
          class="ml-auto text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors text-2xl"
          (click)="onClose()"
          aria-label="Close Dialog"
        >
          <ng-content select="[dialog-close]">&times;</ng-content>
        </button>
      </header>
      
      <div class="p-6 text-[var(--color-text-muted)]">
        <ng-content select="[dialog-body]"></ng-content>
        <ng-content></ng-content>
      </div>
      
      <footer class="p-6 border-t border-[var(--color-border)] bg-[var(--color-background)]/50 flex justify-end gap-3 empty:hidden">
        <ng-content select="[dialog-footer]"></ng-content>
      </footer>
    </div>
  </div>
}
