import { Component, Input } from '@angular/core';

@Component({
  selector: 'app-input',
  templateUrl: './input.component.html',
  styleUrls: ['./input.component.{{#if (eq styleSystem "scss")}}scss{{else}}css{{/if}}']
})
export class InputComponent {
  private static nextId = 0;
  @Input() id = `input-${InputComponent.nextId++}`;
  @Input() label = '';
  @Input() placeholder = '';
  @Input() variant: {{> shared/variant-types}} = 'default';
  @Input() size:    {{> shared/size-types}} = 'md';
  @Input() error = '';
  @Input() hint = '';
  @Input() disabled = false;
  @Input() required = false;
  @Input() type: 'text' | 'password' = 'text';

  showPassword = false;

  togglePassword() {
    this.showPassword = !this.showPassword;
  }

  get currentType(): string {
    if (this.type === 'password') {
      return this.showPassword ? 'text' : 'password';
    }
    return this.type;
  }

  get containerClasses(): string {
    return [
      'input-container',
      `input--${this.size}`,
      this.variant === 'error' || this.error ? 'input--error' : '',
      this.disabled ? 'input--disabled' : ''
    ].filter(Boolean).join(' ');
  }

  get errorId(): string {
    return `${this.id}-error`;
  }

  get hintId(): string {
    return `${this.id}-hint`;
  }

  get describedBy(): string | null {
    const ids = [];
    if (this.error) ids.push(this.errorId);
    if (this.hint) ids.push(this.hintId);
    return ids.length ? ids.join(' ') : null;
  }
}
