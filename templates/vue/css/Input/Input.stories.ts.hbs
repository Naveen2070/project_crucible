import type { Meta, StoryObj } from '@storybook/vue3';
import { ref } from 'vue';
import Input from './Input.vue';

const meta: Meta<typeof Input> = {
  title: 'Crucible/{{name}}',
  component: Input,
  tags: ['autodocs'],
  argTypes: {
    variant:     { control: 'select', options: {{> shared/variant-options}} },
    size:        { control: 'select', options: {{> shared/size-options}} },
    type:        { control: 'select', options: ['text', 'password'] },
    disabled:    { control: 'boolean' },
    required:    { control: 'boolean' },
  },
};

export default meta;
type Story = StoryObj<typeof Input>;

export const Default: Story = {
  args: {
    label: 'Username',
    placeholder: 'Enter your username',
    size: 'md',
  },
  render: (args) => ({
    components: { Input },
    setup() {
      const value = ref('');
      return { args, value };
    },
    template: `<Input v-bind="args" v-model="value" />`,
  }),
};

{{#each sizes}}
export const {{capitalize this}}: Story = {
  args: { size: '{{this}}', label: '{{capitalize this}} Size', placeholder: 'Input with {{this}} size' },
  render: (args) => ({
    components: { Input },
    setup() {
      const value = ref('');
      return { args, value };
    },
    template: `<Input v-bind="args" v-model="value" />`,
  }),
};
{{/each}}

