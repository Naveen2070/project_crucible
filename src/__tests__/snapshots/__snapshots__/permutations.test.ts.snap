  "Table.tsx": "import React, { useState, useMemo, useCallback, useRef, useEffect } from 'react';
import { sort, SortDirection } from '../../utils/table-sorter';
import { getPageData, getPageNumbers } from '../../utils/table-paginator';
import { VirtualState, HeadlessVirtualizer } from '../../utils/virtualizer';

export type TableVariant = 'default' | 'striped' | 'bordered' | 'compact';
export type TableSize    = 'sm' | 'md' | 'lg';

export interface TableColumn<T = unknown> {
  key: string;
  label: string;
  sortable?: boolean;
  width?: string;
  align?: 'left' | 'center' | 'right';
}

export interface TableProps<T = unknown> {
  columns: TableColumn<T>[];
  data: T[];
  rowKey: keyof T;
  variant?: TableVariant;
  size?: TableSize;
  virtualize?: boolean;
  virtualizationThreshold?: number;
  itemHeight?: number;
  customVirtualState?: VirtualState;
  paginationMode?: 'client' | 'server';
  pageSize?: number;
  page?: number;
  totalPages?: number;
  totalCount?: number;
  onPageChange?: (page: number, pageSize: number) => void;
  sortKey?: string;
  sortDirection?: SortDirection;
  onSort?: (key: string, direction: SortDirection) => void;
  selectionMode?: 'single' | 'multiple' | 'none';
  selectedRows?: string[];
  onSelect?: (keys: string[]) => void;
  onSelectAll?: (selected: boolean) => void;
  loading?: boolean;
  emptyMessage?: string;
  className?: string;
}

const sizeClasses: Record<string, string> = {
  sm: 'text-sm py-2',
  md: 'text-base py-3',
  lg: 'text-lg py-4',
};

const alignClasses: Record<string, string> = {
  left: 'text-left',
  center: 'text-center',
  right: 'text-right',
};

export const TableRoot = <T extends Record<string, unknown>>({
  columns,
  data,
  rowKey,
  variant = 'default',
  size = 'md',
  virtualize = false,
  virtualizationThreshold = 100,
  itemHeight = 44,
  customVirtualState,
  paginationMode = 'client',
  pageSize = 10,
  page = 1,
  totalPages: totalPagesProp,
  totalCount,
  onPageChange,
  sortKey,
  sortDirection,
  onSort,
  selectionMode = 'none',
  selectedRows = [],
  onSelect,
  onSelectAll,
  loading = false,
  emptyMessage = 'No data available',
  className,
}: TableProps<T>) => {
  const [internalPage, setInternalPage] = useState(page);
  const [internalSortKey, setInternalSortKey] = useState(sortKey);
  const [internalSortDir, setInternalSortDir] = useState<SortDirection>(sortDirection || 'asc');
  const [internalSelected, setInternalSelected] = useState<string[]>(selectedRows);

  const shouldVirtualize = virtualize && customVirtualState !== undefined;
  const virtualItems = customVirtualState?.virtualItems || [];
  const totalHeight = customVirtualState?.totalHeight || 0;
  const offsetY = customVirtualState?.offsetY || 0;

  const processedData = useMemo(() => {
    let result = [...data];
    if (internalSortKey && onSort) {
      result = sort(result, internalSortKey, internalSortDir);
    }
    return result;
  }, [data, internalSortKey, internalSortDir, onSort]);

  const paginationResult = useMemo(() => {
    if (paginationMode === 'server') {
      return {
        data: processedData,
        pageInfo: {
          page,
          pageSize,
          totalItems: totalCount || 0,
          totalPages: totalPagesProp || 0,
          startIndex: 0,
          endIndex: processedData.length,
          hasNextPage: page < (totalPagesProp || 0),
          hasPrevPage: page > 1,
        },
      };
    }
    return getPageData(processedData, internalPage, pageSize);
  }, [processedData, paginationMode, page, pageSize, internalPage, totalPagesProp, totalCount]);

  const { data: displayData, pageInfo } = paginationResult;
  const pageNumbers = getPageNumbers(pageInfo.page, pageInfo.totalPages);

  const handleSort = useCallback((column: TableColumn) => {
    if (!column.sortable) return;
    const newDir = internalSortKey === column.key
      ? (internalSortDir === 'asc' ? 'desc' : 'asc')
      : 'asc';
    setInternalSortKey(column.key);
    setInternalSortDir(newDir);
    onSort?.(column.key, newDir);
  }, [internalSortKey, internalSortDir, onSort]);

  const handleSelect = useCallback((row: T) => {
    const key = String(row[rowKey]);
    let newSelected: string[];
    if (selectionMode === 'single') {
      newSelected = internalSelected.includes(key) ? [] : [key];
    } else {
      newSelected = internalSelected.includes(key)
        ? internalSelected.filter(k => k !== key)
        : [...internalSelected, key];
    }
    setInternalSelected(newSelected);
    onSelect?.(newSelected);
  }, [internalSelected, onSelect, selectionMode, rowKey]);

  const handleSelectAll = useCallback(() => {
    const allKeys = displayData.map(row => String(row[rowKey]));
    const newSelected = internalSelected.length === displayData.length
      ? []
      : allKeys;
    setInternalSelected(newSelected);
    onSelectAll?.(newSelected.length > 0);
  }, [displayData, internalSelected, onSelectAll, rowKey]);

  const isStriped = variant === 'striped';
  const isBordered = variant === 'bordered';
  const isCompact = variant === 'compact';

  const wrapperClasses = [
    'w-full overflow-hidden rounded-[var(--radius-md)] border',
    isBordered ? 'border-[var(--color-border)]' : 'border-transparent',
    className,
  ].filter(Boolean).join(' ');

  const tableClasses = [
    'w-full border-collapse',
    loading && 'opacity-50 pointer-events-none',
  ].filter(Boolean).join(' ');

  const renderRows = () => {
    return displayData.map((row, idx) => {
      const key = String(row[rowKey]);
      const isSelected = internalSelected.includes(key);

      return (
        <tr
          key={key}
          className={[
            'transition-colors',
            isStriped && idx % 2 === 1 ? 'bg-[var(--color-muted)]' : '',
            !isStriped && !isCompact ? 'hover:bg-[var(--color-secondary)]' : '',
            isSelected ? 'bg-[var(--color-primary)]/10' : '',
          ].filter(Boolean).join(' ')}
        >
          {selectionMode !== 'none' && (
            <td className="px-4 py-2">
              <input
                type="checkbox"
                checked={isSelected}
                onChange={() => handleSelect(row)}
                className="rounded border-[var(--color-border)]"
              />
            </td>
          )}
          {columns.map(col => (
            <td
              key={col.key}
              className={[
                'px-4',
                sizeClasses[size],
                alignClasses[col.align || 'left'],
                isBordered ? 'border border-[var(--color-border)]' : '',
              ].filter(Boolean).join(' ')}
              style={col.width ? { width: col.width } : undefined}
            >
              {String(row[col.key] ?? '')}
            </td>
          ))}
        </tr>
      );
    });
  };

  const headerCellClasses = (col: TableColumn) => [
    'px-4 py-3 font-semibold text-left',
    sizeClasses[size],
    alignClasses[col.align || 'left'],
    col.sortable ? 'cursor-pointer select-none hover:bg-[var(--color-secondary)]' : '',
    isBordered ? 'border border-[var(--color-border)]' : '',
  ].filter(Boolean).join(' ');

  return (
    <div className={wrapperClasses}>
      <div className="overflow-auto">
        <table className={tableClasses} role="grid">
          <thead className="bg-[var(--color-surface)]">
            <tr className="border-b border-[var(--color-border)]">
              {selectionMode !== 'none' && (
                <th className="px-4 py-3">
                  <input
                    type="checkbox"
                    checked={internalSelected.length === displayData.length && displayData.length > 0}
                    onChange={handleSelectAll}
                    className="rounded border-[var(--color-border)]"
                  />
                </th>
              )}
              {columns.map(col => (
                <th
                  key={col.key}
                  className={headerCellClasses(col)}
                  style={col.width ? { width: col.width } : undefined}
                  onClick={() => handleSort(col)}
                  role={col.sortable ? 'columnheader' : undefined}
                  aria-sort={internalSortKey === col.key ? (internalSortDir === 'asc' ? 'ascending' : 'descending') : undefined}
                >
                  {col.label}
                  {col.sortable && internalSortKey === col.key && (
                    <span className="ml-1">{internalSortDir === 'asc' ? '↑' : '↓'}</span>
                  )}
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {displayData.length === 0 && !loading ? (
              <tr>
                <td colSpan={columns.length + (selectionMode !== 'none' ? 1 : 0)} className="px-4 py-8 text-center text-[var(--color-text-muted)]">
                  {emptyMessage}
                </td>
              </tr>
            ) : (
              renderRows()
            )}
          </tbody>
        </table>
      </div>

      {paginationMode === 'client' && pageInfo.totalPages > 1 && (
        <div className="flex items-center justify-between px-4 py-3 border-t border-[var(--color-border)] bg-[var(--color-surface)]">
          <div className="text-sm text-[var(--color-text-muted)]">
            Showing {pageInfo.startIndex + 1} to {pageInfo.endIndex} of {pageInfo.totalItems} results
          </div>
          <div className="flex items-center gap-1">
            <button
              onClick={() => {
                const newPage = internalPage - 1;
                setInternalPage(newPage);
                onPageChange?.(newPage, pageSize);
              }}
              disabled={!pageInfo.hasPrevPage}
              className="px-3 py-1 text-sm rounded border border-[var(--color-border)] disabled:opacity-50 disabled:cursor-not-allowed"
            >
              Previous
            </button>
            {pageNumbers.map(p => (
              <button
                key={p}
                onClick={() => {
                  setInternalPage(p);
                  onPageChange?.(p, pageSize);
                }}
                className={[
                  'px-3 py-1 text-sm rounded border',
                  p === internalPage
                    ? 'bg-[var(--color-primary)] text-[var(--color-primary-foreground)]'
                    : 'border-[var(--color-border)] hover:bg-[var(--color-secondary)]',
                ].filter(Boolean).join(' ')}
              >
                {p}
              </button>
            ))}
            <button
              onClick={() => {
                const newPage = internalPage + 1;
                setInternalPage(newPage);
                onPageChange?.(newPage, pageSize);
              }}
              disabled={!pageInfo.hasNextPage}
              className="px-3 py-1 text-sm rounded border border-[var(--color-border)] disabled:opacity-50 disabled:cursor-not-allowed"
            >
              Next
            </button>
          </div>
        </div>
      )}
    </div>
  );
};

TableRoot.displayName = 'Table';

export const Table = Object.assign(TableRoot, {
  displayName: 'Table',
});",
  "virtualization-adapters-guide.md": "# Virtualization Adapters Guide

Generated by Crucible v1.0.0 | Theme: soft | Framework: react

This guide explains how to integrate external virtualization libraries with the Table component using the \`customVirtualState\` escape hatch.

---

## Overview

The Table component includes a **headless virtualization system** based on \`HeadlessVirtualizer\` - a framework-agnostic class that provides basic virtual scrolling without any UI dependencies. This allows:

1. **Zero-dependency** out-of-the-box virtualization
2. **Easy migration** to feature-rich libraries when needed
3. **Plug-and-play** integration with any virtualization library

---

## React Integration

### Using TanStack Virtual

TanStack Virtual (formerly react-virtual) is the most popular virtualization library for React. Here's how to integrate it:

\`\`\`tsx
import { useVirtualizer } from '@tanstack/react-virtual';
import { Table } from './Table';
import type { VirtualState } from './utils/virtualizer';

interface YourComponentProps {
  data: YourDataType[];
  columns: TableColumn<YourDataType>[];
}

export function YourComponent({ data, columns }: YourComponentProps) {
  const parentRef = useRef<HTMLDivElement>(null);

  const rowVirtualizer = useVirtualizer({
    count: data.length,
    getScrollElement: () => parentRef.current,
    estimateSize: () => 44,
    overscan: 5,
  });

  // Map TanStack Virtual state to our VirtualState interface
  const customVirtualState: VirtualState = {
    startIndex: rowVirtualizer.options.startIndex ?? 0,
    endIndex: rowVirtualizer.options.startIndex ?? 0 + (rowVirtualizer.getVirtualItems().length - 1),
    totalHeight: rowVirtualizer.getTotalSize(),
    offsetY: rowVirtualizer.getVirtualItems()[0]?.start ?? 0,
    virtualItems: rowVirtualizer.getVirtualItems().map((item) => ({
      index: item.index,
      start: item.start,
    })),
  };

  return (
    <Table
      columns={columns}
      data={data}
      rowKey="id"
      virtualize={true}
      customVirtualState={customVirtualState}
    />
  );
}
\`\`\`

### Using react-virtual (Alternative)

\`\`\`tsx
import { useVirtual } from 'react-virtual';
import { Table } from './Table';
import type { VirtualState } from './utils/virtualizer';

export function YourComponent({ data, columns }) {
  const parentRef = useRef(null);

  const rowVirtualizer = useVirtual({
    size: data.length,
    parentRef,
    estimateSize: () => 44,
    overscan: 5,
  });

  const customVirtualState: VirtualState = {
    startIndex: rowVirtualizer.startIndex,
    endIndex: rowVirtualizer.endIndex,
    totalHeight: rowVirtualizer.totalSize,
    offsetY: rowVirtualizer.offsetStart,
    virtualItems: rowVirtualizer.virtualItems.map((item) => ({
      index: item.index,
      start: item.start,
    })),
  };

  return (
    <Table
      columns={columns}
      data={data}
      rowKey="id"
      virtualize={true}
      customVirtualState={customVirtualState}
    />
  );
}
\`\`\`

### Custom VirtualState from Scratch

You can also create your own virtualization logic:

\`\`\`tsx
import { Table } from './Table';
import type { VirtualState } from './utils/virtualizer';

function useMyCustomVirtualizer(data: any[], containerRef: React.RefObject) {
  const [virtualState, setVirtualState] = useState<VirtualState>({
    startIndex: 0,
    endIndex: 0,
    totalHeight: data.length * 44,
    offsetY: 0,
    virtualItems: [],
  });

  // Your custom virtualization logic here
  // Update virtualState based on scroll position

  return virtualState;
}

export function YourComponent({ data, columns }) {
  const containerRef = useRef(null);
  const virtualState = useMyCustomVirtualizer(data, containerRef);

  return (
    <Table
      columns={columns}
      data={data}
      rowKey="id"
      virtualize={true}
      customVirtualState={virtualState}
    />
  );
}
\`\`\`

---

## API Reference

### VirtualState Interface

\`\`\`typescript
export interface VirtualState {
  startIndex: number;      // First visible item index
  endIndex: number;       // Last visible item index
  totalHeight: number;    // Total scrollable height
  offsetY: number;        // Y offset for positioning
  virtualItems: {         // Array of visible items
    index: number;        // Item index in data array
    start: number;        // Y position of item
  }[];
}
\`\`\`

### Table Props for Virtualization

| Prop | Type | Description |
|------|------|-------------|
| \`virtualize\` | \`boolean\` | Enable virtualization |
| \`virtualizationThreshold\` | \`number\` | Min items before virtualizing (default: 100) |
| \`itemHeight\` | \`number\` | Height of each row in pixels (default: 44) |
| \`customVirtualState\` | \`VirtualState\` | External virtualization state |

---

## Migration from HeadlessVirtualizer

If you started with the built-in \`HeadlessVirtualizer\` and need more features:

1. **Install TanStack Virtual**: \`npm install @tanstack/react-virtual\`
2. **Create the virtualizer** with your container ref
3. **Map the state** to \`VirtualState\` interface
4. **Pass to Table** via \`customVirtualState\` prop
5. **Remove** \`virtualize\`, \`itemHeight\`, \`virtualizationThreshold\` props (or keep for fallback)

The DOM structure stays the same - only the state source changes!




---

## Common Issues & Solutions

### 1. Row Height Mismatch

**Problem**: Rows don't align with virtual positions.

**Solution**: Ensure \`itemHeight\` in your adapter matches actual row height:
\`\`\`typescript
// Match the actual CSS row height
const itemHeight = 44; // Check your CSS!
\`\`\`

### 2. Scroll Position Reset

**Problem**: Scroll position jumps when switching virtualizers.

**Solution**: Sync scroll positions before switching:
\`\`\`typescript
const scrollTop = containerRef.current?.scrollTop ?? 0;
// Set external virtualizer to same position
externalVirtualizer.scrollTo(scrollTop);
\`\`\`

### 3. Empty or Missing Rows

**Problem**: Some rows don't render.

**Solution**: Check \`virtualItems\` mapping:
\`\`\`typescript
// Ensure index maps correctly
virtualItems: rowVirtualizer.getVirtualItems().map(item => ({
  index: item.index,  // This should match data array index
  start: item.start,
}))
\`\`\`

---

## Performance Tips

1. **Memoize VirtualState**: Use \`useMemo\` (React) / \`computed\` (Vue) / \`computed\` (Angular)
2. **Debounce Scroll Handlers**: Avoid excessive state updates
3. **Use Overscan**: Render extra items to prevent blank areas during fast scroll
4. **Profile with DevTools**: Check FPS during scroll to ensure 60fps

---

## Related Files

- \`utils/virtualizer.ts\` - HeadlessVirtualizer implementation
- \`utils/table-sorter.ts\` - Sorting utilities
- \`utils/table-paginator.ts\` - Pagination utilities

---

_This guide is auto-generated. Edit the source template or run \`crucible upgrade\` after updating your config._",
}
`;

