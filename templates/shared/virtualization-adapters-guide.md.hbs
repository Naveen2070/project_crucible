{{#if (eq framework 'react')}}
## React Integration

### Using TanStack Virtual

TanStack Virtual (formerly react-virtual) is the most popular virtualization library for React. Here's how to integrate it:

```tsx
import { useVirtualizer } from '@tanstack/react-virtual';
import { Table } from './Table';
import type { VirtualState } from './utils/virtualizer';

interface YourComponentProps {
  data: YourDataType[];
  columns: TableColumn<YourDataType>[];
}

export function YourComponent({ data, columns }: YourComponentProps) {
  const parentRef = useRef<HTMLDivElement>(null);

  const rowVirtualizer = useVirtualizer({
    count: data.length,
    getScrollElement: () => parentRef.current,
    estimateSize: () => 44,
    overscan: 5,
  });

  // Map TanStack Virtual state to our VirtualState interface
  const customVirtualState: VirtualState = {
    startIndex: rowVirtualizer.options.startIndex ?? 0,
    endIndex: rowVirtualizer.options.startIndex ?? 0 + (rowVirtualizer.getVirtualItems().length - 1),
    totalHeight: rowVirtualizer.getTotalSize(),
    offsetY: rowVirtualizer.getVirtualItems()[0]?.start ?? 0,
    virtualItems: rowVirtualizer.getVirtualItems().map((item) => ({
      index: item.index,
      start: item.start,
    })),
  };

  return (
    <Table
      columns={columns}
      data={data}
      rowKey="id"
      virtualize={true}
      customVirtualState={customVirtualState}
    />
  );
}
```

