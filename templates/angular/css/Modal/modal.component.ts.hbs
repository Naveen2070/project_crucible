import { Component, Input, Output, EventEmitter } from '@angular/core';

@Component({
  selector: 'app-modal',
  templateUrl: './modal.component.html',
  styleUrls: ['./modal.component.{{#if (eq styleSystem "scss")}}scss{{else}}css{{/if}}']
})
export class ModalComponent {
  @Input() isOpen = false;
  @Input() title = '';
  @Input() variant: {{> shared/variant-types}} = 'default';
  @Input() size:    {{> shared/size-types}} = 'md';
  
  @Output() close = new EventEmitter<void>();

  titleId = 'modal-title-' + Math.random().toString(36).substring(2, 9);

  onClose() {
    this.close.emit();
  }

  get modalClasses(): string {
    return [
      'modal',
      `modal--${this.size}`,
      `modal--${this.variant}`
    ].filter(Boolean).join(' ');
  }
}
