    }

    &--sm { padding: 6px 10px;  font-size: 13px; }
    &--md { padding: 10px 14px; font-size: 15px; }
    &--lg { padding: 14px 18px; font-size: 17px; }
  }

  &--error .input {
    border-color: var(--color-destructive);
  }

  &--disabled .input {
    background: var(--color-background);
    cursor:     not-allowed;
    opacity:    0.7;
  }

  .password-toggle {
    position:   absolute;
    right:      12px;
    top:        50%;
    transform:  translateY(-50%);
    background: transparent;
    border:     none;
    padding:    0;
    margin:     0;
    font-family: var(--font-family);
    font-size:  12px;
    color:      var(--color-text-muted);
    cursor:     pointer;

    &:hover {
      color: var(--color-text);
    }
  }

  .error {
    color:       var(--color-destructive);
    font-family: var(--font-family);
    font-size:   12px;
    margin-top:  2px;
  }
}
