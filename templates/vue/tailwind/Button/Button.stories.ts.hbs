import type { Meta, StoryObj } from '@storybook/vue3';
import Button from './Button.vue';

const meta: Meta<typeof Button> = {
  title: 'Crucible/{{name}}',
  component: Button,
  argTypes: {
    variant:  { control: 'select', options: [{{#each variants}}'{{this}}'{{#unless @last}}, {{/unless}}{{/each}}] },
    size:     { control: 'select', options: [{{#each sizes}}'{{this}}'{{#unless @last}}, {{/unless}}{{/each}}] },
    loading:  { control: 'boolean' },
    disabled: { control: 'boolean' },
  },
};

export default meta;
type Story = StoryObj<typeof Button>;

{{#each variants}}
export const {{capitalize this}}: Story = {
  args: { variant: '{{this}}' },
  render: (args) => ({
    components: { Button },
    setup() { return { args }; },
    template: `<Button v-bind="args">{{capitalize this}}</Button>`,
  }),
};
{{/each}}

{{#if features.compoundComponents}}
export const WithSlots: Story = {
  args: { variant: 'primary' },
  render: (args) => ({
    components: { Button },
    setup() { return { args }; },
    template: `
<Button v-bind="args">
  <template #icon><span>🔥</span></template>
  With Custom Icon
</Button>`,
  }),
};

export const LoadingSlot: Story = {
  args: { variant: 'primary', loading: true },
  render: (args) => ({
    components: { Button },
    setup() { return { args }; },
    template: `
<Button v-bind="args">
  <template #spinner><span>⏳</span></template>
  Custom Spinner
</Button>`,
  }),
};
{{/if}}
