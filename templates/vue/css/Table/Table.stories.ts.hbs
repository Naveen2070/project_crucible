import type { Meta, StoryObj } from '@storybook/vue';
import { ref } from 'vue';
import Table from './Table.vue';

const meta: Meta<typeof Table> = {
  title: 'Crucible/Table',
  component: Table,
  parameters: { layout: 'fullscreen' },
  argTypes: {
    variant: { control: 'select', options: ['default', 'striped', 'bordered', 'compact'] },
    size: { control: 'select', options: ['sm', 'md', 'lg'] },
    virtualize: { control: 'boolean' },
    paginationMode: { control: 'select', options: ['client', 'server'] },
    selectionMode: { control: 'select', options: ['none', 'single', 'multiple'] },
  },
};

export default meta;
type Story = StoryObj<typeof Table>;

const columns = [
  { key: 'id', label: 'ID', sortable: true, width: '60px' },
  { key: 'name', label: 'Name', sortable: true },
  { key: 'email', label: 'Email', sortable: true },
  { key: 'role', label: 'Role', sortable: true },
  { key: 'status', label: 'Status' },
];

const generateData = (count: number) =>
  Array.from({ length: count }, (_, i) => ({
    id: i + 1,
    name: `User ${i + 1}`,
    email: `user${i + 1}@example.com`,
    role: i % 3 === 0 ? 'Admin' : i % 2 === 0 ? 'Editor' : 'Viewer',
    status: i % 4 === 0 ? 'Inactive' : 'Active',
  }));

export const Default: Story = {
  args: {
    columns,
    data: generateData(20),
    rowKey: 'id',
  },
};

export const Striped: Story = {
  args: {
    columns,
    data: generateData(20),
    rowKey: 'id',
    variant: 'striped',
  },
};

export const Bordered: Story = {
  args: {
    columns,
    data: generateData(20),
    rowKey: 'id',
    variant: 'bordered',
  },
};

export const Compact: Story = {
  args: {
    columns,
    data: generateData(20),
    rowKey: 'id',
    variant: 'compact',
  },
};

export const WithPagination: Story = {
  args: {
    columns,
    data: generateData(50),
    rowKey: 'id',
    paginationMode: 'client',
    pageSize: 10,
  },
};

export const WithSorting: Story = {
  args: {
    columns,
    data: generateData(20),
