.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 16px;
}

.modal {
  background: #ffffff;
  border-radius: 16px;
  box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
  max-height: calc(100vh - 64px);
  display: flex;
  flex-direction: column;
  width: 100%;
  animation: modalIn 0.3s ease-out;
}

@keyframes modalIn {
  from { opacity: 0; transform: scale(0.95) translateY(10px); }
  to { opacity: 1; transform: scale(1) translateY(0); }
}

.modal--sm { max-width: 400px; }
.modal--md { max-width: 600px; }
.modal--lg { max-width: 800px; }

.modal-header {
  padding: 16px;
  border-bottom: 1px solid #e2e1f0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.modal-title {
  margin: 0;
  font-size: 1.25rem;
  font-weight: 600;
  color: #1a1a2e;
  font-family: system-ui, -apple-system, sans-serif;
}

.modal-close {
  background: transparent;
  border: none;
  font-size: 1.5rem;
  line-height: 1;
  color: #6b7280;
  cursor: pointer;
  padding: 8px;
  border-radius: 4px;
}

.modal-close:hover {
  background: #f8f9fa;
  color: #1a1a2e;
}

.modal-body {
  padding: 24px;
  overflow-y: auto;
  font-family: system-ui, -apple-system, sans-serif;
  color: #1a1a2e;
  line-height: 1.5;
}

.modal-footer {
  padding: 16px;
  border-top: 1px solid #e2e1f0;
  display: flex;
  justify-content: flex-end;
  gap: 12px;
}

.modal-footer:empty {
  display: none;
}
