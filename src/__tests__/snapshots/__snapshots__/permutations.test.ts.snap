  margin-left: 4px;
}

.tbody {
  transition: background-color 0.2s ease;
}

.row {
  transition: background-color 0.2s ease;

  &-striped:nth-child(odd) {
    background-color: var(--table-striped-bg, var(--color-muted));
  }

  &-hover:hover {
    background-color: var(--table-row-hover-bg, var(--color-secondary));
  }

  &-selected {
    background-color: var(--color-primary-light);
  }
}

.cell {
  padding: var(--table-cell-padding, calc(var(--spacing-unit) * 3));
  border: none;

  &-bordered {
    border: 1px solid var(--color-border);
  }

  &-sm {
