import type { Meta, StoryObj } from '@storybook/react';
import React, { useState } from 'react';
import { Select } from './Select';

const meta: Meta<typeof Select> = {
  title: 'Crucible/{{name}}',
  component: Select,
  parameters: { layout: 'centered' },
  argTypes: {
    variant:  { control: 'select', options: [{{#each variants}}'{{this}}'{{#unless @last}}, {{/unless}}{{/each}}] },
    size:     { control: 'select', options: [{{#each sizes}}'{{this}}'{{#unless @last}}, {{/unless}}{{/each}}] },
    disabled: { control: 'boolean' },
  },
};
export default meta;
type Story = StoryObj<typeof Select>;

{{#if features.compoundComponents}}
export const Default: Story = {
  render: (args) => {
    const [value, setValue] = useState('');
    return (
      <Select {...args} value={value} onChange={setValue}>
        <Select.Label>Country</Select.Label>
        <Select.Trigger>
          <Select.Value placeholder="Choose a country..." />
          <Select.Icon />
        </Select.Trigger>
        <Select.Content>
          <Select.Item value="us" label="United States" />
          <Select.Item value="ca" label="Canada" />
          <Select.Item value="uk" label="United Kingdom" />
          <Select.Item value="au" label="Australia" />
        </Select.Content>
      </Select>
    );
  },
};
{{else}}
const options = [
  { value: 'us', label: 'United States' },
  { value: 'ca', label: 'Canada' },
  { value: 'uk', label: 'United Kingdom' },
  { value: 'au', label: 'Australia' },
];

export const Default: Story = {
  args: {
    label: 'Country',
    options,
    placeholder: 'Choose a country...',
  },
};

export const Disabled: Story = {
  args: {
    label: 'Country',
    options,
    disabled: true,
    value: 'us',
  },
};

export const Error: Story = {
  args: {
    label: 'Country',
    options,
    error: 'Please select a valid country',
  },
};
{{/if}}
