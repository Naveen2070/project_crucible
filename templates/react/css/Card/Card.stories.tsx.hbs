{{> react/stories-header}}
  argTypes: {
    variant: { control: 'select', options: {{> shared/variant-options}} },
    size:    { control: 'select', options: {{> shared/size-options}} },
  },
{{> react/stories-footer}}

{{#if features.compoundComponents}}
export const Default: Story = {
  render: (args) => (
    <Card {...args}>
      <Card.Header>
        <h3 style=\{{ margin: 0 }}>Card Title</h3>
      </Card.Header>
      <Card.Content>
        This is a default card with some content inside it.
      </Card.Content>
    </Card>
  ),
};

export const Hoverable: Story = {
  args: { variant: 'hoverable' },
  render: (args) => (
    <Card {...args}>
      <Card.Header>
        <h3 style=\{{ margin: 0 }}>Hoverable Card</h3>
      </Card.Header>
      <Card.Content>
        This card changes its border color and shadow on hover.
      </Card.Content>
    </Card>
  ),
};

export const Clickable: Story = {
  args: { 
    variant: 'clickable',
    onClick: () => alert('Card clicked!'),
  },
  render: (args) => (
    <Card {...args}>
      <Card.Header>
        <h3 style=\{{ margin: 0 }}>Clickable Card</h3>
      </Card.Header>
      <Card.Content>
        This card acts like a button and has an active state.
      </Card.Content>
    </Card>
  ),
};

export const Link: Story = {
  args: { 
    variant: 'clickable',
    href: 'https://example.com',
  },
  render: (args) => (
    <Card {...args}>
      <Card.Header>
        <h3 style=\{{ margin: 0 }}>Link Card</h3>
      </Card.Header>
      <Card.Content>
        This card acts like an anchor tag.
      </Card.Content>
    </Card>
  ),
};
{{else}}
export const Default: Story = {
  args: {
    title:    'Card Title',
    children: 'This is a default card with some content inside it.',
  },
};

export const Hoverable: Story = {
  args: {
    variant:  'hoverable',
    title:    'Hoverable Card',
    children: 'This card changes its border color and shadow on hover.',
  },
};

export const Clickable: Story = {
  args: {
    variant:  'clickable',
    title:    'Clickable Card',
    children: 'This card acts like a button and has an active state.',
    onClick:  () => alert('Card clicked!'),
  },
};

export const Link: Story = {
  args: {
    variant:  'clickable',
    title:    'Link Card',
    children: 'This card acts like an anchor tag.',
    href:     'https://example.com',
  },
};
{{/if}}
