.tableWrapper {
  width: 100%;
  overflow: hidden;
  border-radius: var(--table-border-radius, var(--radius-md));
  border: 1px solid var(--color-border);

  &Bordered {
    border: 1px solid var(--color-border);
  }
}

.tableContainer {
  overflow: auto;
}

.tableContainerVirtual {
  overflow: auto;
}

.table {
  width: 100%;
  border-collapse: collapse;
}

.tableLoading {
  opacity: 0.5;
  pointer-events: none;
}

.thead {
  background-color: var(--color-surface);
  position: sticky;
  top: 0;
  z-index: 10;
}

.headerRow {
  border-bottom: 1px solid var(--color-border);
}

.headerCell {
  padding: var(--table-cell-padding, calc(var(--spacing-unit) * 3));
  font-weight: 600;
  text-align: left;
  cursor: pointer;
  user-select: none;

  &-sortable:hover {
    background-color: var(--color-secondary);
  }

  &-center {
    text-align: center;
  }

  &-right {
    text-align: right;
  }
}

.sortIcon {
  margin-left: 4px;
}

.tbody {
  transition: background-color 0.2s ease;
}

.row {
  transition: background-color 0.2s ease;
  background-color: transparent;

  &-striped {
    background-color: #F8F9FA !important;
  }

  &-compact {
    height: auto !important;
    padding: 0 !important;
  }

  &-compact td {
    padding: calc(var(--spacing-unit) * 1.5) !important;
    font-size: 0.875rem !important;
  }

  &-hover:hover {
    background-color: var(--table-row-hover-bg, var(--color-secondary));
  }

  &-selected {
    background-color: var(--color-primary-light);
  }
}

.cell {
  padding: var(--table-cell-padding, calc(var(--spacing-unit) * 3));
  border: none;

  &-bordered {
    border: 1px solid var(--color-border);
  }

  &-compact {
    padding: calc(var(--spacing-unit) * 1.5) !important;
    font-size: 0.875rem !important;
  }

  &-sm {
    padding: calc(var(--spacing-unit) * 2);
    font-size: 0.875rem;
  }

  &-md {
    padding: calc(var(--spacing-unit) * 3);
    font-size: 1rem;
  }

  &-lg {
    padding: calc(var(--spacing-unit) * 4);
    font-size: 1.125rem;
  }

  &-left {
    text-align: left;
  }

  &-center {
    text-align: center;
  }

  &-right {
    text-align: right;
  }
}

.checkbox {
  border-radius: 2px;
  border-color: var(--color-border);
}

.emptyRow {
  padding: calc(var(--spacing-unit) * 8);
  text-align: center;
  color: var(--color-text-muted);
}

.virtualSpacer {
  position: relative;
}

.pagination {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(var(--spacing-unit) * 3) calc(var(--spacing-unit) * 4);
  border-top: 1px solid var(--color-border);
  background-color: var(--color-surface);

  &Info {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  &Buttons {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  &Btn {
    padding: calc(var(--spacing-unit) * 1) calc(var(--spacing-unit) * 3);
    font-size: 0.875rem;
    border-radius: 4px;
    border: 1px solid var(--color-border);
    background: transparent;
    cursor: pointer;
    transition: all 0.2s ease;

    &:hover:not(:disabled) {
      background-color: var(--color-secondary);
    }

    &:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    &Active {
      background-color: var(--color-primary);
      color: var(--color-primary-foreground);
      border-color: var(--color-primary);
    }
  }
}