import { Component, Input } from '@angular/core';

@Component({
  selector: 'app-button',
  templateUrl: './button.component.html',
  styleUrls: ['./button.component.{{#if (eq styleSystem "scss")}}scss{{else}}css{{/if}}']
})
export class ButtonComponent {
  @Input() variant: {{#each variants}}'{{this}}'{{#unless @last}} | {{/unless}}{{/each}} = 'primary';
  @Input() size:    {{#each sizes}}'{{this}}'{{#unless @last}} | {{/unless}}{{/each}} = 'md';
  @Input() loading = false;
  @Input() disabled = false;
  @Input() className = '';

  get classes(): string {
    return [
      'btn',
      `btn--${this.variant}`,
      `btn--${this.size}`,
      this.loading ? 'btn--loading' : '',
      this.disabled ? 'btn--disabled' : '',
      this.className
    ].filter(Boolean).join(' ');
  }
}
