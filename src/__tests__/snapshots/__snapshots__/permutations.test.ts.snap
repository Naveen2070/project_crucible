  "Select.module.css": "/* Generated by Crucible — edit freely, re-generate with --force */

.select-container, .container {
  display:        flex;
  flex-direction: column;
  gap:            var(--spacing-unit);
  width:          100%;
  position:       relative;
}

.select-wrapper {
  position:       relative;
  display:        flex;
  align-items:    center;
  width:          100%;
}

.select-label, .label {
  font-family: var(--font-family);
  font-size:   14px;
  font-weight: 500;
  color:       var(--color-text);
}

.select-combobox, .combobox {
  --select-height: calc(var(--spacing-unit) * 10);
  --select-padding-x: calc(var(--spacing-unit) * 3);
  --select-radius: var(--radius-md);

  display:         flex;
  align-items:     center;
  justify-content: space-between;
  background:      var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius:   var(--select-radius);
  cursor:          pointer;
  font-family:     var(--font-family);
  color:           var(--color-text);
  transition:      border-color 0.15s ease, box-shadow 0.15s ease;
  width:           100%;
  min-height:      var(--select-height);
  padding:         0 var(--select-padding-x);
  box-sizing:      border-box;
}

.select-combobox--open, .combobox--open {
  border-color: var(--color-primary);
  border-bottom-left-radius: 0;
  border-bottom-right-radius: 0;
}

.select-combobox:focus-visible, .combobox:focus-visible {
  outline: none;
  border-color: var(--color-primary);
  box-shadow: 0 0 0 2px var(--color-background), 0 0 0 4px var(--color-primary);
}

.select-combobox--disabled, .combobox--disabled {
  background: var(--color-background);
  cursor:     not-allowed;
  opacity:    0.7;
}

.select-combobox--error, .combobox--error {
  border-color: var(--color-destructive);
}

.select-value, .value {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.select-arrow, .arrow {
  margin-left: calc(var(--spacing-unit) * 2);
  font-size:   0.8em;
  color:       var(--color-text-muted);
}

.select-listbox, .listbox {
  --select-dropdown-shadow: 0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -2px rgba(0,0,0,0.05);

  position:      absolute;
  top:           100%;
  left:          0;
  right:         0;
  background:    var(--color-surface);
  border: 1px solid var(--color-primary);
  border-top:    none;
  border-radius: 0 0 var(--select-radius) var(--select-radius);
  list-style:    none;
  margin:        0;
  padding:       0;
  z-index:       900;
  max-height:    200px;
  overflow-y:    auto;
  box-shadow:    var(--select-dropdown-shadow);
}

.select-option, .option {
  --select-option-padding: calc(var(--spacing-unit) * 2.5);
  padding:     var(--select-option-padding) var(--select-padding-x);
  cursor:      pointer;
  font-family: var(--font-family);
  font-size:   14px;
  color:       var(--color-text);
  transition:  background 0.15s ease;
}

.select-option--active, .option--active {
  background: var(--color-secondary);
  color:      var(--color-primary);
}

.select-option--selected, .option--selected {
  font-weight: 600;
  background:  var(--color-secondary);
  color:       var(--color-primary);
}

.select-error, .error {
  color:       var(--color-destructive);
  font-family: var(--font-family);
  font-size:   12px;
  margin-top:  2px;
}

/* Group and Indicator */
.select-group, .select-group-label {
  padding:     0.5rem var(--select-padding-x);
  font-size:   0.75rem;
  font-weight: 600;
  color:       var(--color-text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.item-indicator {
  width:      1.25rem;
  height:     1.25rem;
  display:    flex;
  align-items: center;
  justify-content: center;
  color:       var(--color-primary);
}

/* Sizes */
.select-combobox--sm, .combobox--sm { min-height: var(--select-height); font-size: 13px; }
.select-combobox--md, .combobox--md { min-height: var(--select-height); font-size: 15px; }
.select-combobox--lg, .combobox--lg { min-height: var(--select-height); font-size: 17px; }
",
  "Select.tsx": "import React, { useState, useRef, useEffect, useId, createContext, useContext } from 'react';
import styles from './Select.module.css';
export interface SelectOption {
  value: string;
  label: string;
}

export type SelectVariant = 'default' | 'error';
export type SelectSize    = 'sm' | 'md' | 'lg';

export interface SelectProps {
  options?:  SelectOption[];
  value?:    string;
  onChange?: (value: string) => void;
  label?:    string;
  placeholder?: string;
  variant?:  SelectVariant;
  size?:     SelectSize;
  error?:    string;
  disabled?: boolean;
  children?: React.ReactNode;
}

interface SelectContextValue {
  isOpen: boolean;
  setIsOpen: (open: boolean) => void;
  value?: string;
  onChange?: (value: string) => void;
  activeIndex: number;
  setActiveIndex: (index: number | ((prev: number) => number)) => void;
  id: string;
  labelId: string;
  listboxId: string;
  size: SelectSize;
  variant?: SelectVariant;
  error?: string;
  disabled?: boolean;
  options: SelectOption[];
  setOptions: React.Dispatch<React.SetStateAction<SelectOption[]>>;
}

const SelectContext = createContext<SelectContextValue | undefined>(undefined);

const useSelectContext = () => {
  const context = useContext(SelectContext);
  if (!context) throw new Error('Select sub-components must be used within Select');
  return context;
};

export const SelectRoot = ({
  children,
  value,
  onChange,
  variant = 'default',
  size = 'md',
  error,
  disabled,
}: SelectProps) => {
  const [isOpen, setIsOpen] = useState(false);
  const [activeIndex, setActiveIndex] = useState(-1);
  const [options, setOptions] = useState<SelectOption[]>([]);
  const containerRef = useRef<HTMLDivElement>(null);
  const id = useId();
  const labelId = \`\${id}-label\`;
  const listboxId = \`\${id}-listbox\`;

  useEffect(() => {
    const handleClickOutside = (e: MouseEvent) => {
      if (containerRef.current && !containerRef.current.contains(e.target as Node)) {
        setIsOpen(false);
      }
    };
    document.addEventListener('mousedown', handleClickOutside);
    return () => document.removeEventListener('mousedown', handleClickOutside);
  }, []);

  return (
    <SelectContext.Provider value={{
      isOpen, setIsOpen, value, onChange, activeIndex, setActiveIndex,
      id, labelId, listboxId, size, variant, error, disabled, options, setOptions
    }}>
      <div className={styles.container} ref={containerRef}>
        {children}
      </div>
    </SelectContext.Provider>
  );
};

export const SelectTrigger = ({ children, className }: { children: React.ReactNode; className?: string }) => {
  const { 
    isOpen, setIsOpen, labelId, listboxId, activeIndex, setActiveIndex, 
    value, options, disabled, id, onChange, size, variant, error
  } = useSelectContext();
  
  const searchString = useRef('');
  const searchTimeout = useRef<ReturnType<typeof setTimeout> | null>(null);

  const handleKeyDown = (e: React.KeyboardEvent) => {
    if (disabled) return;

    // Type-ahead logic
    if (e.key.length === 1 && !e.ctrlKey && !e.metaKey && !e.altKey) {
      searchString.current += e.key.toLowerCase();
      if (searchTimeout.current) clearTimeout(searchTimeout.current);
      searchTimeout.current = setTimeout(() => {
        searchString.current = '';
      }, 500);

      const matchIndex = options.findIndex((opt) =>
        opt.label.toLowerCase().startsWith(searchString.current)
      );

      if (matchIndex >= 0) {
        setActiveIndex(matchIndex);
        if (!isOpen) {
          onChange?.(options[matchIndex].value);
        }
      }
      return;
    }

    if (!isOpen) {
      if (e.key === 'Enter' || e.key === ' ' || e.key === 'ArrowDown' || e.key === 'ArrowUp') {
        e.preventDefault();
        setIsOpen(true);
        const currentIndex = options.findIndex(o => o.value === value);
        setActiveIndex(currentIndex >= 0 ? currentIndex : 0);
      }
      return;
    }

    switch (e.key) {
      case 'ArrowDown':
        e.preventDefault();
        setActiveIndex((prev) => (prev < options.length - 1 ? prev + 1 : prev));
        break;
      case 'ArrowUp':
        e.preventDefault();
        setActiveIndex((prev) => (prev > 0 ? prev - 1 : prev));
        break;
      case 'Enter':
      case ' ':
        e.preventDefault();
        if (activeIndex >= 0) {
          onChange?.(options[activeIndex].value);
          setIsOpen(false);
        }
        break;
      case 'Escape':
        setIsOpen(false);
        break;
      case 'Home':
        e.preventDefault();
        setActiveIndex(0);
        break;
      case 'End':
        e.preventDefault();
        setActiveIndex(options.length - 1);
        break;
    }
  };

  return (
    <div
      className={[
        styles.combobox,
        styles[\`combobox--\${size}\`],
        (error || variant === 'error') && styles['combobox--error'],
        disabled && styles['combobox--disabled'],
        isOpen && styles['combobox--open'],
        className,
      ].join(' ')}
      role="combobox"
      aria-expanded={isOpen}
      aria-haspopup="listbox"
      aria-labelledby={labelId}
      aria-controls={listboxId}
      tabIndex={disabled ? -1 : 0}
      onKeyDown={handleKeyDown}
      onClick={() => !disabled && setIsOpen(!isOpen)}
      aria-activedescendant={activeIndex >= 0 ? \`\${id}-option-\${activeIndex}\` : undefined}
    >
      {children}
    </div>
  );
};

export const SelectValue = ({ placeholder }: { placeholder?: string }) => {
  const { value, options } = useSelectContext();
  const selectedOption = options.find(opt => opt.value === value);
  return (
    <span className={styles.value}>
      {selectedOption ? selectedOption.label : placeholder}
    </span>
  );
};

export const SelectIcon = () => (
  <span className={styles.arrow} aria-hidden="true">▼</span>
);

export const SelectContent = ({ children, className }: { children: React.ReactNode; className?: string }) => {
  const { isOpen, listboxId, labelId } = useSelectContext();
  if (!isOpen) return null;
  return (
    <ul
      id={listboxId}
      className={[styles.listbox, className].join(' ')}
      role="listbox"
      aria-labelledby={labelId}
    >
      {children}
    </ul>
  );
};

export const SelectItem = ({ value: itemValue, label, children }: { value: string; label: string; children?: React.ReactNode }) => {
  const { value, onChange, setIsOpen, options, setOptions, activeIndex, setActiveIndex, id } = useSelectContext();
  
  const index = options.findIndex(opt => opt.value === itemValue);
  
  useEffect(() => {
    setOptions(prev => {
      if (prev.find(opt => opt.value === itemValue)) return prev;
      return [...prev, { value: itemValue, label }];
    });
  }, [itemValue, label, setOptions]);

  return (
    <li
      id={\`\${id}-option-\${index}\`}
      role="option"
      aria-selected={value === itemValue}
      className={[
        styles.option,
        value === itemValue && styles['option--selected'],
        activeIndex === index && styles['option--active'],
      ].join(' ')}
      onClick={(e) => {
        e.stopPropagation();
        onChange?.(itemValue);
        setIsOpen(false);
      }}
      onMouseEnter={() => setActiveIndex(index)}
    >
      {children || label}
    </li>
  );
};

export const SelectItemText = ({ children }: { children: React.ReactNode }) => (
  <>{children}</>
);

export const SelectLabel = ({ children, className }: { children: React.ReactNode; className?: string }) => {
  const { labelId } = useSelectContext();
  return <label id={labelId} className={[styles.label, className].join(' ')}>{children}</label>;
};

export const SelectError = ({ children, className }: { children?: React.ReactNode; className?: string }) => {
  const { error } = useSelectContext();
  if (!error) return null;
  return <span className={[styles.error, className].join(' ')} role="alert">{children || error}</span>;
};

export const SelectGroup = ({ children, className }: { children: React.ReactNode; className?: string }) => (
  <div className={[styles['select-group'], className].join(' ')} role="group">{children}</div>
);

export const SelectItemIndicator = ({ className }: { className?: string }) => (
  <span className={[styles['item-indicator'], className].join(' ')} aria-hidden="true">✓</span>
);

export const Select = Object.assign(SelectRoot, {
  Root: SelectRoot,
  Trigger: SelectTrigger,
  Value: SelectValue,
  Icon: SelectIcon,
  Content: SelectContent,
  Item: SelectItem,
  ItemText: SelectItemText,
  ItemIndicator: SelectItemIndicator,
  Label: SelectLabel,
  Error: SelectError,
  Group: SelectGroup,
});

Select.displayName = 'Select';
SelectRoot.displayName = 'Select.Root';
SelectTrigger.displayName = 'Select.Trigger';
SelectValue.displayName = 'Select.Value';
SelectIcon.displayName = 'Select.Icon';
SelectContent.displayName = 'Select.Content';
SelectItem.displayName = 'Select.Item';
SelectItemText.displayName = 'Select.ItemText';
SelectItemIndicator.displayName = 'Select.ItemIndicator';
SelectError.displayName = 'Select.Error';
SelectLabel.displayName = 'Select.Label';
SelectGroup.displayName = 'Select.Group';
",
}
`;

