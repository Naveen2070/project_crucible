/* Generated by Crucible — edit freely, re-generate with --force */

.input-container {
  display:        flex;
  flex-direction: column;
  gap:            var(--spacing-unit);
  width:          100%;
}

.label {
  font-family: var(--font-family);
  font-size:   0.875rem;
  font-weight: 500;
  color:       var(--color-text);
  margin-bottom: calc(var(--spacing-unit) * 1.5);
}

.required {
  color:       var(--color-danger);
  margin-left: calc(var(--spacing-unit) * 0.5);
}

.input-wrapper {
  position: relative;
  width:    100%;
}

.input {
  width:           100%;
  font-family:     var(--font-family);
  border:          1px solid var(--color-border);
  border-radius:   var(--radius-md);
  background:      var(--color-surface);
  color:           var(--color-text);
  transition:      all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  box-sizing:      border-box;
}

{{#if a11y.focusRing}}
.input:focus-visible {
  outline:        {{a11y.focusRingWidth}} solid {{a11y.focusRingColor}};
  outline-offset: {{a11y.focusRingOffset}};
  border-color:   var(--color-primary);
  box-shadow:     0 0 0 4px rgba(108, 99, 255, 0.1);
}
{{/if}}

/* Sizes */
.input--sm { 
  padding:   calc(var(--spacing-unit) * 1.5) calc(var(--spacing-unit) * 2.5);  
  font-size: 0.875rem; 
}
.input--md { 
  padding:   calc(var(--spacing-unit) * 2.5) calc(var(--spacing-unit) * 3.5); 
  font-size: 1rem; 
}
.input--lg { 
  padding:   calc(var(--spacing-unit) * 3.5) calc(var(--spacing-unit) * 4.5); 
  font-size: 1.125rem; 
}

/* Variants */
.input--error {
  border-color: var(--color-danger);
}

.input--disabled {
  background: var(--color-background);
  cursor:     not-allowed;
  opacity:    0.7;
}

.password-toggle {
  position:   absolute;
  right:      12px;
  top:        50%;
  transform:  translateY(-50%);
  background: transparent;
  border:     none;
  padding:    0;
  margin:     0;
  font-family: var(--font-family);
  font-size:  12px;
  color:      var(--color-text-muted);
  cursor:     pointer;
}

.password-toggle:hover {
  color: var(--color-text);
}

{{#if a11y.focusRing}}
.password-toggle:focus-visible {
  outline:        {{a11y.focusRingWidth}} solid {{a11y.focusRingColor}};
  outline-offset: {{a11y.focusRingOffset}};
  border-radius:  var(--radius-sm);
}
{{/if}}

.hint, .error {
  font-family: var(--font-family);
  font-size:   12px;
  margin-top:  2px;
}

.hint {
  color: var(--color-text-muted);
}

.error {
  color: var(--color-danger);
}
