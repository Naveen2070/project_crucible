  color:          var(--color-text);
  font-family:    var(--font-family);
  overflow:       hidden;
  text-align:     left;
  width:          100%;
  padding:        0;
  margin:         0;
  text-decoration: none;
  box-shadow:     var(--card-shadow);
}

.card:focus-visible {
  outline:        2px solid var(--color-primary);
  outline-offset: 3px;
}

/* Sizes */
.card--sm { max-width: 300px; }
.card--md { max-width: 450px; }
.card--lg { max-width: 600px; }

/* Variants */
.card--hoverable:hover {
  border-color: var(--color-primary);
  box-shadow:   0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
}

.card--clickable {
  cursor: pointer;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.card--clickable:hover {
  border-color: var(--color-primary);
  box-shadow:   0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
  transform:    translateY(-2px);
}

.card--clickable:active {
  transform:    translateY(0);
}

.header, .card-header {
  padding: var(--card-header-padding);
  border-bottom: 1px solid var(--card-border);
}

.title, .card-title {
  margin:      0;
  padding:     var(--card-header-padding);
  font-size:   1.1rem;
  font-weight: 600;
  color:       var(--color-text);
  font-family: var(--font-family);
}

.content, .card-content {
  padding: var(--card-content-padding);
}

.footer, .card-footer {
  padding: var(--card-footer-padding);
  border-top: 1px solid var(--card-border);
}
",
  "Card.tsx": "import React from 'react';
import styles from './Card.module.css';
export type CardVariant = 'default' | 'hoverable' | 'clickable';
export type CardSize    = 'sm' | 'md' | 'lg';

export interface Props {
  variant?:   Variant;
  size?:      Size;
  
  
  
  
  
  title?:    string;
  
  onClick?:  () => void;
  href?:     string;
  
}

export const CardRoot = ({
  variant = 'default',
  size = 'md',
  children,
  onClick,
  className,
  href,
}: CardProps) => {
  const isClickable = variant === 'clickable' || !!onClick || !!href;
  
  const cls = [
    styles.card,
    styles[\`card--\${variant}\`],
    styles[\`card--\${size}\`],
    isClickable && styles['card--clickable'],
    className,
  ].filter(Boolean).join(' ');

  const handleKeyDown = (e: React.KeyboardEvent) => {
    if (isClickable && (e.key === 'Enter' || e.key === ' ')) {
      e.preventDefault();
      onClick?.();
      if (href) window.location.href = href;
    }
  };

  const Component = href ? 'a' : isClickable ? 'button' : 'article';

  return (
    <Component
      className={cls}
      onClick={onClick}
      href={href}
      role={href ? undefined : isClickable ? 'button' : 'article'}
      tabIndex={isClickable ? 0 : undefined}
      onKeyDown={isClickable ? handleKeyDown : undefined}
    >
      {children}
    </Component>
  );
};

export const CardHeader = ({ children, className }: { children: React.ReactNode; className?: string }) => (
  <div className={[styles.header, className].filter(Boolean).join(' ')}>{children}</div>
);

export const CardTitle = ({ children, className }: { children: React.ReactNode; className?: string }) => (
  <h3 className={[styles.title, className].filter(Boolean).join(' ')}>{children}</h3>
);

export const CardContent = ({ children, className }: { children: React.ReactNode; className?: string }) => (
  <div className={[styles.content, className].filter(Boolean).join(' ')}>{children}</div>
);

export const CardFooter = ({ children, className }: { children: React.ReactNode; className?: string }) => (
  <div className={[styles.footer, className].filter(Boolean).join(' ')}>{children}</div>
);

export const Card = Object.assign(CardRoot, {
  Header: CardHeader,
  Title: CardTitle,
  Content: CardContent,
  Footer: CardFooter,
});

Card.displayName = 'Card';
CardRoot.displayName = 'Card.Root';
CardHeader.displayName = 'Card.Header';
CardTitle.displayName = 'Card.Title';
CardContent.displayName = 'Card.Content';
CardFooter.displayName = 'Card.Footer';
",
