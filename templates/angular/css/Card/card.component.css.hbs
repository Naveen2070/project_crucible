{{> shared/components/card-base}}

.header:not(:empty) {
  padding: calc(var(--spacing-unit) * 4);
  border-bottom: 1px solid var(--color-border);
}

.title-container:not(:empty) {
  padding: calc(var(--spacing-unit) * 4);
}

.title {
  margin:      0;
  font-size:   1.1em;
  font-weight: 600;
}

.content {
  padding: calc(var(--spacing-unit) * 4);
}

.footer:not(:empty) {
  padding: calc(var(--spacing-unit) * 4);
  border-top: 1px solid var(--color-border);
}
