  "Select.tsx": "import React, { useState, useRef, useEffect, useId, createContext, useContext } from 'react';

const variantClasses: Record<string, string> = {
  default: 'bg-[var(--color-surface)] border-[var(--color-border)] focus:border-[var(--color-primary)]',
  error: 'bg-[var(--color-surface)] border-[var(--color-destructive)] focus:border-[var(--color-destructive)]',
 };

const sizeClasses: Record<string, string> = {
  sm: 'px-3 py-1.5 text-sm',
  md: 'px-4 py-2 text-base',
  lg: 'px-5 py-3 text-lg',
};

export interface SelectOption {
  value: string;
  label: string;
}

export type SelectVariant = 'default' | 'error';
export type SelectSize    = 'sm' | 'md' | 'lg';

interface SelectContextValue {
  isOpen: boolean;
  setIsOpen: (open: boolean) => void;
  activeIndex: number;
  setActiveIndex: React.Dispatch<React.SetStateAction<number>>;
  value?: string;
  onChange?: (value: string) => void;
  labelId: string;
  listboxId: string;
  id: string;
  options: SelectOption[];
  setOptions: React.Dispatch<React.SetStateAction<SelectOption[]>>;
  disabled?: boolean;
  error?: string;
  variant: SelectVariant;
  size: SelectSize;
  placeholder: string;
}

const SelectContext = createContext<SelectContextValue | undefined>(undefined);

const useSelectContext = () => {
  const context = useContext(SelectContext);
  if (!context) throw new Error('Select components must be wrapped in <Select />');
  return context;
};

export interface SelectProps {
  options?:  SelectOption[];
  value?:    string;
  onChange?: (value: string) => void;
  variant?:  SelectVariant;
  size?:     SelectSize;
  disabled?: boolean;
  error?:    string;
  placeholder?: string;
  children: React.ReactNode;
}

const SelectRoot: React.FC<SelectProps> = ({
  options: initialOptions = [],
  value,
  onChange,
  variant = 'default',
  size = 'md',
  disabled,
  error,
  placeholder = 'Select an option',
  children,
}) => {
  const [isOpen, setIsOpen] = useState(false);
  const [activeIndex, setActiveIndex] = useState(-1);
  const [options, setOptions] = useState<SelectOption[]>(initialOptions);
  const containerRef = useRef<HTMLDivElement>(null);
  const id = useId();
  const labelId = \`\${id}-label\`;
  const listboxId = \`\${id}-listbox\`;

  useEffect(() => {
    const handleClickOutside = (e: MouseEvent) => {
      if (containerRef.current && !containerRef.current.contains(e.target as Node)) {
        setIsOpen(false);
      }
    };
    document.addEventListener('mousedown', handleClickOutside);
    return () => document.removeEventListener('mousedown', handleClickOutside);
  }, []);

  return (
    <SelectContext.Provider value={{ 
      isOpen, setIsOpen, activeIndex, setActiveIndex, value, onChange, 
      labelId, listboxId, id, options, setOptions, disabled, error, variant, size, placeholder 
    }}>
      <div className="flex flex-col gap-[var(--spacing-unit)] w-full relative" ref={containerRef}>
        {children}
      </div>
    </SelectContext.Provider>
  );
};

const SelectLabel: React.FC<{ children: React.ReactNode; className?: string }> = ({ children, className }) => {
  const { labelId } = useSelectContext();
  return <label id={labelId} className={["font-medium text-[var(--color-text)] text-sm", className].filter(Boolean).join(' ')}>{children}</label>;
};

const SelectTrigger: React.FC<{ children: React.ReactNode; className?: string }> = ({ children, className }) => {
  const { 
    isOpen, setIsOpen, labelId, listboxId, activeIndex, setActiveIndex, 
    value, options, disabled, id, onChange, variant, size, error
  } = useSelectContext();
  
  const searchString = useRef('');
  const searchTimeout = useRef<ReturnType<typeof setTimeout> | null>(null);

  const handleKeyDown = (e: React.KeyboardEvent) => {
    if (disabled) return;

    // Type-ahead logic
    if (e.key.length === 1 && !e.ctrlKey && !e.metaKey && !e.altKey) {
      searchString.current += e.key.toLowerCase();
      if (searchTimeout.current) clearTimeout(searchTimeout.current);
      searchTimeout.current = setTimeout(() => {
        searchString.current = '';
      }, 500);

      const matchIndex = options.findIndex((opt) =>
        opt.label.toLowerCase().startsWith(searchString.current)
      );

      if (matchIndex >= 0) {
        setActiveIndex(matchIndex);
        if (!isOpen) {
          onChange?.(options[matchIndex].value);
        }
      }
      return;
    }

    if (!isOpen) {
      if (e.key === 'Enter' || e.key === ' ' || e.key === 'ArrowDown' || e.key === 'ArrowUp') {
        e.preventDefault();
        setIsOpen(true);
        const currentIndex = options.findIndex(o => o.value === value);
        setActiveIndex(currentIndex >= 0 ? currentIndex : 0);
      }
      return;
    }

    switch (e.key) {
      case 'ArrowDown':
        e.preventDefault();
        setActiveIndex((prev) => (prev < options.length - 1 ? prev + 1 : prev));
        break;
      case 'ArrowUp':
        e.preventDefault();
        setActiveIndex((prev) => (prev > 0 ? prev - 1 : prev));
        break;
      case 'Enter':
      case ' ':
        e.preventDefault();
        if (activeIndex >= 0) {
          onChange?.(options[activeIndex].value);
          setIsOpen(false);
        }
        break;
      case 'Escape':
        setIsOpen(false);
        break;
      case 'Home':
        e.preventDefault();
        setActiveIndex(0);
        break;
      case 'End':
        e.preventDefault();
        setActiveIndex(options.length - 1);
        break;
    }
  };

  return (
    <>
      <div
        className={[
          'flex items-center justify-between bg-[var(--color-surface)] border-[1.5px] rounded-[var(--radius-md)] cursor-pointer transition-all outline-none',
          'focus-visible:ring-2 focus-visible:ring-[var(--color-primary)] focus-visible:ring-offset-2',
          isOpen && 'border-[var(--color-primary)] rounded-b-none',
          disabled && 'opacity-50 cursor-not-allowed bg-[var(--color-background)]',
          error && 'border-[var(--color-destructive)]',
          variantClasses[variant],
          sizeClasses[size],
          className,
        ].join(' ')}
        role="combobox"
        aria-expanded={isOpen}
        aria-haspopup="listbox"
        aria-labelledby={labelId}
        aria-controls={listboxId}
        tabIndex={disabled ? -1 : 0}
        onKeyDown={handleKeyDown}
        onClick={() => !disabled && setIsOpen(!isOpen)}
        aria-activedescendant={activeIndex >= 0 ? \`\${id}-option-\${activeIndex}\` : undefined}
      >
        {children}
      </div>
      {error && <span className="text-xs text-[var(--color-destructive)] mt-1" role="alert">{error}</span>}
    </>
  );
};

const SelectValue: React.FC<{ placeholder?: string }> = ({ placeholder: propPlaceholder }) => {
  const { value, options, placeholder: contextPlaceholder } = useSelectContext();
  const selectedOption = options.find(opt => opt.value === value);
  return (
    <span className="truncate flex-1 text-[var(--color-text)]">
      {selectedOption ? selectedOption.label : (propPlaceholder || contextPlaceholder)}
    </span>
  );
};

const SelectIcon: React.FC = () => (
  <span className="ml-2 text-[var(--color-text-muted)] text-xs" aria-hidden="true">▼</span>
);

const SelectContent: React.FC<{ children: React.ReactNode; className?: string }> = ({ children, className }) => {
  const { isOpen, listboxId, labelId, activeIndex } = useSelectContext();
  const listboxRef = useRef<HTMLUListElement>(null);

  useEffect(() => {
    if (isOpen && activeIndex >= 0 && listboxRef.current) {
      const optionEl = listboxRef.current.children[activeIndex] as HTMLElement;
      if (optionEl) optionEl.scrollIntoView({ block: 'nearest' });
    }
  }, [isOpen, activeIndex]);

  if (!isOpen) return null;

  return (
    <ul
      id={listboxId}
      ref={listboxRef}
      className={[
        "absolute top-full left-0 right-0 z-50 bg-[var(--color-surface)] border-[1.5px] border-[var(--color-primary)] border-t-0 rounded-b-[var(--radius-md)] shadow-lg max-h-[200px] overflow-y-auto m-0 p-0 list-none",
        className
      ].join(' ')}
      role="listbox"
      aria-labelledby={labelId}
    >
      {children}
    </ul>
  );
};

const SelectItem: React.FC<{ value: string; label: string; children?: React.ReactNode; className?: string }> = ({ value: itemValue, label, children, className }) => {
  const { value, onChange, setIsOpen, options, setOptions, activeIndex, setActiveIndex, id } = useSelectContext();
  
  const index = options.findIndex(opt => opt.value === itemValue);
  
  useEffect(() => {
    setOptions(prev => {
      if (prev.find(opt => opt.value === itemValue)) return prev;
      return [...prev, { value: itemValue, label }];
    });
  }, [itemValue, label, setOptions]);

  return (
    <li
      id={\`\${id}-option-\${index}\`}
      role="option"
      aria-selected={value === itemValue}
      className={[
        'px-4 py-2 cursor-pointer transition-colors text-sm',
        value === itemValue && 'bg-[var(--color-secondary)] text-[var(--color-primary)] font-semibold',
        activeIndex === index && 'bg-[var(--color-secondary)] text-[var(--color-primary)]',
        className
      ].join(' ')}
      onClick={(e) => {
        e.stopPropagation();
        onChange?.(itemValue);
        setIsOpen(false);
      }}
      onMouseEnter={() => setActiveIndex(index)}
    >
      {children || label}
    </li>
  );
};

const SelectItemText: React.FC<{ children: React.ReactNode }> = ({ children }) => (
  <>{children}</>
);

export const Select = Object.assign(SelectRoot, {
  Root: SelectRoot,
  Trigger: SelectTrigger,
  Value: SelectValue,
  Icon: SelectIcon,
  Content: SelectContent,
  Item: SelectItem,
  ItemText: SelectItemText,
  Label: SelectLabel,
});

Select.displayName = 'Select';
SelectRoot.displayName = 'Select.Root';
SelectTrigger.displayName = 'Select.Trigger';
SelectValue.displayName = 'Select.Value';
SelectIcon.displayName = 'Select.Icon';
SelectContent.displayName = 'Select.Content';
SelectItem.displayName = 'Select.Item';
SelectItemText.displayName = 'Select.ItemText';
SelectLabel.displayName = 'Select.Label';
",
}
