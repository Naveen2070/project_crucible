import type { Meta, StoryObj } from '@storybook/vue3';
import Button from './Button.vue';

const meta: Meta<typeof Button> = {
  title: 'Crucible/{{name}}',
  component: Button,
  argTypes: {
    variant:  { control: 'select', options: {{> shared/variant-options}} },
    size:     { control: 'select', options: {{> shared/size-options}} },
    loading:  { control: 'boolean' },
    disabled: { control: 'boolean' },
  },
};

export default meta;
type Story = StoryObj<typeof Button>;

export const Default: Story = {
  args: { variant: 'default', size: 'md' },
  render: (args) => ({
    components: { Button },
    setup() { return { args }; },
    template: `<Button :variant="args.variant" :size="args.size">Button</Button>`,
  }),
};

{{#each variants}}
{{#unless (eq this "default")}}
export const {{capitalize this}}: Story = {
  args: { variant: '{{this}}' },
  render: (args) => ({
    components: { Button },
    setup() { return { args }; },
    template: `<Button :variant="args.variant">{{capitalize this}} Button</Button>`,
  }),
};
{{/unless}}
{{/each}}

{{#each sizes}}
export const {{capitalize this}}: Story = {
  args: { size: '{{this}}' },
  render: (args) => ({
    components: { Button },
    setup() { return { args }; },
    template: `<Button :size="args.size">{{capitalize this}} Size</Button>`,
  }),
};
{{/each}}

export const Loading: Story = {
  args: { variant: 'primary', size: 'md', loading: true },
  render: (args) => ({
    components: { Button },
    setup() { return { args }; },
    template: `<Button :variant="args.variant" :size="args.size" :loading="args.loading">Loading</Button>`,
  }),
};

export const Disabled: Story = {
  args: { variant: 'primary', size: 'md', disabled: true },
  render: (args) => ({
    components: { Button },
    setup() { return { args }; },
    template: `<Button :variant="args.variant" :size="args.size" :disabled="args.disabled">Disabled</Button>`,
  }),
};

{{#if features.compoundComponents}}
export const WithSlots: Story = {
  args: { variant: 'primary' },
  render: (args) => ({
    components: { Button },
    setup() { return { args }; },
    template: `
<Button :variant="args.variant" :size="args.size">
  <template #icon><span class="mr-2">★</span></template>
  With Custom Icon
</Button>`,
  }),
};

export const LoadingSlot: Story = {
  args: { variant: 'primary', loading: true },
  render: (args) => ({
    components: { Button },
    setup() { return { args }; },
    template: `
<Button :variant="args.variant" :loading="args.loading">
  <template #spinner><span class="spinner"></span></template>
  Custom Spinner
</Button>`,
  }),
};
{{/if}}
