import type { Meta, StoryObj } from '@storybook/vue3';
import Button from './Button.vue';

const meta: Meta<typeof Button> = {
  title: 'Crucible/{{name}}',
  component: Button,
  argTypes: {
    variant:  { control: 'select', options: {{> shared/variant-options}} },
    size:     { control: 'select', options: {{> shared/size-options}} },
    loading:  { control: 'boolean' },
    disabled: { control: 'boolean' },
  },
};

export default meta;
type Story = StoryObj<typeof Button>;

export const Default: Story = {
  args: { variant: 'primary', size: 'md' },
  render: (args) => ({
    components: { Button },
    setup() { return { args }; },
    template: `<Button v-bind="args">Button</Button>`,
  }),
};

{{#each variants}}
export const {{capitalize this}}: Story = {
  args: { variant: '{{this}}' },
  render: (args) => ({
    components: { Button },
    setup() { return { args }; },
    template: `<Button v-bind="args">{{capitalize this}} Button</Button>`,
  }),
};
{{/each}}

{{#each sizes}}
export const {{capitalize this}}: Story = {
  args: { size: '{{this}}' },
  render: (args) => ({
    components: { Button },
    setup() { return { args }; },
    template: `<Button v-bind="args">{{capitalize this}} Size</Button>`,
  }),
};
{{/each}}

export const Loading: Story = {
  args: { variant: 'primary', size: 'md', loading: true },
  render: (args) => ({
    components: { Button },
    setup() { return { args }; },
    template: `<Button v-bind="args">Loading</Button>`,
  }),
};

export const Disabled: Story = {
  args: { variant: 'primary', size: 'md', disabled: true },
  render: (args) => ({
    components: { Button },
    setup() { return { args }; },
    template: `<Button v-bind="args">Disabled</Button>`,
  }),
};

{{#if features.compoundComponents}}
export const WithSlots: Story = {
  args: { variant: 'primary' },
  render: (args) => ({
    components: { Button },
    setup() { return { args }; },
    template: `
<Button v-bind="args">
  <template #icon><span>🔥</span></template>
  With Custom Icon
</Button>`,
  }),
};

export const LoadingSlot: Story = {
  args: { variant: 'primary', loading: true },
  render: (args) => ({
    components: { Button },
    setup() { return { args }; },
    template: `
<Button v-bind="args">
  <template #spinner><span>⏳</span></template>
  Custom Spinner
</Button>`,
  }),
};
{{/if}}
