<script setup lang="ts">
import { computed } from 'vue';

export type ModalVariant = {{> shared/variant-types}};
export type ModalSize    = {{> shared/size-types}};

interface Props {
  isOpen?:  boolean;
  title?:   string;
  variant?: ModalVariant;
  size?:    ModalSize;
}

const props = withDefaults(defineProps<Props>(), {
  isOpen: false,
  title: '',
  variant: 'default',
  size: 'md',
});

const emit = defineEmits(['close']);

const onClose = () => {
  emit('close');
};

const modalClasses = computed(() => [
  'modal',
  `modal--${props.size}`,
  `modal--${props.variant}`,
]);

const titleId = `modal-title-${Math.floor(Math.random() * 1000000)}`;
</script>

<template>
  <slot name="overlay" :close="onClose" :isOpen="isOpen">
    <div v-if="isOpen" class="overlay" @click="onClose">
      <slot name="content">
        <div :class="modalClasses" @click.stop role="dialog" aria-modal="true" :aria-labelledby="titleId">
          <slot name="header">
            <header class="header">
              <slot name="title">
                <h2 :id="titleId" v-if="title" class="title">\{{ title }}</h2>
              </slot>
              <slot name="close">
                <button type="button" class="closeButton" @click="onClose" aria-label="Close modal">
                  &times;
                </button>
              </slot>
            </header>
          </slot>
          
          <slot name="body">
            <div class="body">
              <slot />
            </div>
          </slot>
          
          <slot name="footer" v-if="$slots.footer">
            <footer class="footer">
              <slot name="footer-content">
                <slot name="footer" />
              </slot>
            </footer>
          </slot>
        </div>
      </slot>
    </div>
  </slot>
</template>

