/* Generated by Crucible — edit freely, re-generate with --force */

.select-container, .container {
  display:        flex;
  flex-direction: column;
  gap:            var(--spacing-unit);
  width:          100%;
  position:       relative;
}

.select-wrapper {
  position:       relative;
  display:        flex;
  align-items:    center;
  width:          100%;
}

.select-label, .label {
  font-family: var(--font-family);
  font-size:   14px;
  font-weight: 500;
  color:       var(--color-text);
}

.select-combobox, .combobox {
  --select-height: {{tokens.componentTokens.select.height}};
  --select-padding-x: {{tokens.componentTokens.select.paddingX}};
  --select-radius: {{tokens.componentTokens.select.borderRadius}};

  display:         flex;
  align-items:     center;
  justify-content: space-between;
  background:      var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius:   var(--select-radius);
  cursor:          pointer;
  font-family:     var(--font-family);
  color:           var(--color-text);
  transition:      border-color 0.15s ease, box-shadow 0.15s ease;
  width:           100%;
  min-height:      var(--select-height);
  padding:         0 var(--select-padding-x);
  box-sizing:      border-box;
}

.select-combobox--open, .combobox--open {
  border-color: var(--color-primary);
  border-bottom-left-radius: 0;
  border-bottom-right-radius: 0;
}

{{#if a11y.focusRing}}
.select-combobox:focus-visible, .combobox:focus-visible {
  outline:        {{a11y.focusRingWidth}} solid {{a11y.focusRingColor}};
  outline-offset: {{a11y.focusRingOffset}};
  border-color:   var(--color-primary);
}
{{/if}}

.select-combobox--disabled, .combobox--disabled {
  background: var(--color-background);
  cursor:     not-allowed;
  opacity:    0.7;
}

.select-combobox--error, .combobox--error {
  border-color: var(--color-danger);
}

.select-value, .value {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.select-arrow, .arrow {
  margin-left: calc(var(--spacing-unit) * 2);
  font-size:   0.8em;
  color:       var(--color-text-muted);
}

.select-listbox, .listbox {
  --select-dropdown-shadow: {{tokens.componentTokens.select.dropdownShadow}};

  position:      absolute;
  top:           100%;
  left:          0;
  right:         0;
  background:    var(--color-surface);
  border: 1px solid var(--color-primary);
  border-top:    none;
  border-radius: 0 0 var(--select-radius) var(--select-radius);
  list-style:    none;
  margin:        0;
  padding:       0;
  z-index:       10;
  max-height:    200px;
  overflow-y:    auto;
  box-shadow:    var(--select-dropdown-shadow);
}

.select-option, .option {
  --select-option-padding: {{tokens.componentTokens.select.optionPadding}};
  padding:     var(--select-option-padding) var(--select-padding-x);
  cursor:      pointer;
  font-family: var(--font-family);
  font-size:   14px;
  color:       var(--color-text);
  transition:  background 0.15s ease;
}

.select-option--active, .option--active {
  background: var(--color-secondary);
  color:      var(--color-primary);
}

.select-option--selected, .option--selected {
  font-weight: 600;
  background:  var(--color-secondary);
  color:       var(--color-primary);
}

.select-error, .error {
  color:       var(--color-danger);
  font-family: var(--font-family);
  font-size:   12px;
  margin-top:  2px;
}

/* Sizes */
.select-combobox--sm, .combobox--sm { min-height: var(--select-height); font-size: 13px; }
.select-combobox--md, .combobox--md { min-height: var(--select-height); font-size: 15px; }
.select-combobox--lg, .combobox--lg { min-height: var(--select-height); font-size: 17px; }
