{{> shared/components/card-base}}

.title, .card-title, ::ng-deep [card-title] {
  display:     block;
  margin:      0;
  padding:     var(--card-header-padding);
  font-size:   1.1em;
  font-weight: 600;
  border-bottom: 1px solid var(--color-border);
}

.content, .card-content {
  padding: var(--card-content-padding);
}
