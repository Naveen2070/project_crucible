  "dialog.component.html": "@if (isOpen) {
  <div 
    class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-[var(--dialog-overlay-bg)] backdrop-blur-sm"
    (click)="onClose()"
  >
    <ng-content select="[overlay]"></ng-content>
    <div
      [class]="dialogClasses"
      role="dialog"
      aria-modal="true"
      [attr.aria-labelledby]="titleId"
      [attr.aria-describedby]="descriptionId"
      (click)="$event.stopPropagation()"
    >
      <ng-content select="[content]"></ng-content>
      <header class="flex items-center justify-between p-6 border-b border-[var(--color-border)]">
        <ng-content select="[header]"></ng-content>
        <h2 [id]="titleId" class="text-xl font-bold text-[var(--color-text)]">
          <ng-content select="[dialog-title]"></ng-content>
        </h2>
        <ng-content select="[dialog-description]"></ng-content>
        <p [id]="descriptionId" class="text-sm text-[var(--color-text-muted)]">
          <ng-content select="[description]"></ng-content>
        </p>
        <button
          type="button"
          class="ml-auto text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors text-2xl"
          (click)="onClose()"
          aria-label="Close Dialog"
        >
          <ng-content select="[close]">&times;</ng-content>
        </button>
      </header>
      
      <div class="p-6 text-[var(--color-text-muted)]">
        <ng-content select="[body]"></ng-content>
        <ng-content></ng-content>
      </div>
      
      <footer class="p-6 border-t border-[var(--color-border)] bg-[var(--color-background)]/50 flex justify-end gap-3 empty:hidden">
        <ng-content select="[footer]"></ng-content>
      </footer>
    </div>
  </div>
}
",
  "dialog.component.ts": "import { Component, Input, Output, EventEmitter, OnInit, OnDestroy } from '@angular/core';

const variantClasses: Record<string, string> = {
  default: 'bg-[var(--color-surface)]',
  confirm: 'bg-[var(--color-surface)] border-t-4 border-[var(--color-primary)]',
 };

const sizeClasses: Record<string, string> = {
  sm: 'max-w-md',
  md: 'max-w-lg',
  lg: 'max-w-2xl',
};

@Component({
  selector: 'app-Dialog',
  templateUrl: './dialog.component.html'
})
export class DialogComponent implements OnInit, OnDestroy {
  @Input() isOpen = false;
  @Input() title = '';
  @Input() variant: 'default' | 'confirm' = 'default';
  @Input() size:    'sm' | 'md' | 'lg' = 'md';
  @Input() className = '';

  @Output() close = new EventEmitter<void>();

  titleId = 'dialog-title-' + Math.random().toString(36).substring(2, 9);
  descriptionId = 'dialog-desc-' + Math.random().toString(36).substring(2, 9);

  ngOnInit() {}

  ngOnDestroy() {
    document.body.style.overflow = '';
  }

  @Input() showFooter = false;

  get hasFooter(): boolean {
    return this.showFooter;
  }

  onClose() {
    this.close.emit();
  }

  get dialogClasses(): string {
    return [
      'w-full bg-[var(--color-surface)] rounded-[var(--radius-lg)] shadow-2xl overflow-hidden relative',
      variantClasses[this.variant],
      sizeClasses[this.size],
      this.className
    ].filter(Boolean).join(' ');
  }
}
",
}
`;

