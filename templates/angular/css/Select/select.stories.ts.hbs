import { Meta, StoryObj } from '@storybook/angular';
import { SelectComponent } from './select.component';

const OPTIONS = [
  { label: 'Option 1', value: 1 },
  { label: 'Option 2', value: 2 },
  { label: 'Option 3', value: 3 },
];

const meta: Meta<SelectComponent> = {
  title: 'Crucible/Select',
  component: SelectComponent,
  tags: ['autodocs'],
  argTypes: {
    variant:     { control: 'select', options: {{> shared/variant-options}} },
    size:        { control: 'select', options: {{> shared/size-options}} },
    label:       { control: 'text' },
    placeholder: { control: 'text' },
    error:       { control: 'text' },
    disabled:    { control: 'boolean' },
  },
  decorators: [
    (Story) => ({
      template: '<div style="min-height: 300px;"><story /></div>',
    }),
  ],
};

export default meta;
type Story = StoryObj<SelectComponent>;

export const Default: Story = {
  args: {
    label: 'Select Option',
    placeholder: 'Choose one...',
    options: OPTIONS,
    size: 'md',
    variant: 'default',
  },
};

{{#each variants}}
{{#unless (eq this "default")}}
export const {{capitalize this}}: Story = {
  args: { variant: '{{this}}', label: '{{capitalize this}} Variant', options: OPTIONS },
};
{{/unless}}
{{/each}}

{{#each sizes}}
export const {{capitalize this}}: Story = {
  args: { size: '{{this}}', label: '{{capitalize this}} Size', options: OPTIONS },
};
{{/each}}

export const WithError: Story = {
  args: {
    label: 'Select Option',
    options: OPTIONS,
    error: 'Selection is required',
    size: 'md',
  },
};

export const Disabled: Story = {
  args: {
    label: 'Disabled Select',
    placeholder: 'Cannot select',
    options: OPTIONS,
    disabled: true,
    size: 'md',
  },
};
