{
  "Button.vue": "<script setup lang="ts">
/* eslint-disable vue/multi-word-component-names */
import { computed } from 'vue';

export type ButtonVariant = 'default' | 'primary' | 'secondary' | 'outline' | 'ghost' | 'link' | 'destructive';
export type ButtonSize    = 'xs' | 'sm' | 'md' | 'lg' | 'icon';

interface Props {
  variant?:  ButtonVariant;
  size?:     ButtonSize;
  loading?:  boolean;
  disabled?: boolean;
}

const props = withDefaults(defineProps<Props>(), {
  variant: 'primary',
  size: 'md',
  loading: false,
  disabled: false,
});

const classes = computed(() => [
  'inline-flex items-center justify-center gap-2 font-medium border-[1.5px] border-transparent cursor-pointer rounded-md transition-colors duration-150',
  {
    'bg-primary text-surface border-primary hover:brightness-110': props.variant === 'primary',
    'bg-secondary text-primary border-border hover:bg-primary hover:text-surface': props.variant === 'secondary',
    'bg-transparent text-text border-border hover:bg-secondary': props.variant === 'ghost',
    'bg-destructive text-destructive-foreground border-destructive hover:brightness-110': props.variant === 'destructive',
    'px-3 py-1.5 text-xs': props.size === 'sm',
    'px-5 py-2.5 text-sm': props.size === 'md',
    'px-7 py-3.5 text-base': props.size === 'lg',
    'opacity-45 cursor-not-allowed': props.disabled,
    'cursor-wait': props.loading,
  },
  'focus-visible:outline focus-visible:outline-2px focus-visible:outline-var(--color-primary) focus-visible:outline-offset-3px',
]);
</script>

<template>
  <button
    :class="classes"
    :disabled="disabled || loading"
    :aria-disabled="disabled || loading"
    :aria-busy="loading"
  >
    <slot name="spinner" v-if="loading">
      <span class="w-4 h-4 border-2 border-current border-t-transparent rounded-full animate-spin" aria-hidden="true"></span>
    </slot>
    <slot name="icon" />
    <slot name="label">
      <slot />
    </slot>
  </button>
</template>
",
