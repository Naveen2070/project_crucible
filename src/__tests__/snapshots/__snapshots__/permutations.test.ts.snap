  box-shadow:     var(--card-shadow);
}

.card:focus-visible {
  outline: none;
  box-shadow: 0 0 0 2px var(--card-bg), 0 0 0 4px var(--color-primary);
}

/* Sizes */
.card--sm { max-width: 300px; }
.card--md { max-width: 450px; }
.card--lg { max-width: 600px; }

/* Variants */
.card--hoverable:hover {
  border-color: var(--color-primary);
  box-shadow:   0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
}

.card--clickable {
  cursor: pointer;
  transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
}

.card--clickable:hover {
  border-color: var(--color-primary);
  box-shadow:   0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
  transform:    translateY(-4px);
}

.card--clickable:active {
  transform:    translateY(0);
}

.header, .card-header {
  padding: var(--card-header-padding);
  border-bottom: 1px solid var(--card-border);
}

.title, .card-title {
  margin:      0;
  padding:     var(--card-header-padding);
  font-size:   1.1rem;
  font-weight: 600;
  color:       var(--color-text);
  font-family: var(--font-family);
}

.description, .card-description {
  margin:      0;
  padding:     0 var(--card-header-padding);
  font-size:   0.875rem;
  color:       var(--color-text-muted);
  font-family: var(--font-family);
}

.action, .card-action {
  margin-left: auto;
  display:     flex;
  align-items: center;
  gap:        var(--spacing-unit);
}

.content, .card-content {
  padding: var(--card-content-padding);
}

.footer, .card-footer {
  padding: var(--card-footer-padding);
  border-top: 1px solid var(--card-border);
}
",
  "Card.tsx": "import React from 'react';
import styles from './Card.module.css';
export type CardVariant = 'default' | 'hoverable' | 'clickable';
export type CardSize    = 'sm' | 'md' | 'lg';

export interface CardProps {
  variant?: CardVariant;
  size?: CardSize;
  title?: string;
  children?: React.ReactNode;
  onClick?: () => void;
  className?: string;
  href?: string;
}

export const CardRoot = ({
  variant = 'default',
  size = 'md',
  children,
  onClick,
  className,
  href,
}: CardProps) => {
  const isClickable = variant === 'clickable' || !!onClick || !!href;
  
  const cls = [
    styles.card,
    styles[\`card--\${variant}\`],
    styles[\`card--\${size}\`],
    isClickable && styles['card--clickable'],
    className,
  ].filter(Boolean).join(' ');

  const handleKeyDown = (e: React.KeyboardEvent) => {
    if (isClickable && (e.key === 'Enter' || e.key === ' ')) {
      e.preventDefault();
      onClick?.();
      if (href) window.location.href = href;
    }
  };

  const Component = href ? 'a' : isClickable ? 'button' : 'article';

  return (
    <Component
      className={cls}
      onClick={onClick}
      href={href}
      role={href ? undefined : isClickable ? 'button' : 'article'}
      tabIndex={isClickable ? 0 : undefined}
      onKeyDown={isClickable ? handleKeyDown : undefined}
    >
      {children}
    </Component>
  );
};

export const CardHeader = ({ children, className }: { children: React.ReactNode; className?: string }) => (
  <div className={[styles.header, className].filter(Boolean).join(' ')}>{children}</div>
);

