exports[`Framework x Style-System Permutation Snapshots > Framework: vue > Theme: soft > StyleSystem: css > Component: Input > renders correctly 1`] = `
{
  "Input.vue": "<script setup lang="ts">
import { ref, computed } from 'vue';

export type InputVariant = 'default' | 'error';
export type InputSize    = 'sm' | 'md' | 'lg';

interface Props {
  id?:          string;
  modelValue?:  string;
  label?:       string;
  placeholder?: string;
  variant?:     InputVariant;
  size?:        InputSize;
  error?:       string;
  hint?:        string;
  disabled?:    boolean;
  required?:    boolean;
  type?:        'text' | 'password';
}

const props = withDefaults(defineProps<Props>(), {
  id: '',
  modelValue: '',
  label: '',
  placeholder: '',
  variant: 'default',
  size: 'md',
  error: '',
  hint: '',
  disabled: false,
  required: false,
  type: 'text',
});

const emit = defineEmits(['update:modelValue']);

const showPassword = ref(false);
const generatedId = \`input-\${Math.floor(Math.random() * 1000000)}\`;
const inputId = computed(() => props.id || generatedId);
const errorId = computed(() => \`\${inputId.value}-error\`);
const hintId = computed(() => \`\${inputId.value}-hint\`);

const onInput = (event: Event) => {
  const target = event.target as HTMLInputElement;
  emit('update:modelValue', target.value);
};

const describedBy = computed(() => {
  const ids = [];
  if (props.error) ids.push(errorId.value);
  if (props.hint) ids.push(hintId.value);
  return ids.join(' ') || undefined;
});

const togglePassword = () => {
  showPassword.value = !showPassword.value;
};

const currentType = computed(() => {
  if (props.type === 'password') {
    return showPassword.value ? 'text' : 'password';
  }
  return props.type;
});

const containerClasses = computed(() => [
  'input-container',
  \`input--\${props.size}\`,
  {
    'input--error': props.variant === 'error' || props.error,
    'input--disabled': props.disabled,
  },
]);
</script>

<template>
  <div :class="containerClasses">
    <slot name="label">
      <label v-if="label" :for="inputId" class="input-label">
        {{ label }}
        <span v-if="required" class="input-required" aria-hidden="true">*</span>
      </label>
    </slot>
    
    <div class="input-wrapper">
      <slot name="field">
        <input
          :id="inputId"
          :type="currentType"
          :class="['input', \`input--\${size}\`]"
          :placeholder="placeholder"
          :disabled="disabled"
          :value="modelValue"
          @input="onInput"
          :aria-invalid="!!error"
          :aria-required="required"
          :aria-describedby="describedBy"
        >
      </slot>
      
      <slot name="toggle" v-if="type === 'password'">
        <button
          type="button"
          class="input-password-toggle"
          @click="togglePassword"
          :aria-label="showPassword ? 'Hide password' : 'Show password'"
          :aria-pressed="showPassword"
        >
          {{ showPassword ? 'Hide' : 'Show' }}
        </button>
      </slot>
    </div>

    <slot name="hint">
      <span v-if="hint && !error" :id="hintId" class="input-hint">{{ hint }}</span>
    </slot>

    <slot name="error">
      <span v-if="error" :id="errorId" class="input-error" role="alert">{{ error }}</span>
    </slot>
  </div>
</template>

<style scoped>
/* Generated by Crucible — edit freely, re-generate with --force */

/* Generated by Crucible — edit freely, re-generate with --force */

.input-container {
  display:        flex;
  flex-direction: column;
  gap:            var(--spacing-unit);
  width:          100%;
}

.input-label, .label {
  font-family: var(--font-family);
  font-size:   0.875rem;
  font-weight: 500;
  color:       var(--color-text);
  margin-bottom: calc(var(--spacing-unit) * 1.5);
}

.input-required, .required {
  color:       var(--color-destructive);
  margin-left: calc(var(--spacing-unit) * 0.5);
}

.input-wrapper {
  position: relative;
  width:    100%;
}

.input {
  --input-height: calc(var(--spacing-unit) * 10);
  --input-radius: var(--radius-md);
  --input-border: var(--color-border);
  --input-transition: border-color 0.2s ease, box-shadow 0.2s ease;

  width:           100%;
  font-family:     var(--font-family);
  border:          1px solid var(--input-border);
  border-radius:   var(--input-radius);
  background:      var(--color-surface);
  color:           var(--color-text);
  transition:      var(--input-transition);
  box-sizing:      border-box;
}

.input:focus-visible {
  outline: none;
  border-color: var(--color-primary);
  box-shadow: 0 0 0 2px var(--color-background), 0 0 0 4px var(--color-primary);
}

/* Sizes */
.input--sm { 
  min-height: var(--input-height);
  padding:    0 calc(var(--spacing-unit) * 3);
  font-size:  0.875rem; 
}
.input--md { 
  min-height: var(--input-height);
  padding:    0 calc(var(--spacing-unit) * 3);
  font-size:  1rem; 
}
.input--lg { 
  min-height: var(--input-height);
  padding:    0 calc(var(--spacing-unit) * 3);
  font-size:  1.125rem; 
}

/* Variants */
.input--error {
  border-color: var(--color-destructive);
}

.input--disabled {
  background: var(--color-background);
  cursor:     not-allowed;
  opacity:    0.7;
}

.input-password-toggle, .password-toggle {
  position:   absolute;
  right:      12px;
  top:        50%;
  transform:  translateY(-50%);
  background: transparent;
  border:     none;
  padding:    0;
  margin:     0;
  font-family: var(--font-family);
  font-size:  12px;
  color:      var(--color-text-muted);
  cursor:     pointer;
}

.input-password-toggle:hover, .password-toggle:hover {
  color: var(--color-text);
}

.input-password-toggle:focus-visible, .password-toggle:focus-visible {
  outline:        2px solid var(--color-primary);
  outline-offset: 3px;
  border-radius:  var(--radius-sm);
}

.input-hint, .input-error, .hint, .error {
  font-family: var(--font-family);
  font-size:   12px;
  margin-top:  2px;
}

.input-hint, .hint {
  color: var(--color-text-muted);
}

.input-error, .error {
  color: var(--color-destructive);
}
