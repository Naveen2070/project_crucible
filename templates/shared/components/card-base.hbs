/* Generated by Crucible — edit freely, re-generate with --force */

.card {
  --card-bg: {{tokens.componentTokens.card.backgroundColor}};
  --card-border: {{tokens.componentTokens.card.borderColor}};
  --card-radius: {{tokens.componentTokens.card.borderRadius}};
  --card-shadow: {{tokens.componentTokens.card.shadow}};
  --card-header-padding: {{tokens.componentTokens.card.headerPadding}};
  --card-content-padding: {{tokens.componentTokens.card.contentPadding}};
  --card-footer-padding: {{tokens.componentTokens.card.footerPadding}};

  display:        flex;
  flex-direction: column;
  background:     var(--card-bg);
  border:         1px solid var(--card-border);
  border-radius:  var(--card-radius);
  color:          var(--color-text);
  font-family:    var(--font-family);
  overflow:       hidden;
  text-align:     left;
  width:          100%;
  padding:        0;
  margin:         0;
  text-decoration: none;
  box-shadow:     var(--card-shadow);
}

{{#if a11y.focusRing}}
.card:focus-visible {
  outline: none;
  box-shadow: 0 0 0 2px var(--card-bg), 0 0 0 4px {{a11y.focusRingColor}};
}
{{/if}}

/* Sizes */
.card--sm { max-width: 300px; }
.card--md { max-width: 450px; }
.card--lg { max-width: 600px; }

/* Variants */
.card--hoverable:hover {
  border-color: var(--color-primary);
  box-shadow:   0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
}

.card--clickable {
  cursor: pointer;
  transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
}

.card--clickable:hover {
  border-color: var(--color-primary);
  box-shadow:   0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
  transform:    translateY(-4px);
}

.card--clickable:active {
  transform:    translateY(0);
}

.header, .card-header {
  padding: var(--card-header-padding);
  border-bottom: 1px solid var(--card-border);
}

.title, .card-title {
  margin:      0;
  padding:     var(--card-header-padding);
  font-size:   1.1rem;
  font-weight: 600;
  color:       var(--color-text);
  font-family: var(--font-family);
}

.content, .card-content {
  padding: var(--card-content-padding);
}

.footer, .card-footer {
  padding: var(--card-footer-padding);
  border-top: 1px solid var(--card-border);
}
