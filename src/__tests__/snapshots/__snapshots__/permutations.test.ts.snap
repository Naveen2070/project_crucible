  "table.component.ts": "import { Component, Input, Output, EventEmitter, OnInit, OnDestroy, signal, computed } from '@angular/core';
import { CommonModule } from '@angular/common';
import { FormsModule } from '@angular/forms';
import { HeadlessVirtualizer, VirtualState } from './utils/virtualizer';
import { sort, SortDirection } from './utils/table-sorter';
import { getPageData, getPageNumbers } from './utils/table-paginator';

export type TableVariant = 'default' | 'striped' | 'bordered' | 'compact';
export type TableSize    = 'sm' | 'md' | 'lg';

export interface TableColumn<T = unknown> {
  key: string;
  label: string;
  sortable?: boolean;
  width?: string;
  align?: 'left' | 'center' | 'right';
}

@Component({
  selector: 'app-table',
  standalone: true,
  imports: [CommonModule, FormsModule],
  templateUrl: './table.component.html',
  styleUrls: ['./table.component.scss']
})
export class TableComponent<T extends Record<string, unknown>> implements OnInit, OnDestroy {
  @Input() columns: TableColumn<T>[] = [];
  @Input() data: T[] = [];
  @Input() rowKey: keyof T | string = '';
  @Input() variant: TableVariant = 'default';
  @Input() size: TableSize = 'md';
  @Input() virtualize = false;
  @Input() virtualizationThreshold = 100;
  @Input() itemHeight = 44;
  @Input() customVirtualState?: VirtualState;
  @Input() paginationMode: 'client' | 'server' = 'client';
  @Input() pageSize = 10;
  @Input() page = 1;
  @Input() totalPages = 0;
  @Input() totalCount?: number;
  @Input() sortKey?: string;
  @Input() sortDirection: SortDirection = 'asc';
  @Input() selectionMode: 'single' | 'multiple' | 'none' = 'none';
  @Input() selectedRows: string[] = [];
  @Input() loading = false;
  @Input() emptyMessage = 'No data available';
  @Input() className = '';

  @Output() pageChange = new EventEmitter<{ page: number; pageSize: number }>();
  @Output() sortChange = new EventEmitter<{ key: string; direction: SortDirection }>();
  @Output() selectChange = new EventEmitter<string[]>();
  @Output() selectAllChange = new EventEmitter<boolean>();

  containerRef: HTMLDivElement | null = null;
  scrollTop = signal(0);
  containerHeight = signal(600);
  internalPage = signal(1);
  internalSortKey = signal<string | undefined>(undefined);
  internalSortDir = signal<SortDirection>('asc');
  internalSelected = signal<string[]>([]);

  virtualizer: HeadlessVirtualizer | null = null;
  resizeObserver: ResizeObserver | null = null;

  sizeClasses: Record<string, string> = {
    sm: 'cellSm',
    md: 'cellMd',
    lg: 'cellLg',
  };

  alignClasses: Record<string, string> = {
    left: 'cellLeft',
    center: 'cellCenter',
    right: 'cellRight',
  };

  tableContainer = 'tableContainer';
  thead = 'thead';
  tbody = 'tbody';
  headerRow = 'headerRow';
  emptyRow = 'emptyRow';
  pagination = 'pagination';
  paginationInfo = 'paginationInfo';
  paginationButtons = 'paginationButtons';
  paginationBtn = 'paginationBtn';
  paginationBtnActive = 'paginationBtnActive';
  checkbox = 'checkbox';
  sortIcon = 'sortIcon';

  getAriaSort(colKey: string): string | null {
    if (this.internalSortKey() !== colKey) return null;
    return this.internalSortDir() === 'asc' ? 'ascending' : 'descending';
  }

  shouldShowSortIcon(colKey: string): boolean {
    return this.internalSortKey() === colKey;
  }

  shouldVirtualize = computed(() => this.virtualize && this.data.length >= this.virtualizationThreshold);

  virtualState = computed(() => {
    if (!this.shouldVirtualize() || !this.virtualizer) return null;
    return this.virtualizer.getState();
  });

  effectiveVirtualState = computed(() => {
    return this.customVirtualState || this.virtualState();
  });

  processedData = computed(() => {
    let result = [...this.data];
    if (this.internalSortKey()) {
      result = sort(result, this.internalSortKey()!, this.internalSortDir());
    }
    return result;
  });

  paginationResult = computed(() => {
    if (this.paginationMode === 'server') {
      return {
        data: this.processedData(),
        pageInfo: {
          page: this.page,
          pageSize: this.pageSize,
          totalItems: this.totalCount || 0,
          totalPages: this.totalPages,
          startIndex: 0,
          endIndex: this.processedData().length,
          hasNextPage: this.page < this.totalPages,
          hasPrevPage: this.page > 1,
        },
      };
    }
    return getPageData(this.processedData(), this.internalPage(), this.pageSize);
  });

  displayData = computed(() => this.paginationResult().data);
  pageInfo = computed(() => this.paginationResult().pageInfo);
  pageNumbers = computed(() => getPageNumbers(this.pageInfo().page, this.pageInfo().totalPages));

  getPaginationInfo(): string {
    const info = this.pageInfo();
    return \`Showing \${info.startIndex + 1} to \${info.endIndex} of \${info.totalItems} results\`;
  }

  isStriped = computed(() => this.variant === 'striped');
  isBordered = computed(() => this.variant === 'bordered');
  isCompact = computed(() => this.variant === 'compact');

  ngOnInit() {
    this.internalPage.set(this.page);
    this.internalSortKey.set(this.sortKey);
    this.internalSortDir.set(this.sortDirection);
    this.internalSelected.set([...this.selectedRows]);

    if (this.shouldVirtualize()) {
      this.virtualizer = new HeadlessVirtualizer({
        itemCount: this.data.length,
        itemHeight: this.itemHeight,
        overscan: 5,
        containerHeight: this.containerHeight(),
      });
    }
  }

  ngOnDestroy() {
    if (this.resizeObserver) {
      this.resizeObserver.disconnect();
    }
  }

  setContainerRef(el: HTMLDivElement) {
    this.containerRef = el;
    if (el) {
      this.resizeObserver = new ResizeObserver(entries => {
        this.containerHeight.set(entries[0].contentRect.height);
      });
      this.resizeObserver.observe(el);
    }
  }

  onScroll(event: Event) {
    const target = event.target as HTMLDivElement;
    this.scrollTop.set(target.scrollTop);
    if (this.virtualizer) {
      this.virtualizer.updateScroll(target.scrollTop);
    }
  }

  handleSort(column: TableColumn<T>) {
    if (!column.sortable) return;
    const currentKey = this.internalSortKey();
    const currentDir = this.internalSortDir();
    const newDir = currentKey === column.key
      ? (currentDir === 'asc' ? 'desc' : 'asc')
      : 'asc';
    this.internalSortKey.set(column.key);
    this.internalSortDir.set(newDir);
    this.sortChange.emit({ key: column.key, direction: newDir });
  }

  handleSelect(row: T) {
    const key = String(row[this.rowKey]);
    const current = this.internalSelected();
    let newSelected: string[];
    if (this.selectionMode === 'single') {
      newSelected = current.includes(key) ? [] : [key];
    } else {
      newSelected = current.includes(key)
        ? current.filter(k => k !== key)
        : [...current, key];
    }
    this.internalSelected.set(newSelected);
    this.selectChange.emit(newSelected);
  }

  handleSelectAll() {
    const allKeys = this.displayData().map(row => String(row[this.rowKey]));
    const current = this.internalSelected();
    const newSelected = current.length === this.displayData().length ? [] : allKeys;
    this.internalSelected.set(newSelected);
    this.selectAllChange.emit(newSelected.length > 0);
  }

  onPageChange(newPage: number) {
    this.internalPage.set(newPage);
    this.pageChange.emit({ page: newPage, pageSize: this.pageSize });
  }

  getWrapperClasses(): string {
    const classes = ['tableWrapper'];
    if (this.isBordered()) {
      classes.push('tableWrapper');
    }
    if (this.className) {
      classes.push(this.className);
    }
    return classes.join(' ');
  }

  getTableClasses(): string {
    const classes = ['table'];
    if (this.loading) {
      classes.push('tableLoading');
    }
    return classes.join(' ');
  }

  getHeaderCellClasses(col: TableColumn<T>): string {
    const classes = ['headerCell', this.sizeClasses[this.size]];
    classes.push(this.alignClasses[col.align || 'left']);
    if (col.sortable) {
      classes.push('headerCellSortable');
    }
    if (this.isBordered()) {
      classes.push('cellBordered');
    }
    return classes.join(' ');
  }

  getRowClasses(row: T, index: number): string {
    const classes = ['row'];
    const key = String(row[this.rowKey]);
    const isSelected = this.internalSelected().includes(key);
    
    if (this.isStriped() && index % 2 === 1) {
      classes.push('rowStriped');
    }
    if (!this.isStriped() && !this.isCompact()) {
      classes.push('rowHover');
    }
    if (isSelected) {
      classes.push('rowSelected');
    }
    return classes.join(' ');
  }

  getCellClasses(col: TableColumn<T>): string {
    const classes = ['cell', this.sizeClasses[this.size], this.alignClasses[col.align || 'left']];
    if (this.isBordered()) {
      classes.push('cellBordered');
    }
    return classes.join(' ');
  }

  getCellValue(row: T, colKey: string): string {
    return String(row[colKey as keyof T] ?? '');
  }

  trackByKey(index: number, col: TableColumn<T>): string {
    return col.key;
  }

  trackByIndex(index: number, item: T): number {
    return index;
  }

  trackByPage(index: number, page: number): number {
    return page;
  }
}",
  "virtualization-adapters-guide.md": "# Virtualization Adapters Guide

Generated by Crucible v1.0.0 | Theme: minimal | Framework: angular

This guide explains how to integrate external virtualization libraries with the Table component using the \`customVirtualState\` escape hatch.

---

## Overview

The Table component includes a **headless virtualization system** based on \`HeadlessVirtualizer\` - a framework-agnostic class that provides basic virtual scrolling without any UI dependencies. This allows:

1. **Zero-dependency** out-of-the-box virtualization
2. **Easy migration** to feature-rich libraries when needed
3. **Plug-and-play** integration with any virtualization library

---



## Angular Integration

### Using Angular CDK Virtual Scroll

Angular CDK provides powerful virtualization through \`@angular/cdk/scrolling\`:

\`\`\`typescript
import { Component, ViewChild, AfterViewInit } from '@angular/core';
import { CdkVirtualScrollViewport } from '@angular/cdk/scrolling';
import { TableComponent, TableColumn, VirtualState } from './table.component';

@Component({
  selector: 'app-your-table',
  template: \`
    <app-table
      [columns]="columns"
      [data]="data"
      [rowKey]="'id'"
      [virtualize]="true"
      [customVirtualState]="virtualState"
    />
  \`,
})
export class YourTableComponent implements AfterViewInit {
  @ViewChild(CdkVirtualScrollViewport) viewport!: CdkVirtualScrollViewport;

  columns: TableColumn[] = [];
  data: YourDataType[] = [];
  virtualState: VirtualState | undefined;

  private itemHeight = 44;
  private containerHeight = 600;

  ngAfterViewInit() {
    this.viewport.elementScrolled().subscribe(() => {
      this.updateVirtualState();
    });
  }

  private updateVirtualState() {
    const scrollTop = this.viewport.measureScrollOffset('top');
    const startIndex = Math.max(0, Math.floor(scrollTop / this.itemHeight) - 5);
    const endIndex = Math.min(
      this.data.length - 1,
      Math.ceil((scrollTop + this.containerHeight) / this.itemHeight) + 5
    );

    const virtualItems = [];
    for (let i = startIndex; i <= endIndex; i++) {
      virtualItems.push({ index: i, start: i * this.itemHeight });
    }

    this.virtualState = {
      startIndex,
      endIndex,
      totalHeight: this.data.length * this.itemHeight,
      offsetY: startIndex * this.itemHeight,
      virtualItems,
    };
  }

  // Smooth scroll to index
  scrollToIndex(index: number): void {
    this.viewport.scrollToIndex(index, 'smooth');
  }
}
\`\`\`

### Using @tanstack/angular-virtual

TanStack also provides Angular adapter:

\`\`\`typescript
import { Component, computed } from '@angular/core';
import { injectVirtualizer } from '@tanstack/angular-virtual';
import { TableComponent, TableColumn, VirtualState } from './table.component';

@Component({
  selector: 'app-your-table',
  template: \`
    <app-table
      [columns]="columns"
      [data]="data"
      [rowKey]="'id'"
      [virtualize]="true"
      [customVirtualState]="virtualState()"
    />
  \`,
})
export class YourTableComponent {
  data: YourDataType[] = [];
  columns: TableColumn[] = [];

  private virtualizer = injectVirtualizer({
    count: () => this.data.length,
    getScrollElement: () => document.querySelector('.table-container') as HTMLElement,
    estimateSize: () => 44,
    overscan: 5,
  });

  virtualState = computed(() => {
    const items = this.virtualizer.getVirtualItems();
    return {
      startIndex: items[0]?.index ?? 0,
      endIndex: items[items.length - 1]?.index ?? 0,
      totalHeight: this.virtualizer.getTotalSize(),
      offsetY: items[0]?.start ?? 0,
      virtualItems: items.map((item) => ({
        index: item.index,
        start: item.start,
      })),
    };
  });

  scrollToIndex(index: number): void {
    this.virtualizer.scrollToIndex(index, { behavior: 'smooth' });
  }
}
\`\`\`

### Custom VirtualState from Scratch

\`\`\`typescript
import { Component, signal, computed } from '@angular/core';
import { TableComponent, TableColumn, VirtualState } from './table.component';

@Component({
  selector: 'app-your-table',
  template: \`
    <app-table
      [columns]="columns"
      [data]="data"
      [rowKey]="'id'"
      [virtualize]="true"
      [customVirtualState]="virtualState()"
    />
  \`,
})
export class YourTableComponent {
  columns: TableColumn[] = [];
  data: YourDataType[] = [];

  private scrollTop = signal(0);
  private containerHeight = 600;
  private itemHeight = 44;

  virtualState = computed(() => {
    const startIndex = Math.max(0, Math.floor(this.scrollTop() / this.itemHeight) - 5);
    const endIndex = Math.min(
      this.data.length - 1,
      Math.ceil((this.scrollTop() + this.containerHeight) / this.itemHeight) + 5
    );

    const virtualItems = [];
    for (let i = startIndex; i <= endIndex; i++) {
      virtualItems.push({ index: i, start: i * this.itemHeight });
    }

    return {
      startIndex,
      endIndex,
      totalHeight: this.data.length * this.itemHeight,
      offsetY: startIndex * this.itemHeight,
      virtualItems,
    };
  });

  onScroll(event: Event): void {
    const target = event.target as HTMLElement;
    this.scrollTop.set(target.scrollTop);
  }
}
\`\`\`

---

## API Reference

### VirtualState Interface

\`\`\`typescript
export interface VirtualState {
  startIndex: number;      // First visible item index
  endIndex: number;        // Last visible item index
  totalHeight: number;     // Total scrollable height
  offsetY: number;         // Y offset for positioning
  virtualItems: {         // Array of visible items
    index: number;        // Item index in data array
    start: number;        // Y position of item
  }[];
}
\`\`\`

### Table Input Properties for Virtualization

| Property | Type | Description |
|----------|------|-------------|
| \`@Input() virtualize: boolean\` | Enable virtualization |
| \`@Input() virtualizationThreshold: number\` | Min items before virtualizing (default: 100) |
| \`@Input() itemHeight: number\` | Height of each row in pixels (default: 44) |
| \`@Input() customVirtualState: VirtualState\` | External virtualization state |

### Table Output Events

| Event | Type | Description |
|-------|------|-------------|
| \`@Output() pageChange\` | EventEmitter | Fired on pagination changes |

---

## Migration from HeadlessVirtualizer

If you started with the built-in \`HeadlessVirtualizer\` and need more features:

1. **Install Angular CDK**: \`ng add @angular/cdk\`
2. **Create CdkVirtualScrollViewport** with your container
3. **Map the state** to \`VirtualState\` interface using computed signals
4. **Pass to Table** via \`[customVirtualState]\` input binding
5. **Keep or remove** built-in virtualization props for fallback

The DOM structure stays the same - only the state source changes!

---

## Smooth Scrolling

All external libraries support smooth scrolling:

- **TanStack**: \`virtualizer.scrollToIndex(index, { behavior: 'smooth' })\`
- **Angular CDK**: \`viewport.scrollToIndex(index, 'smooth')\`
- **Vue**: Use library's built-in methods

When using \`customVirtualState\`, the smooth scrolling is handled entirely by the external library - just call its scroll method on your container element.


---

## Common Issues & Solutions

### 1. Row Height Mismatch

**Problem**: Rows don't align with virtual positions.

**Solution**: Ensure \`itemHeight\` in your adapter matches actual row height:
\`\`\`typescript
// Match the actual CSS row height
const itemHeight = 44; // Check your CSS!
\`\`\`

### 2. Scroll Position Reset

**Problem**: Scroll position jumps when switching virtualizers.

**Solution**: Sync scroll positions before switching:
\`\`\`typescript
const scrollTop = containerRef.current?.scrollTop ?? 0;
// Set external virtualizer to same position
externalVirtualizer.scrollTo(scrollTop);
\`\`\`

### 3. Empty or Missing Rows

**Problem**: Some rows don't render.

**Solution**: Check \`virtualItems\` mapping:
\`\`\`typescript
// Ensure index maps correctly
virtualItems: rowVirtualizer.getVirtualItems().map(item => ({
  index: item.index,  // This should match data array index
  start: item.start,
}))
\`\`\`

---

## Performance Tips

1. **Memoize VirtualState**: Use \`useMemo\` (React) / \`computed\` (Vue) / \`computed\` (Angular)
2. **Debounce Scroll Handlers**: Avoid excessive state updates
3. **Use Overscan**: Render extra items to prevent blank areas during fast scroll
4. **Profile with DevTools**: Check FPS during scroll to ensure 60fps

---

## Related Files

- \`utils/virtualizer.ts\` - HeadlessVirtualizer implementation
- \`utils/table-sorter.ts\` - Sorting utilities
- \`utils/table-paginator.ts\` - Pagination utilities

---

_This guide is auto-generated. Edit the source template or run \`crucible upgrade\` after updating your config._",
}
`;

