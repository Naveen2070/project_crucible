<script setup lang="ts">
import { ref, computed } from 'vue';

export type SelectVariant = {{> shared/variant-types}};
export type SelectSize    = {{> shared/size-types}};

interface Props {
  options?:     any[];
  modelValue?:  any;
  label?:       string;
  placeholder?: string;
  variant?:     SelectVariant;
  size?:        SelectSize;
  error?:       string;
  disabled?:    boolean;
}

const props = withDefaults(defineProps<Props>(), {
  options: () => [],
  modelValue: null,
  label: '',
  placeholder: 'Select an option',
  variant: 'default',
  size: 'md',
  error: '',
  disabled: false,
});

const emit = defineEmits(['update:modelValue']);

const isOpen = ref(false);
const activeIndex = ref(-1);
const searchString = ref('');
let searchTimeout: any;

const listboxId = `select-listbox-${Math.floor(Math.random() * 1000000)}`;
const getOptionId = (index: number) => `select-option-${listboxId}-${index}`;

const toggle = () => {
  if (!props.disabled) {
    isOpen.value = !isOpen.value;
    if (isOpen.value) {
      activeIndex.value = props.options.findIndex(o => isSelected(o));
      if (activeIndex.value === -1) activeIndex.value = 0;
    }
  }
};

const handleKeyDown = (e: KeyboardEvent) => {
  if (props.disabled) return;

  // Type-ahead
  if (e.key.length === 1 && !e.ctrlKey && !e.metaKey && !e.altKey) {
    searchString.value += e.key.toLowerCase();
    if (searchTimeout) clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
      searchString.value = '';
    }, 500);

    const matchIndex = props.options.findIndex((opt) => {
      const label = typeof opt === 'object' && 'label' in opt ? opt.label : String(opt);
      return label.toLowerCase().startsWith(searchString.value);
    });

    if (matchIndex >= 0) {
      activeIndex.value = matchIndex;
      if (!isOpen.value) {
        selectOption(props.options[matchIndex]);
      }
    }
    return;
  }

  if (!isOpen.value) {
    if (e.key === 'Enter' || e.key === ' ' || e.key === 'ArrowDown' || e.key === 'ArrowUp') {
      e.preventDefault();
      toggle();
    }
    return;
  }

  switch (e.key) {
    case 'ArrowDown':
      e.preventDefault();
      activeIndex.value = Math.min(activeIndex.value + 1, props.options.length - 1);
      break;
    case 'ArrowUp':
      e.preventDefault();
      activeIndex.value = Math.max(activeIndex.value - 1, 0);
      break;
    case 'Enter':
    case ' ':
      e.preventDefault();
      if (activeIndex.value >= 0) {
        selectOption(props.options[activeIndex.value]);
      }
      break;
    case 'Escape':
      isOpen.value = false;
      break;
    case 'Home':
      activeIndex.value = 0;
      break;
    case 'End':
      activeIndex.value = props.options.length - 1;
      break;
  }
};

const selectOption = (option: any) => {
  emit('update:modelValue', option);
  isOpen.value = false;
};

const isSelected = (option: any) => {
  if (props.modelValue === null || props.modelValue === undefined) return false;
  
  const getVal = (v: any) => (typeof v === 'object' && v !== null && 'value' in v ? v.value : v);
  
  return getVal(props.modelValue) === getVal(option);
};

const displayValue = computed(() => {
  const selected = props.options.find(o => isSelected(o));
  if (selected) {
    return typeof selected === 'object' && 'label' in selected ? selected.label : selected;
  }
  return props.placeholder;
});

const comboboxClasses = computed(() => [
  'combobox',
  `combobox--${props.size}`,
  {
    'combobox--error': props.variant === 'error' || props.error,
    'combobox--disabled': props.disabled,
    'combobox--open': isOpen.value,
  },
]);

const activeOptionId = computed(() => 
  activeIndex.value >= 0 ? getOptionId(activeIndex.value) : undefined
);
</script>

<template>
  <div class="container">
    <slot name="label">
      <label v-if="label" class="label">\{{ label }}</label>
    </slot>
    
    <slot name="trigger" :toggle="toggle" :isOpen="isOpen" :displayValue="displayValue">
      <div
        :class="comboboxClasses"
        @click="toggle"
        @keydown="handleKeyDown"
        :aria-expanded="isOpen"
        role="combobox"
        aria-haspopup="listbox"
        :aria-controls="listboxId"
        :aria-activedescendant="activeOptionId"
        :tabindex="disabled ? -1 : 0"
      >
        <slot name="value">
          <span class="value">\{{ displayValue }}</span>
        </slot>
        <slot name="icon">
          <span class="arrow" aria-hidden="true">▼</span>
        </slot>
      </div>
    </slot>

    <slot name="content" v-if="isOpen">
      <ul :id="listboxId" class="listbox" role="listbox">
        <li
          v-for="(option, i) in options"
          :key="typeof option === 'object' ? option.value || i : option"
          :id="getOptionId(i)"
          @click="selectOption(option)"
          @mouseenter="activeIndex = i"
          :class="['option', { 'option--selected': isSelected(option), 'option--active': activeIndex === i }]"
          role="option"
          :aria-selected="isSelected(option)"
        >
          <slot name="item" :option="option" :isSelected="isSelected(option)">
            <slot name="item-text" :option="option">
              \{{ typeof option === 'object' && 'label' in option ? option.label : option }}
            </slot>
          </slot>
        </li>
      </ul>
    </slot>

    <slot name="error">
      <span v-if="error" class="error" role="alert">\{{ error }}</span>
    </slot>
  </div>
</template>

