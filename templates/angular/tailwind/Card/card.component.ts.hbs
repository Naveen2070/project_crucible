import { Component, Input } from '@angular/core';

const variantClasses: Record<string, string> = {
{{#each variants}}  {{this}}: '{{lookup ../tailwindVariants this}}',
{{/each}} };

const sizeClasses: Record<string, string> = {
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8',
};

@Component({
  selector: 'app-card',
  templateUrl: './card.component.html'
})
export class CardComponent {
  @Input() title = '';
  @Input() variant: {{#each variants}}'{{this}}'{{#unless @last}} | {{/unless}}{{/each}} = 'default';
  @Input() size:    {{#each sizes}}'{{this}}'{{#unless @last}} | {{/unless}}{{/each}} = 'md';
  @Input() className = '';

  get classes(): string {
    const isClickable = this.variant === 'clickable';
    return [
      'rounded-[var(--radius-lg)] border-1.5 transition-all text-left w-full block bg-[var(--color-surface)]',
      {{#if a11y.focusRing}}'focus-visible:outline focus-visible:outline-2 focus-visible:outline-[{{a11y.focusRingColor}}] focus-visible:outline-offset-2',{{/if}}
      variantClasses[this.variant],
      sizeClasses[this.size],
      isClickable ? 'cursor-pointer' : '',
      this.className
    ].filter(Boolean).join(' ');
  }
}
